<!DOCTYPE html>
<!--[if lt IE 7]>      <html class="no-js lt-ie9 lt-ie8 lt-ie7" lang=""> <![endif]-->
<!--[if IE 7]>         <html class="no-js lt-ie9 lt-ie8" lang=""> <![endif]-->
<!--[if IE 8]>         <html class="no-js lt-ie9" lang=""> <![endif]-->
<!--[if gt IE 8]><!-->
<html class="no-js" lang="<%= locale || 'nl' %>">
<!--<![endif]-->

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="<%= t('meta.description', 'Taxiofany — wheelchair-accessible taxis and handicap transport across Belgium. Adapted vans with ramps, lifts and trained drivers. Business and regular taxi rides.') %>">
    <meta name="author" content="<%= t('meta.author', 'Taxiofany') %>">

    <title><%= (typeof pageTitle !== 'undefined' && pageTitle) ? pageTitle : t('meta.title', 'Taxiofany — Handicap & wheelchair-accessible taxi transport') %></title>

    <link rel="shortcut icon" type="image/x-icon" href="/assets/img/favicon.png">

    <link rel="stylesheet" href="/assets/css/bootstrap.min.css">
    <link rel="stylesheet" href="/assets/css/animate.min.css">
    <link rel="stylesheet" href="/assets/css/fontawesome.min.css">
    <link rel="stylesheet" href="/assets/css/line-awesome.min.css">
    <link rel="stylesheet" href="/assets/css/keyframe-animation.css">
    <link rel="stylesheet" href="/assets/css/jquery.datetimepicker.min.css">
    <link rel="stylesheet" href="/assets/css/nice-select.css">
    <link rel="stylesheet" href="/assets/css/venobox.min.css">
    <link rel="stylesheet" href="/assets/css/swiper.min.css">
    <link rel="stylesheet" href="/assets/css/elements.css">
    <link rel="stylesheet" href="/assets/css/header.css">
    <link rel="stylesheet" href="/assets/css/slider.css">
    <link rel="stylesheet" href="/assets/css/blog.css">
    <link rel="stylesheet" href="/assets/css/main.css">
    <link rel="stylesheet" href="/assets/css/responsive.css">
    <link rel="stylesheet" href="/assets/css/client-portal.css">
    <% const sitePrimaryColor = (siteSettings && siteSettings.primaryColor) ? siteSettings.primaryColor : '#1E56B8'; %>
    <style>
        :root {
            --site-primary-color: <%= sitePrimaryColor %>;
        }

        .default-btn,
        .menu-btn,
        .lang-picker-icon {
            background: var(--site-primary-color) !important;
        }

        .default-btn,
        .menu-btn {
            border-color: var(--site-primary-color) !important;
        }

        .default-btn:hover,
        .menu-btn:hover,
        .header-social-share li a:hover,
        .top-header-nav li a:hover,
        .nav-menu li a:hover {
            color: var(--site-primary-color) !important;
        }
    </style>
</head>

<body>
    <!--[if lt IE 8]>
    <p class="browserupgrade">
        <%= t('meta.browserUpgrade.before', 'You are using an outdated browser. Please') %>
        <a href="http://browsehappy.com/"><%= t('meta.browserUpgrade.link', 'upgrade your browser') %></a>
        <%= t('meta.browserUpgrade.after', 'to improve your experience.') %>
    </p><![endif]-->

    <div class="site-preloader">
        <div class="car">
            <div class="strike"></div>
            <div class="strike strike2"></div>
            <div class="strike strike3"></div>
            <div class="strike strike4"></div>
            <div class="strike strike5"></div>
            <div class="car-detail spoiler"></div>
            <div class="car-detail back"></div>
            <div class="car-detail center"></div>
            <div class="car-detail center1"></div>
            <div class="car-detail front"></div>
            <div class="car-detail wheel"></div>
            <div class="car-detail wheel wheel2"></div>
        </div>
    </div><!--/.site-preloader-->
