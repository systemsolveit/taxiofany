<header class="main-header">
    <div class="top-header">
        <div class="container">
            <div class="top-header-wrap">
                <% const headerConfig = (siteSettings && siteSettings.header) ? siteSettings.header : {}; %>
                <% const topTagline = headerConfig.topTagline || t('header.topTagline', 'Wheelchair-accessible taxis across Belgium.'); %>
                <% const mobileTopTagline = topTagline.length > 20 ? topTagline.slice(0, 20) + '...' : topTagline; %>
                <div class="top-left">
                    <p>
                        <span class="top-tagline-full"><%= topTagline %></span>
                        <span class="top-tagline-mobile"><%= mobileTopTagline %></span>
                    </p>
                </div>
                <div class="top-right">
                    <% const headerTopLinks = Array.isArray(headerConfig.topLinks) ? headerConfig.topLinks.filter(function(item){ return item && item.enabled; }) : []; %>
                    <% const headerSocialLinks = Array.isArray(headerConfig.socialLinks) ? headerConfig.socialLinks.filter(function(item){ return item && item.enabled; }) : []; %>
                    <ul class="top-header-nav">
                        <% if (headerTopLinks.length) { %>
                            <% headerTopLinks.forEach(function(item) { %>
                                <% const translationKey = 'header.' + (item.key || ''); %>
                                <% const translatedLabel = translationKey ? t(translationKey, item.label) : item.label; %>
                                <li><a href="<%= item.url %>"><%= translatedLabel %></a></li>
                            <% }) %>
                        <% } else { %>
                            <li><a href="/faqs"><%= t('header.help', 'Help') %></a></li>
                            <li><a href="/contact"><%= t('header.support', 'Support') %></a></li>
                            <li><a href="/faqs"><%= t('header.faq', 'FAQ') %></a></li>
                        <% } %>
                    </ul>
                    <% var currentLocaleItem = (availableLocales || []).find(function(localeItem) { return localeItem.code === locale; }) || { code: locale || 'nl', label: (locale === 'fr' ? 'Français' : (locale === 'en' ? 'English' : 'Nederlands')) }; %>
                    <div class="lang-switch" aria-label="<%= t('header.langSwitcherAria', 'Language switcher') %>">
                        <details class="lang-picker">
                            <summary class="lang-picker-toggle">
                                <span class="lang-picker-icon" aria-hidden="true"><i class="las la-globe"></i></span>
                                <span class="lang-picker-meta">
                                    <small><%= t('header.langPickerLabel', 'Language') %></small>
                                    <strong><%= currentLocaleItem.label %> (<%= currentLocaleItem.code.toUpperCase() %>)</strong>
                                </span>
                                <span class="lang-picker-caret" aria-hidden="true"><i class="las la-angle-down"></i></span>
                            </summary>
                            <div class="lang-picker-menu">
                                <% (availableLocales || []).forEach(function(localeItem) { %>
                                    <a
                                        class="lang-picker-option <%= locale === localeItem.code ? 'active' : '' %>"
                                        href="<%= switchLangUrl(localeItem.code) %>"
                                        title="<%= localeItem.label %>"
                                    >
                                        <span class="lang-picker-option-code"><%= localeItem.code.toUpperCase() %></span>
                                        <span class="lang-picker-option-label"><%= localeItem.label %></span>
                                        <% if (locale === localeItem.code) { %>
                                            <span class="lang-picker-option-check" aria-hidden="true"><i class="las la-check"></i></span>
                                        <% } %>
                                    </a>
                                <% }) %>
                            </div>
                        </details>
                    </div>
                    <% if (headerSocialLinks.length) { %>
                        <ul class="header-social-share">
                            <% headerSocialLinks.forEach(function(item){ %>
                                <li><a href="<%= item.url %>"><i class="<%= item.iconClass %>"></i></a></li>
                            <% }) %>
                        </ul>
                    <% } %>
                </div>
            </div>
        </div>
    </div><!--/.top-header-->
    <div class="mid-header">
        <div class="container">
            <div class="mid-header-wrap">
                <div class="site-logo">
                    <a href="/"><img src="/assets/img/logo-dark.png" alt="<%= t('header.logoAlt', 'Taxiofany logo') %>"></a>
                </div><!--/.site-logo-->
                <ul class="header-info">
                    <li>
                        <div class="header-info-icon">
                            <i class="las la-phone-volume"></i>
                        </div>
                        <div class="header-info-text">
                            <h3><span><%= t('header.callNow', 'Call us now') %></span><a href="tel:<%= String((headerConfig.phone || t('header.fallbackPhone', '+32484262105'))).replace(/[^\d+]/g, '') %>"><%= headerConfig.phone || t('header.fallbackPhone', '+32484262105') %></a></h3>
                        </div>
                    </li>
                    <li>
                        <div class="header-info-icon">
                            <i class="las la-envelope-open"></i>
                        </div>
                        <div class="header-info-text">
                            <h3><span><%= t('header.emailNow', 'Email us now') %></span><%= headerConfig.email || t('header.fallbackEmail', 'info@taxiofany.com') %></h3>
                        </div>
                    </li>
                    <li>
                        <div class="header-info-icon">
                            <i class="las la-map-marked-alt"></i>
                        </div>
                        <div class="header-info-text">
                            <h3><span><%= t('header.locationLabel', 'Find us') %></span><%= headerConfig.location || t('header.fallbackLocation', 'Wemmel Brussels Belgium') %></h3>
                        </div>
                    </li>
                </ul>
            </div>
        </div>
    </div><!--/.mid-header-->
    <div class="nav-menu-wrapper">
        <div class="container">
            <div class="nav-menu-inner">
                <div class="site-logo">
                    <a href="/"><img src="/assets/img/logo-dark.png" alt="<%= t('header.logoAlt', 'Taxiofany logo') %>"></a>
                </div><!--/.site-logo-->
                <div class="header-menu-wrap">
                    <% const hideNav = typeof isHiddenFromMainNav === 'function' ? isHiddenFromMainNav : function(){ return false; }; %>
                    <% const rawNavbarMenu = (siteSettings && Array.isArray(siteSettings.navbarMenu)) ? siteSettings.navbarMenu.filter(function(item){ return item && item.enabled; }) : []; %>
                    <% const configuredMenu = rawNavbarMenu.filter(function(item) { return item && !hideNav(item.url); }); %>
                    <ul class="nav-menu">
                        <% if (configuredMenu.length) { %>
                            <% configuredMenu.forEach(function(item) { %>
                                <% const translationKey = 'header.nav.' + (item.key || ''); %>
                                <% const translatedLabel = translationKey ? t(translationKey, item.label) : item.label; %>
                                <li><a href="<%= item.url %>"><%= translatedLabel %></a></li>
                            <% }) %>
                        <% } else { %>
                            <li class="dropdown_menu">
                                <a href="/"><%= t('header.nav.home') %></a>
                                <ul>
                                    <li><a href="/"><%= t('header.nav.homeDefault') %></a></li>
                                    <li><a href="/home/modern"><%= t('header.nav.homeModern') %></a></li>
                                </ul>
                            </li>
                            <li class="dropdown_menu">
                                <a href="/about"><%= t('header.nav.company') %></a>
                                <ul>
                                    <li><a href="/about"><%= t('header.nav.aboutUs') %></a></li>
                                    <li><a href="/about/company"><%= t('header.nav.aboutCompany') %></a></li>
                                    <li><a href="/services"><%= t('header.nav.services') %></a></li>
                                    <li><a href="/services/details"><%= t('header.nav.serviceDetails') %></a></li>
                                    <li><a href="/book-taxi"><%= t('header.nav.bookRide') %></a></li>
                                </ul>
                            </li>
                            <li class="dropdown_menu">
                                <a href="/taxi"><%= t('header.nav.taxi') %></a>
                                <ul>
                                    <li><a href="/taxi"><%= t('header.nav.taxiList') %></a></li>
                                    <li><a href="/taxi/details"><%= t('header.nav.taxiDetails') %></a></li>
                                </ul>
                            </li>
                            <li><a href="/drivers"><%= t('header.nav.drivers') %></a></li>
                            <li><a href="/blog"><%= t('header.nav.blog') %></a></li>
                            <li><a href="/contact"><%= t('header.nav.contact') %></a></li>
                        <% } %>
                    </ul>
                </div>
                <div class="nav-client-login nav-user-dropdown" aria-label="<%= t('header.accountRegionAria', 'Account') %>">
                    <% if (clientSession && clientSession.user) { %>
                        <% const wl = typeof withLocale === 'function' ? withLocale : function(p) { return p; }; %>
                        <details class="nav-user-details nav-user-dropdown">
                            <summary class="client-login-link nav-user-dropdown-toggle" aria-label="<%= t('header.myAccountMenu', 'My account menu') %>" title="<%= t('header.myAccount', 'My account') %>">
                                <i class="las la-user-circle" aria-hidden="true"></i>
                            </summary>
                            <div class="nav-user-dropdown-menu" role="menu">
                                <a class="dropdown-item" href="<%= wl('/account') %>"><%= t('header.userMenu.dashboard', 'Dashboard') %></a>
                                <a class="dropdown-item" href="<%= wl('/book-taxi') %>"><%= t('header.userMenu.newBooking', 'New booking') %></a>
                                <a class="dropdown-item" href="<%= wl('/account/trips') %>"><%= t('header.userMenu.myTrips', 'My trips') %></a>
                                <div class="dropdown-divider"></div>
                                <a class="dropdown-item" href="<%= wl('/profile') %>"><%= t('header.userMenu.profile', 'Profile') %></a>
                                <a class="dropdown-item" href="<%= wl('/account/password') %>"><%= t('header.userMenu.security', 'Security') %></a>
                                <div class="dropdown-divider"></div>
                                <form method="post" action="<%= wl('/account/logout') %>" class="px-3 py-2 mb-0">
                                    <button type="submit" class="btn btn-sm btn-outline-secondary btn-block"><%= t('account.logout', 'Log out') %></button>
                                </form>
                            </div>
                        </details>
                    <% } else { %>
                        <a href="<%= typeof withLocale === 'function' ? withLocale('/account/login') : '/account/login' %>" class="client-login-link" title="<%= t('header.clientLogin', 'Log in') %>" aria-label="<%= t('header.clientLogin', 'Log in') %>">
                            <i class="las la-sign-in-alt" aria-hidden="true"></i>
                        </a>
                    <% } %>
                </div>
                <div class="menu-right-item">
                    <div class="search-icon dl-search-icon">
                        <i class="las la-search"></i>
                    </div>
                    <div class="sidebox-icon dl-sidebox-icon">
                        <i class="las la-bars"></i>
                    </div>
                    <a href="<%= headerConfig.navButtonUrl || '/book-taxi' %>" class="menu-btn"><%= headerConfig.navButtonLabel || t('header.nav.bookTaxi') %></a>
                </div>
                <div class="mobile-menu-icon">
                    <div class="burger-menu">
                        <div class="line-menu line-half first-line"></div>
                        <div class="line-menu"></div>
                        <div class="line-menu line-half last-line"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!--/.nav-menu-->
</header>
<!--/.main-header-->

<div id="popup-search-box">
    <div class="box-inner-wrap d-flex align-items-center">
        <form id="form" action="#" method="get" role="search">
            <input id="popup-search" type="text" name="s" placeholder="<%= t('header.searchPlaceholder', 'Search handicap transport, bookings…') %>">
            <button id="popup-search-button" type="submit" name="submit">
                <i class="las la-search"></i>
            </button>
        </form>
        <div class="search-close"><i class="las la-times"></i></div>
    </div>
</div>
<!--/.popupsearch-box-->
<div id="searchbox-overlay"></div>

<div id="popup-sidebox" class="popup-sidebox">
    <div class="sidebox-content">
        <div class="site-logo">
            <a href="/"><img src="/assets/img/logo-light.png" alt="<%= t('header.logoAlt', 'Taxiofany logo') %>"></a>
        </div>
        <p><%= t('header.sidebox.description', 'Taxiofany specialises in wheelchair-accessible transport across Belgium: ramp- and lift-equipped vans, trained drivers for safe transfers, plus business and regular taxi rides. TFlex/Mutuelle billing on request.') %></p>
        <ul class="sidebox-list">
            <li class="call"><span><%= t('header.sidebox.callForRide') %></span><%= headerConfig.phone || t('header.sidebox.fallbackPhone', '+32484262105') %></li>
            <li>
                <span><%= t('header.sidebox.findUs') %></span><%= headerConfig.location || t('header.sidebox.fallbackAddress', 'Wemmel Brussels Belgium') %>
            </li>
            <li><span><%= t('header.sidebox.emailNow') %></span><%= headerConfig.email || t('header.sidebox.fallbackEmail', 'info@taxiofany.com') %></li>
        </ul>
    </div>
</div>
<!--/.popup-sidebox-->
<div id="sidebox-overlay"></div>

<style>
    /* Login icon: see header.css .nav-client-login (visible on mobile; was hidden inside .menu-right-item) */
    .lang-switch {
        position: relative;
        display: inline-flex;
        margin-right: 10px;
        vertical-align: middle;
    }

    .lang-picker {
        position: relative;
    }

    .lang-picker summary {
        list-style: none;
    }

    .lang-picker summary::-webkit-details-marker {
        display: none;
    }

    .lang-picker-toggle {
        min-width: 150px;
        border: 1px solid #d8e1ea;
        background: #ffffff;
        color: #17324d;
        border-radius: 999px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.35rem 0.85rem 0.35rem 0.5rem;
        box-shadow: 0 6px 16px rgba(15, 23, 42, 0.08);
        transition: background 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .lang-picker-toggle:hover,
    .lang-picker[open] .lang-picker-toggle {
        background: #f8fbff;
        border-color: #b8c9da;
        box-shadow: 0 10px 18px rgba(15, 23, 42, 0.12);
    }

    .lang-picker-icon {
        width: 28px;
        height: 28px;
        border-radius: 999px;
        background: linear-gradient(135deg, #1E56B8, #2563eb);
        color: #fff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        flex: 0 0 auto;
    }

    .lang-picker-meta {
        display: flex;
        flex-direction: column;
        line-height: 1.05;
        text-align: left;
    }

    .lang-picker-meta small {
        font-size: 10px;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .lang-picker-meta strong {
        font-size: 12px;
        font-weight: 700;
        color: #17324d;
    }

    .lang-picker-caret {
        font-size: 14px;
        color: #4a6680;
        margin-left: auto;
    }

    .lang-picker-menu {
        position: absolute;
        top: calc(100% + 0.55rem);
        right: 0;
        min-width: 220px;
        padding: 0.45rem;
        background: #ffffff;
        border-radius: 1rem;
        box-shadow: 0 18px 32px rgba(15, 23, 42, 0.18);
        z-index: 40;
    }

    .lang-picker-option {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        text-decoration: none;
        color: #17324d;
        padding: 0.7rem 0.8rem;
        border-radius: 0.8rem;
        transition: background 0.2s ease, color 0.2s ease;
    }

    .lang-picker-option:hover {
        background: #eef5fb;
        color: #17324d;
    }

    .lang-picker-option.active {
        background: linear-gradient(135deg, #e8f2fb, #f4f9fd);
        color: #17324d;
        font-weight: 700;
    }

    .lang-picker-option-code {
        width: 42px;
        height: 32px;
        border-radius: 999px;
        background: #17324d;
        color: #fff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.06em;
        flex: 0 0 auto;
    }

    .lang-picker-option.active .lang-picker-option-code {
        background: #c1292e;
    }

    .lang-picker-option-label {
        font-size: 13px;
        flex: 1 1 auto;
    }

    .lang-picker-option-check {
        color: #0e7490;
        font-size: 15px;
    }

    @media (max-width: 767.98px) {
        .lang-picker-toggle {
            min-width: auto;
            padding-right: 0.7rem;
        }

        .lang-picker-meta small,
        .lang-picker-meta strong {
            display: none;
        }

        .lang-picker-menu {
            right: auto;
            left: 0;
            min-width: 180px;
        }
    }
</style>
