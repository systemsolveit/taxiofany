<header class="main-header">
    <div class="top-header">
        <div class="container">
            <div class="top-header-wrap">
                <div class="top-left">
                    <p><%= t('header.topTagline') %></p>
                </div>
                <div class="top-right">
                    <ul class="top-header-nav">
                        <li><a href="/faqs"><%= t('header.help') %></a></li>
                        <li><a href="/contact"><%= t('header.support') %></a></li>
                        <li><a href="/faqs"><%= t('header.faq') %></a></li>
                    </ul>
                    <div class="lang-switch" aria-label="Language switcher">
                        <a class="lang-btn <%= locale === 'nl' ? 'active' : '' %>" href="<%= switchLangUrl('nl') %>" title="Nederlands">
                            <span aria-hidden="true">🇧🇪</span>
                        </a>
                        <a class="lang-btn <%= locale === 'en' ? 'active' : '' %>" href="<%= switchLangUrl('en') %>" title="English">
                            <span aria-hidden="true">🇬🇧</span>
                        </a>
                    </div>
                    <ul class="header-social-share">
                        <li><a href="#"><i class="fab fa-facebook-f"></i></a></li>
                        <li><a href="#"><i class="fab fa-twitter"></i></a></li>
                        <li><a href="#"><i class="fab fa-instagram"></i></a></li>
                        <li><a href="#"><i class="fab fa-linkedin"></i></a></li>
                    </ul>
                </div>
            </div>
        </div>
    </div><!--/.top-header-->
    <div class="mid-header">
        <div class="container">
            <div class="mid-header-wrap">
                <div class="site-logo">
                    <a href="/"><img src="/assets/img/logo-dark.png" alt="Logo"></a>
                </div><!--/.site-logo-->
                <ul class="header-info">
                    <li>
                        <div class="header-info-icon">
                            <i class="las la-phone-volume"></i>
                        </div>
                        <div class="header-info-text">
                            <h3><span><%= t('header.callNow') %></span><a href="tel:5267214392">5267-214-392</a></h3>
                        </div>
                    </li>
                    <li>
                        <div class="header-info-icon">
                            <i class="las la-envelope-open"></i>
                        </div>
                        <div class="header-info-text">
                            <h3><span><%= t('header.emailNow') %></span>Info.ridek@mail.com</h3>
                        </div>
                    </li>
                    <li>
                        <div class="header-info-icon">
                            <i class="las la-map-marked-alt"></i>
                        </div>
                        <div class="header-info-text">
                            <h3><span><%= t('header.locationLabel') %></span>New York, USA - 2386</h3>
                        </div>
                    </li>
                </ul>
            </div>
        </div>
    </div><!--/.mid-header-->
    <div class="nav-menu-wrapper">
        <div class="container">
            <div class="nav-menu-inner">
                <div class="site-logo">
                    <a href="/"><img src="/assets/img/logo-dark.png" alt="Logo"></a>
                </div><!--/.site-logo-->
                <div class="header-menu-wrap">
                    <ul class="nav-menu">
                        <li class="dropdown_menu">
                            <a href="/"><%= t('header.nav.home') %></a>
                            <ul>
                                <li><a href="/"><%= t('header.nav.homeDefault') %></a></li>
                                <li><a href="/home/modern"><%= t('header.nav.homeModern') %></a></li>
                            </ul>
                        </li>
                        <li class="dropdown_menu">
                            <a href="/about"><%= t('header.nav.company') %></a>
                            <ul>
                                <li><a href="/about"><%= t('header.nav.aboutUs') %></a></li>
                                <li><a href="/about/company"><%= t('header.nav.aboutCompany') %></a></li>
                                <li><a href="/services"><%= t('header.nav.services') %></a></li>
                                <li><a href="/services/details"><%= t('header.nav.serviceDetails') %></a></li>
                                <li><a href="/book-taxi"><%= t('header.nav.bookRide') %></a></li>
                            </ul>
                        </li>
                        <li class="dropdown_menu">
                            <a href="/taxi"><%= t('header.nav.taxi') %></a>
                            <ul>
                                <li><a href="/taxi"><%= t('header.nav.taxiList') %></a></li>
                                <li><a href="/taxi/details"><%= t('header.nav.taxiDetails') %></a></li>
                            </ul>
                        </li>
                        <li class="dropdown_menu">
                            <a href="#"><%= t('header.nav.pages') %></a>
                            <ul>
                                <li><a href="/drivers"><%= t('header.nav.drivers') %></a></li>
                                <li><a href="/drivers/details"><%= t('header.nav.driverDetails') %></a></li>
                                <li><a href="/testimonials"><%= t('header.nav.reviews') %></a></li>
                                <li><a href="/faqs"><%= t('header.nav.helpFaq') %></a></li>
                                <li><a href="/404"><%= t('header.nav.error404') %></a></li>
                            </ul>
                        </li>
                        <li class="dropdown_menu">
                            <a href="/blog"><%= t('header.nav.blog') %></a>
                            <ul>
                                <li><a href="/blog"><%= t('header.nav.blogGrid') %></a></li>
                                <li><a href="/blog/classic"><%= t('header.nav.blogClassic') %></a></li>
                                <li><a href="/blog/details"><%= t('header.nav.blogDetails') %></a></li>
                            </ul>
                        </li>
                        <li><a href="/contact"><%= t('header.nav.contact') %></a></li>
                    </ul>
                </div>
                <div class="menu-right-item">
                    <div class="search-icon dl-search-icon">
                        <i class="las la-search"></i>
                    </div>
                    <div class="sidebox-icon dl-sidebox-icon">
                        <i class="las la-bars"></i>
                    </div>
                    <a href="/book-taxi" class="menu-btn"><%= t('header.nav.bookTaxi') %></a>
                </div>
                <div class="mobile-menu-icon">
                    <div class="burger-menu">
                        <div class="line-menu line-half first-line"></div>
                        <div class="line-menu"></div>
                        <div class="line-menu line-half last-line"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!--/.nav-menu-->
</header>
<!--/.main-header-->

<div id="popup-search-box">
    <div class="box-inner-wrap d-flex align-items-center">
        <form id="form" action="#" method="get" role="search">
            <input id="popup-search" type="text" name="s" placeholder="Type keywords here...">
            <button id="popup-search-button" type="submit" name="submit">
                <i class="las la-search"></i>
            </button>
        </form>
        <div class="search-close"><i class="las la-times"></i></div>
    </div>
</div>
<!--/.popupsearch-box-->
<div id="searchbox-overlay"></div>

<div id="popup-sidebox" class="popup-sidebox">
    <div class="sidebox-content">
        <div class="site-logo">
            <a href="/"><img src="/assets/img/logo-light.png" alt="logo"></a>
        </div>
        <p><%= t('header.sidebox.description') %></p>
        <ul class="sidebox-list">
            <li class="call"><span><%= t('header.sidebox.callForRide') %></span>5267-214-392</li>
            <li>
                <span><%= t('header.sidebox.findUs') %></span>Halk Street New York, USA - 2386
            </li>
            <li><span><%= t('header.sidebox.emailNow') %></span>Info.ridek@mail.com</li>
        </ul>
    </div>
</div>
<!--/.popup-sidebox-->
<div id="sidebox-overlay"></div>

<style>
    .lang-switch {
        display: inline-flex;
        gap: 6px;
        margin-right: 10px;
        vertical-align: middle;
    }

    .lang-btn {
        border: 1px solid rgba(255, 255, 255, 0.35);
        background: transparent;
        text-decoration: none;
        color: #fff;
        border-radius: 999px;
        width: 30px;
        height: 30px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        font-size: 14px;
    }

    .lang-btn:hover {
        background: rgba(255, 255, 255, 0.2);
    }

    .lang-btn.active {
        background: rgba(255, 255, 255, 0.35);
    }
</style>
