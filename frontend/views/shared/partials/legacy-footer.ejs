<footer class="footer-section">
    <div class="footer-top-wrap bg-grey">
        <div class="container">
            <div class="footer-top">
                <div class="row align-items-end">
                    <div class="col-lg-8">
                        <div class="brand">
                            <a class="footer-logo" href="/"><img src="/assets/img/logo-light.png" alt="<%= t('footer.logoAlt', 'Taxiofany logo') %>"></a>
                            <p><%= t('footer.description') %></p>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="footer-call">
                            <i class="las la-phone-volume"></i>
                            <% const footerHeaderConfig = (siteSettings && siteSettings.header) ? siteSettings.header : {}; %>
                            <% const footerPhone = footerHeaderConfig.phone || t('footer.fallbackPhone', '+32484262105'); %>
                            <p><span><%= t('footer.callForTaxi') %></span><a href="tel:<%= String(footerPhone).replace(/[^\d+]/g, '') %>"><%= footerPhone %></a></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!--/.footer-top-wrap-->
    <div class="footer-mid-wrap">
        <div class="container">
            <div class="row">
                <div class="col-lg-3 col-md-6 sm-padding">
                    <div class="footer-item">
                        <div class="widget-title">
                            <h3><%= t('footer.workingHours') %></h3>
                        </div>
                        <ul class="footer-contact">
                            <li><span><%= t('footer.openEveryDay', 'Every day:') %></span><%= t('footer.hours.alwaysOpen', '24/7') %></li>
                        </ul>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6 sm-padding">
                    <div class="footer-item footer-list">
                        <div class="widget-title">
                            <h3><%= t('footer.usefulLinks') %></h3>
                        </div>
                        <ul class="footer-links">
                            <li><a href="/book-taxi"><%= t('footer.taxiBooking') %></a></li>
                            <li><a href="/faqs"><%= t('footer.helpCenter') %></a></li>
                            <li><a href="/about"><%= t('footer.privacyPolicy') %></a></li>
                            <li><a href="/about/company"><%= t('footer.terms') %></a></li>
                            <li><a href="/contact"><%= t('footer.contactUs') %></a></li>
                        </ul>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6 sm-padding">
                    <div class="footer-item">
                        <div class="widget-title">
                            <h3><%= t('footer.headOffice') %></h3>
                        </div>
                        <ul class="footer-contact">
                            <li><span><%= t('footer.location') %></span><%= footerHeaderConfig.location || t('footer.fallbackAddress', 'Wemmel Brussels Belgium') %></li>
                            <li><span><%= t('footer.joinUs') %></span><%= footerHeaderConfig.email || t('footer.fallbackEmail', 'info@taxiofany.com') %></li>
                        </ul>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6 sm-padding">
                    <div class="footer-item subscribe-wrap">
                        <div class="widget-title">
                            <h3><%= t('footer.newsletter') %></h3>
                        </div>
                        <form action="#" class="subscribe-form">
                            <input class="form-control" type="email" name="email" placeholder="<%= t('footer.yourEmail') %>" required="">
                            <input type="hidden" name="action" value="mailchimpsubscribe">
                            <button class="submit"><%= t('footer.subscribeNow') %></button>
                            <div class="clearfix"></div>
                            <div id="subscribe-result">
                                <div class="subscription-success"></div>
                                <div class="subscription-error"></div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <div class="running-taxi">
            <div class="taxi"></div>
            <div class="taxi-2"></div>
            <div class="taxi-3"></div>
        </div>
    </div>
    <!--/.footer-mid-wrap-->
    <div class="copyright-wrap">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-left mb-2 mb-md-0">
                    <p>
                        © <%= new Date().getFullYear() %>
                        <strong>Taxiofany</strong>.
                        <%= t('footer.rightsReserved', 'All rights reserved.') %>
                    </p>
                </div>
                <div class="col-md-6 text-center text-md-right">
                    <p>
                        <%= t('footer.developedBy', 'Developed by') %>
                        <a class="copyright-brand-link" href="https://systemsolveit.com" target="_blank" rel="noopener noreferrer">SystemSolve IT</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
    <!--/.copyright-wrap-->
</footer>
<!--/.footer-section-->

<% const stickyWhatsapp = (siteSettings && siteSettings.stickyIcons && siteSettings.stickyIcons.whatsapp) || {}; %>
<%
    function normalizeWhatsappDigits(value) {
        const raw = String(value || '').trim();
        const sanitized = raw.replace(/[^\d+]/g, '');
        if (!sanitized) return '';
        if (sanitized.startsWith('+')) return sanitized.slice(1).replace(/\D/g, '');
        const digits = sanitized.replace(/\D/g, '').replace(/^0+/, '');
        return digits.startsWith('32') ? digits : '32' + digits;
    }
    const stickyWhatsappDigits = normalizeWhatsappDigits(stickyWhatsapp.phone || (siteSettings && siteSettings.header && siteSettings.header.phone) || '+32484262105');
%>
<% const stickyWhatsappMessage = stickyWhatsapp.message || t('footer.whatsapp.defaultMessage', 'Hello Taxiofany, I would like to book a taxi.'); %>
<% if (stickyWhatsapp.enabled !== false && stickyWhatsappDigits) { %>
    <a
        class="sticky-whatsapp-button"
        href="https://wa.me/<%= stickyWhatsappDigits %>?text=<%= encodeURIComponent(stickyWhatsappMessage) %>"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="<%= t('footer.whatsapp.ariaLabel', 'Chat with Taxiofany on WhatsApp') %>"
        style="--sticky-whatsapp-color: <%= stickyWhatsapp.color || '#25d366' %>;"
    >
        <i class="lab la-whatsapp" aria-hidden="true"></i>
    </a>
<% } %>

<div id="scrollup">
    <button id="scroll-top" class="scroll-to-top">
        <i class="las la-arrow-up"></i>
    </button>
</div>
<!--scrollup-->

<div class="dl-cursor">
    <div class="cursor-icon-holder"><i class="las la-times"></i></div>
</div>
<!--/.dl-cursor-->

