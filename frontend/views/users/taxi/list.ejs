<%- include('../../shared/partials/legacy-head') %>
<%- include('../../shared/partials/legacy-header-nav') %>

<section class="page-header">
        <div class="page-header-shape"></div>
        <div class="container">
            <div class="page-header-info">
                <h4><%= t('pages.users.taxi.list.our_taxi_lists', 'Our vehicles') %></h4>
                <h2><%= t('pages.users.taxi.list.feel_your_journey', 'Wheelchair-accessible') %> <br> <%= t('pages.users.taxi.list.with', 'fleets with') %> <span><%= t('pages.users.taxi.list.taxiofany', 'Taxiofany') %></span></h2>
                <p><%= t('pages.users.taxi.list.everything_your_taxi_business', 'Vans with ramps, lifts, secure restraints and space for companions—plus business and standard taxis') %> <br><%= t('pages.users.taxi.list.needs_is_already_here', 'when you need a conventional ride.') %> </p>
            </div>
        </div>
    </section>
    <!--/.page-header-->
    
    <section class="our-taxi padding">
        <div class="container">
            <div class="row">
                <% if (Array.isArray(cars) && cars.length) { %>
                    <% cars.forEach(function(car) { %>
                        <div class="col-lg-4 col-md-6 sm-padding">
                            <div class="pricing-item">
                                <div class="pricing-head-wrap">
                                    <div class="pricing-car">
                                        <img src="<%= car.image || '/assets/img/pricing-car.png' %>" alt="<%= t('taxi.carImageAlt', 'Wheelchair-accessible taxi van') %>">
                                        <div class="price">$<%= Number(car.pricePerKm || 0).toFixed(2) %>/km</div>
                                    </div>
                                </div>
                                <div class="pricing-head">
                                    <h3><a href="/taxi/details/<%= encodeURIComponent(car.slug) %>"><%= car.title || '' %></a></h3>
                                    <span class="location"><%= car.city || '-' %></span>
                                </div>
                                <ul class="pricing-list">
                                    <li><%= t('pages.users.taxi.list.initial_charge', 'Initial Charge:') %> <span>$<%= Number(car.initialCharge || 0).toFixed(2) %></span></li>
                                    <li><%= t('pages.users.taxi.list.per_mile_km', 'Per Mile/KM:') %> <span>$<%= Number(car.perMileKm || 0).toFixed(2) %></span></li>
                                    <li><%= t('pages.users.taxi.list.per_stopped_trafic', 'Per Stopped Trafic:') %> <span>$<%= Number(car.perStoppedTraffic || 0).toFixed(2) %></span></li>
                                    <li><%= t('pages.users.taxi.list.passengers', 'Passengers:') %> <span><%= Number(car.passengers || 0) %> <%= t('pages.users.taxi.list.4_person', 'Person') %></span></li>
                                    <li><a href="/book-taxi" class="default-btn"><%= t('pages.users.taxi.list.book_taxi_now', 'Book Taxi Now') %></a></li>
                                </ul>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="col-12 text-center text-muted">
                        <p><%= t('pages.users.taxi.list.noCars', 'No vehicles published yet—add your accessible vans and taxis in the admin panel.') %></p>
                    </div>
                <% } %>
            </div>
        </div>
    </section><!--/.our-taxi-->

    <%- include('../../shared/partials/legacy-footer') %>
