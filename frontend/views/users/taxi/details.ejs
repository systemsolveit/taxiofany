<%- include('../../shared/partials/legacy-head') %>
<%- include('../../shared/partials/legacy-header-nav') %>

<section class="page-header">
        <div class="page-header-shape"></div>
        <div class="container">
            <div class="page-header-info">
                <h4><%= t('pages.users.taxi.details.service_details', 'Vehicle details') %></h4>
                <h2><%= t('pages.users.taxi.details.feel_your_journey', 'Accessible transport') %> <br> <%= t('pages.users.taxi.details.with', 'with') %> <span><%= t('pages.users.taxi.details.taxiofany', 'Taxiofany') %></span></h2>
                <p><%= t('pages.users.taxi.details.everything_your_taxi_business', 'Each listed vehicle is maintained for safe handicap and wheelchair transport') %> <br><%= t('pages.users.taxi.details.needs_is_already_here', 'with specs published by our fleet team.') %> </p>
            </div>
        </div>
    </section>
    <!--/.page-header-->

    <section class="taxi-details bd-bottom padding">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <div class="taxi-details-img">
                        <img src="<%= car && car.detailImage ? car.detailImage : '/assets/img/car-2.png' %>" alt="<%= t('taxi.imageAlt', 'Accessible taxi or van') %>">
                        <div class="price"><i class="las la-calendar-check"></i><%= t('taxi.priceOnReservation', 'Price on reservation') %></div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="section-heading">
                        <h4><span></span><%= t('pages.users.taxi.details.introducing', 'Fleet highlight') %></h4>
                        <h2><%= car && car.slug ? t('car.' + car.slug + '.title', car.title || '') : t('pages.users.taxi.details.mercedes_maybach_haute_voiture_2024', 'Renault Trafic Access (example)') %></h2>
                        <% const detailDesc = car && car.slug ? t('car.' + car.slug + '.description', car.description || '') : ''; %>
                        <p style="white-space:pre-line;"><%= detailDesc && String(detailDesc).trim() ? detailDesc : t('pages.users.taxi.details.we_successfully_cope_with_tasks_of_varying_compl', 'Example spec: lowered floor, side ramp or rear lift, ISO-fixed wheelchair positions, 4-point straps, companion seating and climate control for comfortable medical and daily journeys across Belgium.') %></p>
                    </div>
                    <a href="/book-taxi" class="default-btn mt-30"><%= t('pages.users.taxi.details.book_your_ride', 'Book accessible ride') %></a>
                </div>
            </div>
        </div>
    </section>
    <!--/.taxi-details-->

    <section class="related-taxi bg-grey padding">
        <div class="container">
            <div class="section-heading text-center mb-40">
                <h4><span></span><%= t('pages.users.taxi.details.our_more_taxis', 'More fleet options') %></h4>
                <h2><%= t('pages.users.taxi.details.related_taxis_to_ride', 'Related vehicles') %></h2>
                <p><%= t('pages.users.taxi.details.relatedIntroLine1', 'Browse additional wheelchair vans and taxis—same trained dispatch') %> <br><%= t('pages.users.taxi.details.guarantees_and_regularly_master_new_technologies', 'and paperwork support when eligible.') %></p>
            </div>
            <!--/.section-heading-->
            <div class="swiper-outside">
                <div class="taxi-carousel swiper-container">
                    <div class="swiper-wrapper">
                        <% if (Array.isArray(relatedCars) && relatedCars.length) { %>
                            <% relatedCars.forEach(function(item) { %>
                                <div class="swiper-slide">
                                    <div class="pricing-item">
                                        <div class="pricing-head-wrap">
                                            <div class="pricing-car">
                                                <img src="<%= item.image || '/assets/img/pricing-car.png' %>" alt="<%= t('taxi.carImageAlt', 'Wheelchair-accessible taxi van') %>">
                                                <div class="price"><%= t('taxi.priceOnReservation', 'Price on reservation') %></div>
                                            </div>
                                        </div>
                                        <div class="pricing-head">
                                            <h3><a href="/taxi/details/<%= encodeURIComponent(item.slug) %>"><%= t('car.' + item.slug + '.title', item.title || '') %></a></h3>
                                        </div>
                                        <% const relDesc = t('car.' + item.slug + '.description', item.description || ''); %>
                                        <% if (relDesc && String(relDesc).trim()) { %>
                                            <p class="taxi-card-description sm-padding" style="padding-top:0;padding-bottom:12px;margin:0;color:#555;line-height:1.55;white-space:pre-line;"><%= relDesc %></p>
                                        <% } %>
                                        <ul class="pricing-list">
                                            <li><a href="/book-taxi" class="default-btn"><%= t('pages.users.taxi.details.book_taxi_now', 'Book ride') %></a></li>
                                        </ul>
                                    </div>
                                </div>
                            <% }) %>
                        <% } %>
                    </div>
                </div>
                <!-- Carousel Arrows -->
                <div class="swiper-nav swiper-next"><i class="las la-long-arrow-alt-right"></i></div>
                <div class="swiper-nav swiper-prev"><i class="las la-long-arrow-alt-left"></i></div>
            </div>
        </div>
    </section>
    <!--/.related-taxi-->

    <%- include('../../shared/partials/legacy-footer') %>
