<% 
  const d = driver || {};
  const slug = d.slug ? encodeURIComponent(String(d.slug)) : '';
  const detailPath = slug ? ('/drivers/details/' + slug) : '/drivers/details';
  const href = typeof withLocale === 'function' ? withLocale(detailPath) : detailPath;
  const img = d.image || '/assets/img/team-1.jpg';
%>
<div class="col-lg-3 col-md-6 sm-padding wow fade-in-bottom" data-wow-delay="200ms">
  <div class="team-item">
    <div class="team-thumb">
      <img src="<%= img %>" alt="">
    </div>
    <div class="team-content">
      <h3><a href="<%= href %>"><%= d.fullName || '' %></a></h3>
      <h4><%= d.roleTitle || d.carType || '' %></h4>
    </div>
  </div>
</div>
