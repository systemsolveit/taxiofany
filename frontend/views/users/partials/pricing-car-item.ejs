<% 
  const c = car || {};
  const slug = c.slug ? encodeURIComponent(String(c.slug)) : '';
  const detailPath = slug ? ('/taxi/details/' + slug) : '/taxi/details';
  const href = (typeof withLocale === 'function' ? withLocale(detailPath) : detailPath);
  const img = c.image || '/assets/img/pricing-car.png';
  const ppk = Number(c.pricePerKm);
  const priceLabel = Number.isFinite(ppk) ? ('$' + ppk.toFixed(2) + '/km') : '';
  const initC = Number(c.initialCharge);
  const perMile = Number(c.perMileKm);
  const perStop = Number(c.perStoppedTraffic);
  const pass = c.passengers != null ? c.passengers : '';
%>
<div class="col-lg-4 col-md-6 sm-padding">
  <div class="pricing-item">
    <div class="pricing-head-wrap">
      <div class="pricing-car">
        <img src="<%= img %>" alt="">
        <% if (priceLabel) { %><div class="price"><%= priceLabel %></div><% } %>
      </div>
    </div>
    <div class="pricing-head">
      <h3><a href="<%= href %>"><%= c.title || '' %></a></h3>
      <span class="location"><%= c.city || '' %></span>
    </div>
    <ul class="pricing-list">
      <li><%= t('home.pricing.initialCharge', 'Initial charge') %> <span><%= Number.isFinite(initC) ? ('$' + initC.toFixed(2)) : '-' %></span></li>
      <li><%= t('home.pricing.perMile', 'Per mile/km') %> <span><%= Number.isFinite(perMile) ? ('$' + perMile.toFixed(2)) : '-' %></span></li>
      <li><%= t('home.pricing.perStoppedTraffic', 'Per stopped traffic') %> <span><%= Number.isFinite(perStop) ? ('$' + perStop.toFixed(2)) : '-' %></span></li>
      <li><%= t('home.pricing.passengers', 'Passengers') %> <span><%= pass %></span></li>
      <li><a href="<%=(typeof withLocale === 'function' ? withLocale('/book-taxi') : '/book-taxi')%>" class="default-btn"><%= t('home.pricing.bookTaxiNow', 'Book accessible ride') %></a></li>
    </ul>
  </div>
</div>
