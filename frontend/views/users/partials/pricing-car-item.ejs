<% 
  const c = car || {};
  const slugRaw = c.slug ? String(c.slug).trim() : '';
  const slug = slugRaw ? encodeURIComponent(slugRaw) : '';
  const detailPath = slug ? ('/taxi/details/' + slug) : '/taxi/details';
  const href = (typeof withLocale === 'function' ? withLocale(detailPath) : detailPath);
  const img = c.image || '/assets/img/pricing-car.png';
  const desc = slugRaw ? t('car.' + slugRaw + '.description', c.description || '') : (c.description || '');
  const descTrim = desc && String(desc).trim() ? String(desc).trim() : '';
  const titleTxt = slugRaw ? t('car.' + slugRaw + '.title', c.title || '') : (c.title || '');
%>
<div class="col-lg-4 col-md-6 sm-padding">
  <div class="pricing-item">
    <div class="pricing-head-wrap">
      <div class="pricing-car">
        <img src="<%= img %>" alt="">
        <div class="price"><%= t('taxi.priceOnReservation', 'Price on reservation') %></div>
      </div>
    </div>
    <div class="pricing-head">
      <h3><a href="<%= href %>"><%= titleTxt %></a></h3>
    </div>
    <% if (descTrim) { %>
      <p class="taxi-card-description sm-padding" style="padding-top:0;padding-bottom:12px;margin:0;color:#555;line-height:1.55;white-space:pre-line;"><%= desc %></p>
    <% } %>
    <ul class="pricing-list">
      <li><a href="<%=(typeof withLocale === 'function' ? withLocale('/book-taxi') : '/book-taxi')%>" class="default-btn"><%= t('home.pricing.bookTaxiNow', 'Book accessible ride') %></a></li>
    </ul>
  </div>
</div>
