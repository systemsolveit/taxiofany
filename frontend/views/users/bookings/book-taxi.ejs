<%- include('../../shared/partials/legacy-head') %>
<%- include('../../shared/partials/legacy-header-nav') %>
<% const bookingAuthed = typeof bookingPrefillEmail !== 'undefined' && bookingPrefillEmail; %>
<% const wl = typeof withLocale === 'function' ? withLocale : function (p) { return p; }; %>

<section class="page-header">
        <div class="page-header-shape"></div>
        <div class="container">
            <div class="page-header-info">
                <h4><%= t('pages.users.bookings.book-taxi.get_your_cab', 'Get Your Cab!') %></h4>
                <h2><%= t('pages.users.bookings.book-taxi.book_your', 'Book Your') %> <span><%= t('pages.users.bookings.book-taxi.ride', 'Ride') %></span></h2>
                <p><%= t('pages.users.bookings.book-taxi.everything_your_taxi_business', 'Everything your taxi business') %> <br><%= t('pages.users.bookings.book-taxi.needs_is_already_here', 'needs is already here!') %> </p>
            </div>
        </div>
    </section>
    <!--/.page-header-->

    <div class="taxi-booking bg-grey padding">
        <div class="container">
            <div class="row">
                <div class="col-lg-10 offset-lg-1">
                    <form action="<%= wl('/book-taxi') %>" method="post" id="book-taxi-ride" data-booking-authed="<%= bookingAuthed ? '1' : '0' %>">
                        <div class="taxi-booking-form">
                            <% if (bookingAuthed) { %>
                            <div class="form-field booking-identity-field">
                                <i class="las la-user-tie"></i>
                                <input type="text" id="full-name" name="full-name" class="form-control booking-input-readonly" placeholder="Your Name" value="<%= bookingPrefillName %>" autocomplete="name" readonly required aria-readonly="true">
                            </div>
                            <div class="form-field booking-identity-field">
                                <i class="las la-envelope-open"></i>
                                <input type="email" id="email" name="email" class="form-control booking-input-readonly" placeholder="Email" value="<%= bookingPrefillEmail %>" autocomplete="email" readonly required aria-readonly="true">
                            </div>
                            <% } else { %>
                            <div class="form-field">
                                <i class="las la-user-tie"></i>
                                <input type="text" id="full-name" name="full-name" class="form-control" placeholder="Your Name" value="<%= typeof bookingPrefillName !== 'undefined' ? bookingPrefillName : '' %>" autocomplete="name" required>
                            </div>
                            <div class="form-field">
                                <i class="las la-envelope-open"></i>
                                <input type="email" id="email" name="email" class="form-control" placeholder="Email" value="<%= typeof bookingPrefillEmail !== 'undefined' ? bookingPrefillEmail : '' %>" autocomplete="email" required>
                            </div>
                            <% } %>
                            <div class="form-field">
                                <i class="las la-tags"></i>
                                <select name="package-type" id="package-type" class="niceSelect">
                                    <option value="standard"><%= t('pages.users.bookings.book-taxi.standard', 'Standard') %></option>
                                    <option value="business"><%= t('pages.users.bookings.book-taxi.business', 'Business') %></option>
                                    <option value="economy"><%= t('pages.users.bookings.book-taxi.economy', 'Economy') %></option>
                                    <option value="vip-spacial"><%= t('pages.users.bookings.book-taxi.vip_spacial', 'VIP Spacial') %></option>
                                    <option value="comfort"><%= t('pages.users.bookings.book-taxi.comfort', 'Comfort') %></option>
                                </select>
                            </div>
                            <div class="form-field">
                                <i class="las la-user-friends"></i>
                                <select name="passengers" id="passengers" class="niceSelect">
                                    <option value="1"><%= t('pages.users.bookings.book-taxi.1_person', '1 Person') %></option>
                                    <option value="2"><%= t('pages.users.bookings.book-taxi.2_person', '2 Person') %></option>
                                    <option value="3"><%= t('pages.users.bookings.book-taxi.3_person', '3 Person') %></option>
                                    <option value="4"><%= t('pages.users.bookings.book-taxi.4_person', '4 Person') %></option>
                                    <option value="5"><%= t('pages.users.bookings.book-taxi.5_person', '5 Person') %></option>
                                </select>
                            </div>
                            <div class="form-field">
                                <i class="las la-map-marker"></i>
                                <input type="text" id="start-dest" name="start-dest" class="form-control" placeholder="Start Destination" required>
                            </div>
                            <div class="form-field">
                                <i class="las la-map-marker"></i>
                                <input type="text" id="end-dest" name="end-dest" class="form-control" placeholder="End Destination" required>
                            </div>
                            <div class="form-field">
                                <i class="las la-calendar"></i>
                                <input type="text" id="ride-date" name="ride-date" class="form-control date-picker" placeholder="Select Date" required>
                            </div>
                            <div class="form-field">
                                <i class="las la-clock"></i>
                                <input type="text" id="ride-time" name="ride-time" class="form-control time-picker" placeholder="Select Time" required>
                            </div>
                            <div class="form-field">
                                <button id="submit" class="default-btn" type="submit"><%= t('pages.users.bookings.book-taxi.book_your_taxi', 'Book Your Taxi') %></button>
                            </div>
                        </div>
                        <div id="form-messages" class="alert" role="alert"></div>
                    </form><!-- Booking Form -->
                </div>
            </div>
        </div>
    </div>
    <!--/.booking-form-->

    <%- include('../../shared/partials/legacy-footer') %>
