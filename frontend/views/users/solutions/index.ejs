<%- include('../../shared/partials/legacy-head') %>
<%- include('../../shared/partials/legacy-header-nav') %>
<section class="page-header">
  <div class="page-header-shape"></div>
  <div class="container">
    <div class="page-header-info">
      <h4><%= t('pages.users.solutions.solutions', 'Solutions') %></h4>
      <h2><%= t('solutions.header.title', 'Accessible') %> <span><%= t('solutions.header.highlight', 'transport') %></span></h2>
      <p><%= t('solutions.header.description', 'Handicap and wheelchair-accessible transport leads our solutions—followed by business shuttles and everyday taxi, all bookable the same way.') %></p>
    </div>
  </div>
</section>

<section class="service-section bg-grey bd-bottom padding">
  <div class="container">
    <div class="section-heading text-center mb-40">
      <h4><span></span><%= t('home.services.eyebrow', 'What we offer') %></h4>
      <h2><%= t('home.services.titleStart', 'Handicap transport first') %> <%= t('home.services.titleEnd', '—then business & regular taxi') %></h2>
    </div>
    <div class="row">
      <% const solutionServices = typeof services !== 'undefined' && Array.isArray(services) ? services : []; %>
      <% if (solutionServices.length) { solutionServices.forEach(function(item) { %>
        <div class="col-lg-4 col-sm-6 padding-15">
          <div class="service-item">
            <div class="service-thumb">
              <img src="<%= item.coverImage || '/assets/img/banner-1.jpg' %>" alt="<%= t('service.imageAlt', 'Accessible transport service') %>">
              <div class="service-shape-wrap"><div class="service-shape"></div></div>
              <div class="service-car"><img src="<%= item.serviceCarImage || '/assets/img/car-1.png' %>" alt="<%= t('taxi.carImageAlt', 'Wheelchair-accessible taxi van') %>"></div>
            </div>
            <div class="service-content">
              <h3><a href="/services/details/<%= encodeURIComponent(item.slug) %>"><%= item.slug ? t('service.' + item.slug + '.title', item.title || '') : (item.title || '') %></a></h3>
              <p><%= item.slug ? t('service.' + item.slug + '.shortDescription', item.shortDescription || item.description || '') : (item.shortDescription || item.description || '') %></p>
              <a class="read-more" href="/services/details/<%= encodeURIComponent(item.slug) %>"><%= t('home.services.readMore', 'Read more') %></a>
            </div>
          </div>
        </div>
      <% }); } else { %>
        <div class="col-12">
          <div class="alert alert-light border text-center mb-0"><%= t('pages.services.list.noServices', 'No services published yet—add handicap, business or regular services in the admin panel.') %></div>
        </div>
      <% } %>
    </div>
  </div>
</section>

<section class="service-section padding">
  <div class="container">
    <div class="section-heading text-center mb-40">
      <h4><span></span><%= t('pages.users.packages.packages', 'Packages') %></h4>
      <h2><%= t('packages.header.title', 'Choose Your') %> <%= t('packages.header.highlight', 'Ride Package') %></h2>
    </div>
    <div class="row">
      <% const solutionPackages = typeof packages !== 'undefined' && Array.isArray(packages) ? packages : []; %>
      <% if (solutionPackages.length) { solutionPackages.forEach(function(item) { %>
        <div class="col-lg-4 col-md-6 sm-padding">
          <div class="service-item p-4">
            <h3><%= item.slug ? t('booking.package.' + item.slug, item.title || item.slug) : (item.title || '') %></h3>
            <p><%= item.slug ? t('package.' + item.slug + '.summary', item.summary || '') : (item.summary || '') %></p>
          </div>
        </div>
      <% }); } else { %>
        <div class="col-12">
          <div class="alert alert-light border text-center mb-0"><%= t('packages.empty', 'No packages published yet—create handicap, business or regular bundles in the admin panel.') %></div>
        </div>
      <% } %>
    </div>
  </div>
</section>
  <%- include('../../shared/partials/legacy-footer') %>
