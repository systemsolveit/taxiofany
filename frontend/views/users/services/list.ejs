<%- include('../../shared/partials/legacy-head') %>
<%- include('../../shared/partials/legacy-header-nav') %>

<section class="page-header">
        <div class="page-header-shape"></div>
        <div class="container">
            <div class="page-header-info">
                <h4><%= t('pages.services.list.header.eyebrow', 'Our services') %></h4>
                <h2><%= t('pages.services.list.header.titleLine1', 'Handicap transport') %> <br><span><%= t('pages.services.list.header.titleBrand', 'Taxiofany') %></span> <%= t('pages.services.list.header.titleLine2', '& more') %></h2>
                <p><%= t('pages.services.list.header.description', 'Wheelchair-accessible rides lead our lineup—followed by business transport, regular taxi and airport or medical transfers.') %></p>
            </div>
        </div>
    </section>
    <!--/.page-header-->

    <section class="service-section bg-grey bd-bottom padding">
        <div class="container">
            <div class="row">
                <% if (Array.isArray(services) && services.length) { %>
                    <% services.forEach(function(item) { %>
                        <div class="col-lg-4 col-sm-6 padding-15">
                            <div class="service-item">
                                <div class="service-thumb">
                                    <img src="<%= item.coverImage || '/assets/img/service-1.jpg' %>" alt="img">
                                    <div class="service-shape-wrap">
                                        <div class="service-shape"></div>
                                    </div>
                                    <div class="service-car"><img src="<%= item.serviceCarImage || '/assets/img/car-1.png' %>" alt="<%= t('taxi.carImageAlt', 'Wheelchair-accessible taxi van') %>"></div>
                                </div>
                                <div class="service-content">
                                    <h3><a href="/services/details/<%= encodeURIComponent(item.slug) %>"><%= item.slug ? t('service.' + item.slug + '.title', item.title || t('home.services.handicapTransport', 'Handicap Transport')) : (item.title || t('home.services.handicapTransport', 'Handicap Transport')) %></a></h3>
                                    <p><%= item.slug ? t('service.' + item.slug + '.shortDescription', item.shortDescription || item.description || t('home.services.itemDescription', 'Wheelchair-accessible vans with ramps, lifts, and trained drivers—for hospital, work and daily trips.')) : (item.shortDescription || item.description || t('home.services.itemDescription', 'Wheelchair-accessible vans with ramps, lifts, and trained drivers—for hospital, work and daily trips.')) %></p>
                                    <a class="read-more" href="/services/details/<%= encodeURIComponent(item.slug) %>"><%= t('home.services.readMore', 'Read more') %></a>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="col-12 text-center text-muted">
                        <p><%= t('pages.services.list.noServices', 'No services published yet. Add handicap, business or regular transport services in the admin panel.') %></p>
                    </div>
                <% } %>
            </div>
        </div>
    </section>
    <!--/.service-section-->

    <section class="cta-section-2 padding">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-4">
                    <div class="cta-content">
                        <h4><%= t('home.cta.serviceLabel', 'Taxiofany accessible transport') %></h4>
                        <h2><%= t('home.cta.feelYourJourney', 'Move with confidence') %></h2>
                        <a href="/book-taxi" class="default-btn"><%= t('home.cta.bookTaxiBtn', 'Book accessible ride') %></a>
                    </div>
                </div>
                <div class="col-lg-5">
                    <ul class="check-list">
                        <li><i class="las la-arrow-right"></i><%= t('home.cta2.item1', 'Ramp- and lift-equipped vans') %></li>
                        <li><i class="las la-arrow-right"></i><%= t('home.cta2.item2', 'Drivers trained for wheelchair transfers') %></li>
                        <li><i class="las la-arrow-right"></i><%= t('home.cta2.item3', 'TFlex / Mutuelle paperwork on request') %></li>
                        <li><i class="las la-arrow-right"></i><%= t('home.cta2.item4', '24/7 dispatch for care & hospital rides') %></li>
                    </ul>
                </div>
                <div class="col-lg-3">
                    <div class="cta-men"></div>
                </div>
            </div>
        </div>
    </section>
    <!--/.cta-section-->

    <section class="blog-section bg-grey padding">
        <div class="container">
            <div class="section-heading text-center mb-40">
                <h4><span></span><%= t('home.blog.eyebrow', 'Mobility news') %></h4>
                <h2><%= t('home.blog.title', 'Insights on accessible transport') %></h2>
                <p><%= t('home.blog.description', 'Updates on handicap transport, vehicle adaptations, and travelling safely in Belgium.') %></p>
            </div>
            <!--/.section-heading-->
            <div class="row grid-post">
                <% if (Array.isArray(latestBlogPosts) && latestBlogPosts.length) { %>
                    <% latestBlogPosts.forEach(function(post) { %>
                        <% const postCatKey = (post.category || '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, ''); %>
                        <div class="col-lg-4 col-md-6 padding-15">
                            <div class="post-card">
                                <div class="post-thumb">
                                    <img src="<%= post.coverImage || '/assets/img/banner-1.jpg' %>" alt="<%= t('blog.postImageAlt', 'post') %>" />
                                    <a href="/blog/details/<%= encodeURIComponent(post.slug) %>" class="post-category"><%= postCatKey ? t('blog.category.' + postCatKey, post.category || t('home.blog.categoryBusiness')) : (post.category || t('home.blog.categoryBusiness')) %></a>
                                </div>
                                <div class="post-content-wrap">
                                    <ul class="post-meta">
                                        <li><i class="las la-calendar"></i><%= post.publishedAt ? new Date(post.publishedAt).toLocaleDateString(locale || 'nl') : t('common.dateUnavailable', 'Date unavailable') %></li>
                                        <li><i class="las la-user"></i><%= post.authorName || t('blog.authorFallbackName', 'Taxiofany') %></li>
                                    </ul>
                                    <div class="post-content">
                                        <h3>
                                            <a href="/blog/details/<%= encodeURIComponent(post.slug) %>" class="hover"><%= post.slug ? t('blog.' + post.slug + '.title', post.title || '') : (post.title || '') %></a>
                                        </h3>
                                        <p><%= post.slug ? t('blog.' + post.slug + '.excerpt', post.excerpt || post.summary || '') : (post.excerpt || post.summary || '') %></p>
                                        <a href="/blog/details/<%= encodeURIComponent(post.slug) %>" class="read-more"><%= t('home.blog.readMore', 'Read more') %></a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="col-12">
                        <div class="alert alert-light border text-center mb-0"><%= t('blog.empty', 'No published blog posts are available right now.') %></div>
                    </div>
                <% } %>
            </div>
        </div>
    </section>
    <!--/.blog-section-->

    <%- include('../../shared/partials/legacy-footer') %>
