<%- include('../../shared/partials/legacy-head') %>
<%- include('../../shared/partials/legacy-header-nav') %>

<section class="page-header">
        <div class="page-header-shape"></div>
        <div class="container">
            <div class="page-header-info">
                <h4><%= t('pages.services.list.header.eyebrow') %></h4>
                <h2><%= t('pages.services.list.header.titleLine1') %> <br><span><%= t('pages.services.list.header.titleBrand') %></span> <%= t('pages.services.list.header.titleLine2') %></h2>
                <p><%= t('pages.services.list.header.description') %></p>
            </div>
        </div>
    </section>
    <!--/.page-header-->

    <section class="service-section bg-grey bd-bottom padding">
        <div class="container">
            <div class="row">
                <% if (Array.isArray(services) && services.length) { %>
                    <% services.forEach(function(item) { %>
                        <div class="col-lg-4 col-sm-6 padding-15">
                            <div class="service-item">
                                <div class="service-thumb">
                                    <img src="<%= item.coverImage || '/assets/img/service-1.jpg' %>" alt="img">
                                    <div class="service-shape-wrap">
                                        <div class="service-shape"></div>
                                    </div>
                                    <div class="service-car"><img src="<%= item.serviceCarImage || '/assets/img/car-1.png' %>" alt="car"></div>
                                </div>
                                <div class="service-content">
                                    <h3><a href="/services/details/<%= encodeURIComponent(item.slug) %>"><%= item.slug ? t('service.' + item.slug + '.title', item.title || t('home.services.regularTransport')) : (item.title || t('home.services.regularTransport')) %></a></h3>
                                    <p><%= item.slug ? t('service.' + item.slug + '.shortDescription', item.shortDescription || item.description || t('home.services.itemDescription')) : (item.shortDescription || item.description || t('home.services.itemDescription')) %></p>
                                    <a class="read-more" href="/services/details/<%= encodeURIComponent(item.slug) %>"><%= t('home.services.readMore') %></a>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="col-12 text-center text-muted">
                        <p><%= t('pages.services.list.noServices', 'No services available right now.') %></p>
                    </div>
                <% } %>
            </div>
        </div>
    </section>
    <!--/.service-section-->

    <section class="cta-section-2 padding">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-4">
                    <div class="cta-content">
                        <h4><%= t('home.cta.serviceLabel') %></h4>
                        <h2><%= t('home.cta.feelYourJourney') %></h2>
                        <a href="/book-taxi" class="default-btn"><%= t('home.cta.bookTaxiBtn') %></a>
                    </div>
                </div>
                <div class="col-lg-5">
                    <ul class="check-list">
                        <li><i class="las la-arrow-right"></i><%= t('home.cta2.item1') %></li>
                        <li><i class="las la-arrow-right"></i><%= t('home.cta2.item2') %></li>
                        <li><i class="las la-arrow-right"></i><%= t('home.cta2.item3') %></li>
                        <li><i class="las la-arrow-right"></i><%= t('home.cta2.item4') %></li>
                    </ul>
                </div>
                <div class="col-lg-3">
                    <div class="cta-men"></div>
                </div>
            </div>
        </div>
    </section>
    <!--/.cta-section-->

    <section class="blog-section bg-grey padding">
        <div class="container">
            <div class="section-heading text-center mb-40">
                <h4><span></span><%= t('home.blog.eyebrow') %></h4>
                <h2><%= t('home.blog.title') %></h2>
                <p><%= t('home.blog.description') %></p>
            </div>
            <!--/.section-heading-->
            <div class="row grid-post">
                <div class="col-lg-4 col-md-6 padding-15">
                    <div class="post-card">
                        <div class="post-thumb">
                            <img src="/assets/img/post-1.jpg" alt="post" />
                            <a href="/blog/details" class="post-category"><%= t('home.blog.categoryBusiness') %></a>
                        </div>
                        <div class="post-content-wrap">
                            <ul class="post-meta">
                                <li><i class="las la-calendar"></i><%= t('home.blog.postDate') %></li>
                                <li><i class="las la-user"></i><%= t('home.blog.author') %></li>
                            </ul>
                            <div class="post-content">
                                <h3>
                                    <a href="/blog/details" class="hover"><%= t('home.blog.post1Title') %></a>
                                </h3>
                                <p><%= t('home.blog.postExcerpt') %></p>
                                <a href="/blog/details" class="read-more"><%= t('home.blog.readMore') %></a>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4 col-md-6 padding-15">
                    <div class="post-card">
                        <div class="post-thumb">
                            <img src="/assets/img/post-2.jpg" alt="post" />
                            <a href="/blog/details" class="post-category"><%= t('home.blog.categoryStartup') %></a>
                        </div>
                        <div class="post-content-wrap">
                            <ul class="post-meta">
                                <li><i class="las la-calendar"></i><%= t('home.blog.postDate') %></li>
                                <li><i class="las la-user"></i><%= t('home.blog.author') %></li>
                            </ul>
                            <div class="post-content">
                                <h3>
                                    <a href="/blog/details"><%= t('home.blog.post2Title') %></a>
                                </h3>
                                <p><%= t('home.blog.postExcerpt') %></p>
                                <a href="/blog/details" class="read-more"><%= t('home.blog.readMore') %></a>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4 col-md-6 padding-15">
                    <div class="post-card">
                        <div class="post-thumb">
                            <img src="/assets/img/post-3.jpg" alt="post" />
                            <a href="/blog/details" class="post-category"><%= t('home.blog.categoryFinance') %></a>
                        </div>
                        <div class="post-content-wrap">
                            <ul class="post-meta">
                                <li><i class="las la-calendar"></i><%= t('home.blog.postDate') %></li>
                                <li><i class="las la-user"></i><%= t('home.blog.author') %></li>
                            </ul>
                            <div class="post-content">
                                <h3>
                                    <a href="/blog/details"><%= t('home.blog.post3Title') %></a>
                                </h3>
                                <p><%= t('home.blog.postExcerpt') %></p>
                                <a href="/blog/details" class="read-more"><%= t('home.blog.readMore') %></a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!--/.blog-section-->

    <%- include('../../shared/partials/legacy-footer') %>
