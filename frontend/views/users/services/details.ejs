<%- include('../../shared/partials/legacy-head') %>
<%- include('../../shared/partials/legacy-header-nav') %>

<section class="page-header">
        <div class="page-header-shape"></div>
        <div class="container">
            <div class="page-header-info">
                <h4><%= t('pages.services.details.header.eyebrow') %></h4>
                <h2><%= service && service.title ? t('service.' + service.slug + '.title', service.title) : (t('pages.services.details.header.titleLine1') + ' ' + t('pages.services.details.header.titleLine2')) %></h2>
                <p><%= service && service.shortDescription ? t('service.' + service.slug + '.shortDescription', service.shortDescription) : t('pages.services.details.header.description') %></p>
            </div>
        </div>
    </section>
    <!--/.page-header-->

    <section class="service-details bg-grey padding">
        <div class="container">
            <div class="row">
                <div class="col-lg-8 sm-padding">
                    <div class="service-details-info">
                        <img src="<%= service && service.featureImage ? service.featureImage : '/assets/img/post-2.jpg' %>" alt="img">
                        <h2><%= service && service.title ? t('service.' + service.slug + '.title', service.title) : t('pages.services.details.title') %></h2>
                        <p><%= service && service.description ? t('service.' + service.slug + '.description', service.description) : t('pages.services.details.paragraph1') %></p>
                        <p><%= service && service.shortDescription ? t('service.' + service.slug + '.shortDescription', service.shortDescription) : t('pages.services.details.paragraph2') %></p>
                        <ul class="service-features">
                            <% const detailsFeatures = service && Array.isArray(service.features) && service.features.length ? service.features : []; %>
                            <% if (detailsFeatures.length) { %>
                                <% detailsFeatures.forEach(function(feature, fIdx) { %>
                                    <li>
                                        <div><i class="<%= feature.iconClass || 'las la-check' %>"></i></div>
                                        <div>
                                            <h3><%= t('service.' + service.slug + '.feature.' + fIdx + '.title', feature.title || '') %></h3>
                                            <p><%= t('service.' + service.slug + '.feature.' + fIdx + '.description', feature.description || '') %></p>
                                        </div>
                                    </li>
                                <% }) %>
                            <% } else { %>
                                <li>
                                    <div><i class="las la-shipping-fast"></i></div>
                                    <div>
                                        <h3><%= t('pages.services.details.features.fastPickups.title') %></h3>
                                        <p><%= t('pages.services.details.features.fastPickups.description') %></p>
                                    </div>
                                </li>
                            <% } %>
                        </ul>
                        <p><%= t('pages.services.details.paragraph3') %></p>
                        <div class="service-details-list">
                            <img src="<%= service && service.benefitsImage ? service.benefitsImage : '/assets/img/post-1.jpg' %>" alt="img">
                            <div>
                                <h3><%= t('pages.services.details.benefits.title') %></h3>
                                <p><%= t('pages.services.details.benefits.description') %></p>
                                <ul class="service-icon-list">
                                    <% const benefitPoints = service && Array.isArray(service.benefitPoints) && service.benefitPoints.length ? service.benefitPoints : [t('pages.services.details.benefits.item1'), t('pages.services.details.benefits.item2'), t('pages.services.details.benefits.item3')]; %>
                                    <% benefitPoints.forEach(function(point, bpIdx) { %>
                                        <li><i class="las la-hand-point-right"></i><%= (service && service.slug) ? t('service.' + service.slug + '.benefitPoint.' + bpIdx, point) : point %></li>
                                    <% }) %>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4 sm-padding">
                    <div class="service-sidebar sidebar-widget">
                        <div class="widget-title service-widget">
                            <h3><%= t('pages.services.details.categories.title') %></h3>
                        </div>
                        <ul>
                            <% if (Array.isArray(services) && services.length) { %>
                                <% services.forEach(function(item) { %>
                                    <li><a href="/services/details/<%= encodeURIComponent(item.slug) %>"><%= item.slug ? t('service.' + item.slug + '.title', item.title || '') : (item.title || '') %></a><i class="las la-arrow-right"></i></li>
                                <% }) %>
                            <% } else { %>
                                <li><a href="#"><%= t('home.services.regularTransport') %></a><i class="las la-arrow-right"></i></li>
                            <% } %>
                        </ul>
                    </div>
                    <div class="sidebar-widget banner">
                        <div class="banner-info">
                            <a href="/"><img class="logo" src="/assets/img/logo-light.png" alt="logo"></a>
                            <h3><%= t('pages.services.details.banner.titleLine1') %> <span><%= t('pages.services.details.banner.titleBrand') %></span></h3>
                            <p><%= t('pages.services.details.banner.description') %></p>
                            <h2 class="discount"><span>-60%</span> <%= t('pages.services.details.banner.discountSuffix') %></h2>
                            <a href="/contact" class="default-btn"><%= t('pages.services.details.banner.cta') %></a>
                        </div>
                    </div>
                    <div class="sidebar-widget">
                        <div class="widget-title">
                            <h3><%= t('pages.services.details.tagsTitle') %></h3>
                        </div>
                        <ul class="tags">
                            <% const tags = service && Array.isArray(service.tags) && service.tags.length ? service.tags : [t('pages.users.services.details.business', 'business'), t('pages.users.services.details.marketing', 'marketing'), t('pages.users.services.details.startup', 'startup')]; %>
                            <% tags.forEach(function(tag) { %>
                                <% var tagKey = String(tag || '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, ''); %>
                                <li><a href="#"><%= tagKey ? t('tag.' + tagKey, tag) : tag %></a></li>
                            <% }) %>
                        </ul>
                    </div>
                    <!--Tags-->
                </div>
            </div>
        </div>
    </section>
    <!--/.service-details-->

    <%- include('../../shared/partials/legacy-footer') %>
