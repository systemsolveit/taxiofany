<%- include('../../shared/partials/legacy-head') %>
<%- include('../../shared/partials/legacy-header-nav') %>

<main class="client-portal">
  <div class="container">
    <header class="client-portal__header">
      <h1 class="client-portal__title"><%= t('account.myTripsTitle') %></h1>
      <p class="client-portal__subtitle"><%= t('account.tripsSubtitle') %></p>
    </header>

    <div class="client-portal__layout">
      <%- include('../../shared/partials/client-portal-sidebar') %>
      <div class="client-portal-main">
        <section class="client-portal-card">
          <h2 class="client-portal-card__title"><%= t('account.tripsFor') %> <%= accountUser.fullName %></h2>
          <% if (typeof tripsError !== 'undefined' && tripsError) { %>
            <div class="cp-alert cp-alert--error" role="alert"><%= tripsError %></div>
          <% } %>
          <% if (!tripsError && (!trips || trips.length === 0)) { %>
            <p class="mb-0 text-muted"><%= t('account.noTrips') %></p>
            <p class="mt-3 mb-0"><a class="btn btn-primary btn-sm" href="<%= withLocale('/book-taxi') %>"><%= t('account.portal.newBooking', 'New booking') %></a></p>
          <% } else if (trips && trips.length) { %>
            <div class="table-responsive">
              <table class="table table-striped table-sm mb-0">
                <thead>
                  <tr>
                    <th><%= t('account.tripId') %></th>
                    <th><%= t('account.route') %></th>
                    <th><%= t('account.date') %></th>
                    <th><%= t('account.status') %></th>
                  </tr>
                </thead>
                <tbody>
                  <% trips.forEach((trip) => { %>
                    <tr>
                      <td><%= trip.id %></td>
                      <td><%= trip.from %> → <%= trip.to %></td>
                      <td><%= trip.date %></td>
                      <td><%= trip.status %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </section>

        <form action="<%= withLocale('/account/logout') %>" method="post" class="d-lg-none">
          <button type="submit" class="btn btn-outline-secondary btn-sm"><%= t('account.logout') %></button>
        </form>
      </div>
    </div>
  </div>
</main>

<%- include('../../shared/partials/legacy-footer') %>
