<%- include('../../shared/partials/legacy-head') %>
<%- include('../../shared/partials/legacy-header-nav') %>

<% 
  const wl = typeof withLocale === 'function' ? withLocale : function(p) { return p; };
  const waText = t('account.forgotPasswordWhatsappText', 'Hello, I need help resetting my account password.');
  const waHref = supportWhatsapp ? ('https://wa.me/' + supportWhatsapp + '?text=' + encodeURIComponent(waText)) : '';
%>

<main class="client-auth-page">
  <div class="container">
    <div class="client-auth-card client-auth-card--wide">
      <h1 class="client-auth-card__title"><%= t('account.forgotPasswordTitle', 'Forgot password') %></h1>
      <p class="client-auth-card__lead"><%= t('account.forgotPasswordLead', 'Online password reset is not available yet. Contact our team and we will help you regain access to your account.') %></p>

      <% if (supportWhatsapp) { %>
        <div class="cp-alert cp-alert--info" role="status">
          <%= t('account.forgotPasswordWhatsappInfo', 'Use WhatsApp to reach an administrator. Tap the button below to start a chat with a pre-filled message.') %>
        </div>
        <a class="btn btn-primary btn-block mb-3" href="<%= waHref %>" rel="noopener noreferrer" target="_blank">
          <i class="lab la-whatsapp" style="font-size:1.25rem;vertical-align:middle;" aria-hidden="true"></i>
          <%= t('account.contactWhatsapp', 'Contact administrator on WhatsApp') %>
        </a>
      <% } else { %>
        <div class="cp-alert cp-alert--info" role="status">
          <%= t('account.forgotPasswordNoWhatsapp', 'WhatsApp support is not configured. Please use the contact page and mention your account email.') %>
        </div>
        <a class="btn btn-primary btn-block mb-3" href="<%= wl('/contact') %>"><%= t('account.goToContact', 'Go to contact') %></a>
      <% } %>

      <p class="client-auth-card__footer mb-0">
        <a href="<%= wl('/account/login') %>"><%= t('account.backToLogin', 'Back to sign in') %></a>
      </p>
    </div>
  </div>
</main>

<%- include('../../shared/partials/legacy-footer') %>
