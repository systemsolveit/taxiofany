<%- include('../../shared/partials/legacy-head') %>
<%- include('../../shared/partials/legacy-header-nav') %>

  <main class="container py-5" style="max-width: 760px; margin: 0 auto;">
    <h1><%= t('account.passwordTitle') %></h1>
    <p style="color:#666;"><%= t('account.passwordSubtitle') %></p>

    <nav class="account-tabs" aria-label="Account tabs">
      <a class="account-tab <%= activeAccountTab === 'account' ? 'active' : '' %>" href="/account"><%= t('account.tabs.account') %></a>
      <a class="account-tab <%= activeAccountTab === 'trips' ? 'active' : '' %>" href="/account/trips"><%= t('account.tabs.trips') %></a>
      <a class="account-tab <%= activeAccountTab === 'password' ? 'active' : '' %>" href="/account/password"><%= t('account.tabs.password') %></a>
    </nav>

    <% if (notice) { %>
      <div class="notice <%= notice.type === 'success' ? 'success' : 'error' %>"><%= notice.message %></div>
    <% } %>

    <section class="card">
      <h3 style="margin-top:0;"><%= t('account.changePassword') %></h3>
      <form action="/account/password" method="post" class="form-grid">
        <input type="password" name="currentPassword" placeholder="<%= t('account.currentPassword') %>" required />
        <input type="password" name="newPassword" placeholder="<%= t('account.newPassword') %>" required />
        <input type="password" name="confirmPassword" placeholder="<%= t('account.confirmPassword') %>" required />
        <button type="submit"><%= t('account.updatePassword') %></button>
      </form>
    </section>
  </main>

  <%- include('../../shared/partials/legacy-footer') %>
