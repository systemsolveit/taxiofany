<%- include('../../shared/partials/legacy-head') %>
<%- include('../../shared/partials/legacy-header-nav') %>

<main class="client-portal">
  <div class="container">
    <header class="client-portal__header">
      <h1 class="client-portal__title"><%= t('account.passwordTitle') %></h1>
      <p class="client-portal__subtitle"><%= t('account.passwordSubtitle') %></p>
    </header>

    <div class="client-portal__layout">
      <%- include('../../shared/partials/client-portal-sidebar') %>
      <div class="client-portal-main">
        <% if (notice) { %>
          <div class="notice <%= notice.type === 'success' ? 'success' : 'error' %>" role="alert"><%= notice.message %></div>
        <% } %>

        <section class="client-portal-card">
          <h2 class="client-portal-card__title"><%= t('account.changePassword') %></h2>
          <form action="<%= withLocale('/account/password') %>" method="post" class="form-grid">
            <div class="form-group mb-0">
              <label for="pw-current"><%= t('account.currentPassword') %></label>
              <input id="pw-current" class="form-control" type="password" name="currentPassword" autocomplete="current-password" required placeholder="<%= t('account.currentPassword') %>">
            </div>
            <div class="form-group mb-0">
              <label for="pw-new"><%= t('account.newPassword') %></label>
              <input id="pw-new" class="form-control" type="password" name="newPassword" autocomplete="new-password" required placeholder="<%= t('account.newPassword') %>">
            </div>
            <div class="form-group mb-0">
              <label for="pw-confirm"><%= t('account.confirmPassword') %></label>
              <input id="pw-confirm" class="form-control" type="password" name="confirmPassword" autocomplete="new-password" required placeholder="<%= t('account.confirmPassword') %>">
            </div>
            <button type="submit" class="btn btn-primary"><%= t('account.updatePassword') %></button>
          </form>
        </section>

        <form action="<%= withLocale('/account/logout') %>" method="post" class="d-lg-none">
          <button type="submit" class="btn btn-outline-secondary btn-sm"><%= t('account.logout') %></button>
        </form>
      </div>
    </div>
  </div>
</main>

<%- include('../../shared/partials/legacy-footer') %>
