<%- include('../../shared/partials/legacy-head') %>
<%- include('../../shared/partials/legacy-header-nav') %>

  <main class="container py-5" style="max-width: 760px; margin: 0 auto;">
    <h1>Password Management</h1>
    <p style="color:#666;">Update your account password from your end-user panel.</p>

    <nav class="account-tabs" aria-label="Account tabs">
      <a class="account-tab <%= activeAccountTab === 'account' ? 'active' : '' %>" href="/account">Account</a>
      <a class="account-tab <%= activeAccountTab === 'trips' ? 'active' : '' %>" href="/account/trips">Trips</a>
      <a class="account-tab <%= activeAccountTab === 'password' ? 'active' : '' %>" href="/account/password">Password Management</a>
    </nav>

    <% if (notice) { %>
      <div class="notice <%= notice.type === 'success' ? 'success' : 'error' %>"><%= notice.message %></div>
    <% } %>

    <section class="card">
      <h3 style="margin-top:0;">Change Password</h3>
      <form action="/account/password" method="post" class="form-grid">
        <input type="password" name="currentPassword" placeholder="Current password" required />
        <input type="password" name="newPassword" placeholder="New password" required />
        <input type="password" name="confirmPassword" placeholder="Confirm new password" required />
        <button type="submit">Update Password</button>
      </form>
    </section>
  </main>

  <%- include('../../shared/partials/legacy-footer') %>
