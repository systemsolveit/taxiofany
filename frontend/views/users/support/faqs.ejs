<%- include('../../shared/partials/legacy-head') %>
<%- include('../../shared/partials/legacy-header-nav') %>

<section class="page-header">
        <div class="page-header-shape"></div>
        <div class="container">
            <div class="page-header-info">
                <h4><%= t('pages.users.support.faqs.help_faqs', 'Help & FAQs') %></h4>
                <h2><%= t('pages.users.support.faqs.frequently_asked', 'Accessible transport') %> <br> <span><%= t('pages.users.support.faqs.questions', 'questions') %></span></h2>
                <p><%= t('pages.users.support.faqs.everything_your_taxi_business', 'Answers about wheelchair vans, bookings, billing and safety') %> <br><%= t('pages.users.support.faqs.needs_is_already_here', 'for passengers and caregivers across Belgium.') %> </p>
            </div>
        </div>
    </section>
    <!--/.page-header-->

    <section class="blog-section blog-page bg-grey padding">
        <div class="container">
            <div class="row">
                <div class="col-lg-8 sm-padding">
                    <div class="accordion faq-accordion" id="faq-accordion">
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingOne">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne"><%= t('pages.users.support.faqs.what_makes_a_good_taxi_service', 'What equipment do your handicap vehicles have?') %></button>
                            </h2>
                            <div id="collapseOne" class="accordion-collapse collapse show" aria-labelledby="headingOne" data-bs-parent="#faq-accordion">
                                <div class="accordion-body">
                                    <p><%= t('pages.users.support.faqs.the_restaurants_in_hangzhou_also_catered_to_many', 'Our adapted vans typically include a ramp or lift, lowered floor, wheelchair anchorage points (ISO fixing), 4-point restraint straps and seating for a companion. Tell dispatch your wheelchair size and whether you need extra time to board.') %></p>
                                </div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingTwo">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo"><%= t('pages.users.support.faqs.what_is_the_purpose_of_a_taxi_service', 'Can a caregiver ride along?') %> </button>
                            </h2>
                            <div id="collapseTwo" class="accordion-collapse collapse" aria-labelledby="headingTwo" data-bs-parent="#faq-accordion">
                                <div class="accordion-body">
                                    <p><%= t('pages.users.support.faqs.answer2', 'Yes. Mention how many companions when you book so we reserve the correct vehicle and seating.') %></p>
                                </div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingThree">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseThree" aria-expanded="false" aria-controls="collapseThree"> <%= t('pages.users.support.faqs.how_to_download_the_taxiofany_taxi_app_online', 'Do you support TFlex or Mutuelle reimbursement paperwork?') %> </button>
                            </h2>
                            <div id="collapseThree" class="accordion-collapse collapse" aria-labelledby="headingThree" data-bs-parent="#faq-accordion">
                                <div class="accordion-body">
                                    <p><%= t('pages.users.support.faqs.answer3', 'We can provide ride confirmations and invoicing suitable for many reimbursement schemes—ask when booking so dispatch notes your file requirements.') %></p>
                                </div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingFour">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFour" aria-expanded="false" aria-controls="collapseFour"> <%= t('pages.users.support.faqs.what_should_i_be_asking_for_first_ride', 'How do I book a hospital or therapy trip?') %> </button>
                            </h2>
                            <div id="collapseFour" class="accordion-collapse collapse" aria-labelledby="headingFour" data-bs-parent="#faq-accordion">
                                <div class="accordion-body">
                                    <p><%= t('pages.users.support.faqs.answer4', 'Use the online booking form or call us with appointment time, pickup window, and any mobility notes. We prioritise medical and care-home schedules when possible.') %></p>
                                </div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingFive">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFive" aria-expanded="false" aria-controls="collapseFive"> <%= t('pages.users.support.faqs.how_many_cars_does_taxiofany_taxi_service_have', 'Do you also offer regular or business taxi—not only handicap?') %> </button>
                            </h2>
                            <div id="collapseFive" class="accordion-collapse collapse" aria-labelledby="headingFive" data-bs-parent="#faq-accordion">
                                <div class="accordion-body">
                                    <p><%= t('pages.users.support.faqs.answer5', 'Yes. Handicap-accessible transport is our focus, but you can book business and regular taxi rides through the same channels—choose the package type when you reserve.') %></p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4 sm-padding">
                    <div class="sidebar-widget">
                        <form action="" class="search-form">
                            <input type="text" class="form-control" placeholder="<%= t('common.search', 'Search') %>">
                            <button class="search-btn" type="button"><i class="fa fa-search"></i></button>
                        </form>
                    </div>
                    <!--Search Form-->
                    <div class="sidebar-widget">
                        <div class="widget-title">
                            <h3><%= t('pages.users.support.faqs.categories', 'Categories') %></h3>
                        </div>
                        <ul class="category-list">
                            <li><a href="/blog"><%= t('pages.users.support.faqs.business_strategy', 'Handicap transport') %></a><span>23</span></li>
                            <li><a href="/blog"><%= t('pages.users.support.faqs.project_management', 'Wheelchair taxi') %></a><span>05</span></li>
                            <li><a href="/blog"><%= t('pages.users.support.faqs.digital_marketing', 'Medical rides') %></a><span>18</span></li>
                            <li><a href="/blog"><%= t('pages.users.support.faqs.customer_experience', 'Caregiver tips') %></a><span>04</span></li>
                            <li><a href="/blog"><%= t('pages.users.support.faqs.partnership_system', 'Belgium mobility') %></a><span>15</span></li>
                        </ul>
                    </div>
                    <!--Categories-->
                    <div class="sidebar-widget">
                        <div class="widget-title">
                            <h3><%= t('pages.users.support.faqs.recent_articles', 'Recent Articles') %></h3>
                        </div>
                        <ul class="thumb-post">
                            <li>
                                <div class="thumb">
                                    <img src="/assets/img/post-thumb-1.jpg" alt="thumb">
                                </div>
                                <div class="thumb-post-info">
                                    <h3><a href="/blog/details"><%= t('pages.users.support.faqs.how_to_go_about_initiating_an_startup_in_few_day', 'Choosing a wheelchair-accessible taxi in Belgium.') %></a></h3>
                                    <a href="#" class="date"><%= t('pages.users.support.faqs.jan_01_2022', 'Jan 01 2022') %></a>
                                </div>
                            </li>
                            <li>
                                <div class="thumb">
                                    <img src="/assets/img/post-thumb-2.jpg" alt="thumb">
                                </div>
                                <div class="thumb-post-info">
                                    <h3><a href="/blog/details"><%= t('pages.users.support.faqs.financial_experts_support_help_you_to_find_out', 'What to tell dispatch before your first accessible ride.') %></a></h3>
                                    <a href="#" class="date"><%= t('pages.users.support.faqs.jan_01_2022', 'Jan 01 2022') %></a>
                                </div>
                            </li>
                            <li>
                                <div class="thumb">
                                    <img src="/assets/img/post-thumb-3.jpg" alt="thumb">
                                </div>
                                <div class="thumb-post-info">
                                    <h3><a href="/blog/details"><%= t('pages.users.support.faqs.innovative_helping_business_all_over_the_world', 'TFlex, Mutuelle and mobility reimbursement basics.') %></a></h3>
                                    <a href="#" class="date"><%= t('pages.users.support.faqs.jan_01_2022', 'Jan 01 2022') %></a>
                                </div>
                            </li>
                        </ul>
                    </div>
                    <!--Recent Thumb Post-->
                    <div class="sidebar-widget">
                        <div class="widget-title">
                            <h3><%= t('pages.users.support.faqs.tags', 'Tags') %></h3>
                        </div>
                        <ul class="tags">
                            <li><a href="#"><%= t('pages.users.support.faqs.business', 'handicap') %></a></li>
                            <li><a href="#"><%= t('pages.users.support.faqs.marketing', 'wheelchair') %></a></li>
                            <li><a href="#"><%= t('pages.users.support.faqs.startup', 'TFlex') %></a></li>
                            <li><a href="#"><%= t('pages.users.support.faqs.design', 'Mutuelle') %></a></li>
                            <li><a href="#"><%= t('pages.users.support.faqs.consulting', 'hospital') %></a></li>
                            <li><a href="#"><%= t('pages.users.support.faqs.strategy', 'care home') %></a></li>
                            <li><a href="#"><%= t('pages.users.support.faqs.development', 'Brussels') %></a></li>
                            <li><a href="#"><%= t('pages.users.support.faqs.tips', 'Wemmel') %></a></li>
                            <li><a href="#"><%= t('pages.users.support.faqs.seo', 'Belgium') %></a></li>
                        </ul>
                    </div>
                    <!--Tags-->
                </div>
                <!--Sidebar-->
            </div>
        </div>
    </section>
    <!--Blog Section-->

    <%- include('../../shared/partials/legacy-footer') %>
