<%- include('../../shared/partials/legacy-head') %>
<%- include('../../shared/partials/legacy-header-nav') %>
<% const publicPhone = (siteSettings && siteSettings.header && siteSettings.header.phone) || t('footer.fallbackPhone', '+32484262105'); %>

<div class="slider-section">
        <div class="main-slider">
            <div class="swiper-wrapper">
                <% const homeBannerImages = ['/assets/img/banner-1.jpg', '/assets/img/banner-2.jpg', '/assets/img/banner-3.jpg', '/assets/img/slider-bg.jpg']; %>
                <% homeBannerImages.forEach(function(bannerImage) { %>
                <div class="swiper-slide">
                    <div class="slider-img"><img src="<%= bannerImage %>" alt="Taxiofany banner" class="kenburns"
                            style="animation-duration: 12000ms; "></div>
                    <div class="car-holder">
                        <img src="/assets/img/car-1.png" alt="<%= t('taxi.carImageAlt', 'Wheelchair-accessible taxi van') %>" data-animation="car-animation" data-duration="1.5s">
                        <div class="shape">
                            <div data-animation="slide-in-bottom" data-duration="1.5s" data-delay="0.3s"></div>
                            <div data-animation="fade-in" data-duration="1.5s" data-delay="0.2s"></div>
                            <div data-animation="slide-in-top" data-duration="1.5s" data-delay="0.5s"></div>
                        </div>
                    </div>
                    <div class="slider-content-wrap d-flex align-items-center text-left">
                        <div class="container">
                            <div class="slider-content">
                                <div class="slider-caption medium">
                                    <div class="inner-layer">
                                        <div data-animation="fade-in-bottom" data-delay="0.3s"><%= t('home.hero.tagline', 'Wheelchair-accessible taxis across Belgium.') %>
                                        </div>
                                    </div>
                                </div>
                                <div class="slider-caption big">
                                    <div class="inner-layer">
                                        <div data-animation="fade-in-bottom" data-delay="0.5s"><%= t('home.hero.title', 'Reliable handicap transport with adapted vehicles.') %>
                                        </div>
                                    </div>
                                </div>
                                <div class="slider-caption small">
                                    <div class="inner-layer">
                                        <div data-animation="fade-in-bottom" data-delay="0.7s" data-duration="1s"><%= t('home.hero.description', 'Taxiofany specialises in wheelchair-accessible transport. Our adapted vehicles—low-floor entry, side ramps, wheelchair lifts and 4-point restraints—are driven by trained accessibility specialists. We also provide business and regular taxi transport. TFlex/Mutuelle billing on request.') %></div>
                                    </div>
                                </div>
                                <div class="slider-btn">
                                    <a href="/book-taxi" class="default-btn" data-animation="fade-in-bottom"
                                        data-delay="0.9s"><%= t('home.hero.ctaBookNow', 'Book Now') %></a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <% }); %>
            </div>
            <!-- Slider navigation buttons -->
            <div class="slider-controls">
                <div class="slider-control slider-button-prev"><span><i
                            class="las la-long-arrow-alt-left"></i></span><%= t('home.hero.prev', 'Prev') %></div>
                <div class="slider-pagination"></div>
                <div class="slider-control slider-button-next"><%= t('home.hero.next', 'Next') %><span><i
                            class="las la-long-arrow-alt-right"></i></span>
                </div>
            </div>
        </div>
    </div>
    <!--/.slider-section-->

    <section class="about-section padding">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <div class="about-img">
                        <img class="about-img1 wow fade-in-left" data-wow-delay="200ms" src="/assets/img/about-1.png" alt="img">
                        <img class="about-img2 wow fade-in-bottom" data-wow-delay="400ms" src="/assets/img/about-2.png" alt="img">
                        <figure class="round-text"><img src="/assets/img/experience-text-round.png" alt="img"></figure>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="section-heading mb-40 wow fade-in-right" data-wow-delay="200ms">
                        <h4><span></span><%= t('home.about.eyebrow', 'About Taxiofany') %></h4>
                        <h2><%= t('home.about.title', 'Safe, dignified mobility for every passenger') %></h2>
                        <p><%= t('home.about.description', 'We focus on handicap and wheelchair-accessible transport first: trained drivers, ramp- and lift-equipped vans, and 24/7 dispatch for hospital, care-home and daily journeys across Belgium. Corporate shuttles and regular taxi rides are available too.') %></p>
                    </div>
                    <!--/.section-heading-->
                    <ul class="about-info wow fade-in-right" data-wow-delay="400ms">
                        <li>
                            <img class="owner-thumb" src="/assets/img/comment-1.png" alt="thumb">
                            <div class="owner">
                                <h4><%= t('home.about.founderTitle', 'Dispatch & accessibility team') %></h4>
                                <img class="signature" src="/assets/img/signature.png" alt="signature">
                            </div>
                        </li>
                        <li>
                            <h2><span><%= t('home.about.callForTaxi', 'Call for accessible transport') %></span><a href="tel:<%= String(publicPhone).replace(/[^\d+]/g, '') %>"><%= publicPhone %></a></h2>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>
    <!--/.about-section-->

    <% const homeServices = typeof services !== 'undefined' && Array.isArray(services) ? services : []; %>
    <% const homeFleetCars = typeof cars !== 'undefined' && Array.isArray(cars) ? cars : []; %>
    <section class="service-section bg-grey padding">
        <div class="bg-half"></div>
        <div class="container">
            <div class="section-heading text-center mb-40 wow fade-in-bottom" data-wow-delay="200ms">
                <h4><span></span><%= t('home.services.eyebrow', 'What we offer') %></h4>
                <h2 class="white"><%= t('home.services.titleStart', 'Handicap transport first') %><br><%= t('home.services.titleEnd', '—then business & regular taxi') %></h2>
                <p><%= t('home.services.description', 'Primary: wheelchair-accessible vans with ramps, lifts and secure restraint systems. Secondary: executive business transport and everyday taxi rides. Airport and medical-appointment transfers welcome.') %></p>
            </div>
            <!--/.section-heading-->
            <% if (homeServices.length) { %>
            <div class="swiper-outside">
                <div class="service-carousel">
                    <div class="swiper-wrapper">
                        <% homeServices.forEach(function(item, idx) { %>
                        <% const slugOk = item.slug && String(item.slug).trim(); %>
                        <% const detailPath = slugOk ? ('/services/details/' + encodeURIComponent(String(item.slug).trim())) : '/services'; %>
                        <% const serviceHref = typeof withLocale === 'function' ? withLocale(detailPath) : detailPath; %>
                        <% const cover = (item.coverImage && String(item.coverImage).trim()) || (item.featureImage && String(item.featureImage).trim()) || (item.benefitsImage && String(item.benefitsImage).trim()) || ''; %>
                        <% const carImg = (item.serviceCarImage && String(item.serviceCarImage).trim()) || (homeFleetCars.length ? (homeFleetCars[idx % homeFleetCars.length].detailImage || homeFleetCars[idx % homeFleetCars.length].image || '') : ''); %>
                        <% const useWow = idx < 3; %>
                        <% const delayMap = ['200ms', '400ms', '600ms']; %>
                        <div class="swiper-slide">
                            <div class="service-item<%= useWow ? ' wow fade-in-bottom' : '' %>"<% if (useWow) { %> data-wow-delay="<%= delayMap[idx] %>"<% } %>>
                                <div class="service-thumb">
                                    <img src="<%= cover || '/assets/img/service-1.jpg' %>" alt="">
                                    <div class="service-shape-wrap">
                                        <div class="service-shape"></div>
                                    </div>
                                    <% if (carImg) { %><div class="service-car"><img src="<%= carImg %>" alt=""></div><% } %>
                                </div>
                                <div class="service-content">
                                    <h3><a href="<%= serviceHref %>"><%= item.slug ? t('service.' + item.slug + '.title', item.title || t('home.services.handicapTransport', 'Handicap Transport')) : (item.title || t('home.services.handicapTransport', 'Handicap Transport')) %></a></h3>
                                    <p><%= item.slug ? t('service.' + item.slug + '.shortDescription', item.shortDescription || item.description || t('home.services.itemDescription', 'Wheelchair-accessible vans with ramps, lifts, and trained drivers—for hospital, work and daily trips.')) : (item.shortDescription || item.description || t('home.services.itemDescription', 'Wheelchair-accessible vans with ramps, lifts, and trained drivers—for hospital, work and daily trips.')) %></p>
                                    <a class="read-more" href="<%= serviceHref %>"><%= t('home.services.readMore', 'Read more') %></a>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                    </div>
                    <div class="swiper-pagination"></div><!-- Carousel Dots -->
                </div>
                <!-- Carousel Arrows -->
                <div class="swiper-nav swiper-next"><i class="las la-long-arrow-alt-right"></i></div>
                <div class="swiper-nav swiper-prev"><i class="las la-long-arrow-alt-left"></i></div>
            </div>
            <% } else { %>
            <p class="text-center text-white-50 py-5 mb-0" style="opacity:0.9"><%= t('home.empty.noPublishedServices', 'No published services to show. Publish at least one service in the admin panel (Show on public website).') %></p>
            <% } %>
        </div>
    </section>
    <!--/.service-section-->

    <% const bookingAuthed = typeof bookingPrefillEmail !== 'undefined' && bookingPrefillEmail; %>
    <% const wl = typeof withLocale === 'function' ? withLocale : function (p) { return p; }; %>
    <section class="booking-section">
        <div class="container">
            <div class="row pos-relative padding">
                <div class="col-lg-4">
                    <div class="booking-car wow fade-in-left" data-wow-delay="200ms"></div>
                </div>
                <div class="col-lg-8">
                    <div class="booking-wrap">
                        <div class="section-heading mb-30">
                            <h4><span></span><%= t('home.booking.onlineBooking', 'Online booking') %></h4>
                            <h2 class="white"><%= t('home.booking.bookTaxiRide', 'Book your accessible ride') %></h2>
                        </div>
                        <form action="<%= wl('/book-taxi') %>" method="post" id="book-taxi-ride" data-booking-authed="<%= bookingAuthed ? '1' : '0' %>">
                            <div class="booking-form">
                                <% if (bookingAuthed) { %>
                                <div class="form-field booking-identity-field">
                                    <i class="las la-user-tie"></i>
                                    <input type="text" id="full-name" name="full-name" class="form-control booking-input-readonly"
                                        placeholder="<%= t('home.booking.yourName', 'Your name') %>" value="<%= bookingPrefillName %>" autocomplete="name" readonly required aria-readonly="true">
                                </div>
                                <div class="form-field booking-identity-field">
                                    <i class="las la-envelope-open"></i>
                                    <input type="email" id="email" name="email" class="form-control booking-input-readonly" placeholder="<%= t('home.booking.email', 'Email') %>"
                                        value="<%= bookingPrefillEmail %>" autocomplete="email" readonly required aria-readonly="true">
                                </div>
                                <% } else { %>
                                <div class="form-field">
                                    <i class="las la-user-tie"></i>
                                    <input type="text" id="full-name" name="full-name" class="form-control"
                                        placeholder="<%= t('home.booking.yourName', 'Your name') %>" value="<%= typeof bookingPrefillName !== 'undefined' ? bookingPrefillName : '' %>" autocomplete="name" required>
                                </div>
                                <div class="form-field">
                                    <i class="las la-envelope-open"></i>
                                    <input type="email" id="email" name="email" class="form-control" placeholder="<%= t('home.booking.email', 'Email') %>"
                                        value="<%= typeof bookingPrefillEmail !== 'undefined' ? bookingPrefillEmail : '' %>" autocomplete="email" required>
                                </div>
                                <% } %>
                                <div class="form-field">
                                    <i class="las la-tags"></i>
                                    <select name="package-type" id="type" class="niceSelect">
                                        <option value="regular" selected><%= t('booking.package.regular', 'Regular Transport') %></option>
                                        <option value="business"><%= t('booking.package.business', 'Business Transport') %></option>
                                        <option value="handicap"><%= t('booking.package.handicap', 'Handicap Transport') %></option>
                                    </select>
                                </div>
                                <div class="form-field">
                                    <i class="las la-user-friends"></i>
                                    <select name="passengers" id="passengers" class="niceSelect">
                                        <%- include('../bookings/partials/passenger-select-options') %>
                                    </select>
                                </div>
                                <div class="form-field">
                                    <i class="las la-map-marker"></i>
                                    <input type="text" id="start-dest" name="start-dest" class="form-control"
                                        placeholder="<%= t('home.booking.startDestination', 'Pickup address') %>" required>
                                </div>
                                <div class="form-field">
                                    <i class="las la-map-marker"></i>
                                    <input type="text" id="end-dest" name="end-dest" class="form-control"
                                        placeholder="<%= t('home.booking.endDestination', 'Drop-off address') %>" required>
                                </div>
                                <div class="form-field">
                                    <i class="las la-calendar"></i>
                                    <input type="text" id="ride-date" name="ride-date" class="form-control date-picker"
                                        placeholder="<%= t('home.booking.selectDate', 'Ride date') %>" required>
                                </div>
                                <div class="form-field">
                                    <i class="las la-clock"></i>
                                    <input type="text" id="ride-time" name="ride-time" class="form-control time-picker"
                                        placeholder="<%= t('home.booking.selectTime', 'Ride time') %>" required>
                                </div>
                                <div class="form-field">
                                    <button id="submit" class="default-btn" type="submit"><%= t('home.booking.submit', 'Request ride') %></button>
                                </div>
                            </div>
                            <div id="form-messages" class="alert" role="alert"></div>
                        </form><!-- Booking Form -->
                    </div>
                </div>
            </div>
        </div>
    </section><!--/.booking-section-->

    <section class="pricing-section bg-grey bd-bottom padding">
        <div class="container">
            <div class="section-heading text-center mb-40 wow fade-in-bottom" data-wow-delay="200ms">
                <h4><span></span><%= t('home.pricing.eyebrow', 'Our fleet') %></h4>
                <h2><%= t('home.pricing.title', 'Adapted vans & accessible taxis') %></h2>
                <p><%= t('home.pricing.description', 'Explore wheelchair-accessible vehicles with ramps or lifts, plus business and standard taxis. Published vehicles appear below—admin can add photos and specs.') %></p>
            </div><!--/.section-heading-->
            <ul class="nav pricing-tab-menu" id="pricing-tab" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="hybrid-taxi" data-bs-toggle="tab"
                        data-bs-target="#hybrid-taxi-content" type="button" role="tab"
                        aria-controls="hybrid-taxi-content" aria-selected="true"><%= t('home.pricing.hybridTaxi', 'Wheelchair vans') %></button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="town-taxt" data-bs-toggle="tab" data-bs-target="#town-taxi-content"
                        type="button" role="tab" aria-controls="town-taxi-content" aria-selected="false"><%= t('home.pricing.townTaxi', 'Business transport') %></button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="limousine-taxi" data-bs-toggle="tab"
                        data-bs-target="#limousine-taxi-content" type="button" role="tab"
                        aria-controls="limousine-taxi-content" aria-selected="false"><%= t('home.pricing.limousineTaxi', 'Regular taxi') %></button>
                </li>
            </ul>
            <!--Tab Menu-->
            <% const pt = pricingTabs && pricingTabs.length === 3 ? pricingTabs : [[], [], []]; %>
            <div class="tab-content" id="pricing-tab-content">
                <div class="tab-pane fade show active" id="hybrid-taxi-content" role="tabpanel"
                    aria-labelledby="hybrid-taxi-content">
                    <div class="row">
                        <% if (pt[0].length) { pt[0].forEach(function(car) { %>
                            <%- include('../partials/pricing-car-item', { car: car, t: t, withLocale: typeof withLocale === 'function' ? withLocale : null }) %>
                        <% }); } else { %>
                            <div class="col-12 text-center text-muted py-4"><%= t('home.pricing.noCars', 'No vehicles published yet. Add cars in the admin panel.') %></div>
                        <% } %>
                    </div>
                </div>
                <div class="tab-pane fade" id="town-taxi-content" role="tabpanel" aria-labelledby="town-taxi-content">
                    <div class="row">
                        <% if (pt[1].length) { pt[1].forEach(function(car) { %>
                            <%- include('../partials/pricing-car-item', { car: car, t: t, withLocale: typeof withLocale === 'function' ? withLocale : null }) %>
                        <% }); } else { %>
                            <div class="col-12 text-center text-muted py-4"><%= t('home.pricing.noCars', 'No vehicles published yet. Add cars in the admin panel.') %></div>
                        <% } %>
                    </div>
                </div>
                <div class="tab-pane fade" id="limousine-taxi-content" role="tabpanel" aria-labelledby="limousine-taxi">
                    <div class="row">
                        <% if (pt[2].length) { pt[2].forEach(function(car) { %>
                            <%- include('../partials/pricing-car-item', { car: car, t: t, withLocale: typeof withLocale === 'function' ? withLocale : null }) %>
                        <% }); } else { %>
                            <div class="col-12 text-center text-muted py-4"><%= t('home.pricing.noCars', 'No vehicles published yet. Add cars in the admin panel.') %></div>
                        <% } %>
                    </div>
                </div>
            </div><!-- Tab Content -->
        </div>
    </section>
    <!--/.pricing-section-->

    <% const ctaBookPath = typeof withLocale === 'function' ? withLocale('/book-taxi') : '/book-taxi'; %>
    <section class="download-section bd-bottom padding" style="background: linear-gradient(180deg, #f8fafc 0%, #fff 100%);">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <div class="section-heading wow fade-in-left" data-wow-delay="200ms">
                        <h4><span></span><%= t('home.professional.eyebrow', 'Accessibility first') %></h4>
                        <h2><%= t('home.professional.title', 'Handicap transport you can trust') %></h2>
                        <p class="text-muted"><%= t('home.professional.description', 'Handicap transport is our priority: adapted vehicles, trained drivers, and 24/7 dispatch for hospitals and care homes. We also provide executive business rides and everyday taxi—book on the web; no app required.') %></p>
                        <ul class="app-feature">
                            <li>
                                <i><img class="feature-icon" src="/assets/img/icon-navigator.svg" alt=""></i>
                                <h3><%= t('home.professional.point1', 'Safe wheelchair transfers') %><br><span class="text-muted" style="font-size:0.9rem;font-weight:400"><%= t('home.professional.point1sub', 'Ramps, lifts, restraints—and drivers who know how to use them.') %></span></h3>
                            </li>
                            <li>
                                <i><img class="feature-icon" src="/assets/img/icon-clock.svg" alt=""></i>
                                <h3><%= t('home.professional.point2', 'TFlex & Mutuelle billing') %><br><span class="text-muted" style="font-size:0.9rem;font-weight:400"><%= t('home.professional.point2sub', 'Ask about reimbursement paperwork when you book.') %></span></h3>
                            </li>
                            <li>
                                <i><img class="feature-icon" src="/assets/img/icon-docs.svg" alt=""></i>
                                <h3><%= t('home.professional.point3', 'Business & regular taxi too') %><br><span class="text-muted" style="font-size:0.9rem;font-weight:400"><%= t('home.professional.point3sub', 'Same booking flow—choose handicap, business or regular transport.') %></span></h3>
                            </li>
                        </ul>
                        <div class="mt-4">
                            <a href="<%= ctaBookPath %>" class="default-btn d-inline-block"><%= t('home.professional.ctaBook', 'Book your ride') %></a>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 d-none d-lg-block text-center">
                    <img class="img-fluid rounded shadow-sm wow fade-in-bottom" data-wow-delay="200ms" src="/assets/img/slider-bg.jpg" alt="" style="max-height: 380px; object-fit: cover; width: 100%; max-width: 520px; margin: 0 auto;">
                </div>
            </div>
        </div>
    </section>
    <!--/.value section (replaces app download)-->

    <section class="testimonial-section bg-grey">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <div class="section-heading mb-10">
                        <h4><span></span><%= t('home.testimonial.eyebrow', 'Passenger stories') %></h4>
                        <h2><%= t('home.testimonial.title', 'Trusted for accessible rides') %></h2>
                        <p><%= t('home.testimonial.description', 'Families and caregivers rely on Taxiofany for dignified, on-time handicap transport across Belgium.') %></p>
                    </div>
                    <div class="swiper-outside testi-pagination">
                        <div class="testimonial-carousel">
                            <div class="swiper-wrapper">
                                <%- include('../partials/testimonial-slides', { testimonials: testimonials, t: t }) %>
                            </div>
                        </div>
                        <div class="swiper-pagination"></div><!-- Carousel Dots -->
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="feature-wrap">
                        <div class="section-heading mb-30 wow fade-in-right" data-wow-delay="200ms">
                            <h4 class="white"><span></span><%= t('home.features.eyebrow', 'Why Taxiofany') %></h4>
                            <h2 class="white"><%= t('home.features.title', 'Built around accessibility') %></h2>
                            <p class="white"><%= t('home.features.description', 'Ramp- and lift-equipped vans, 4-point wheel restraint systems, caregiver seating, and dispatch that understands medical and care-home schedules.') %></p>
                        </div>
                        <!--/.section-heading-->
                        <ul class="taxiofany-features">
                            <li class="wow fade-in-right" data-wow-delay="300ms">
                                <div class="feature-icon">
                                    <i class="las la-gem"></i>
                                </div>
                                <div class="feature-content">
                                    <h3><%= t('home.features.safeGuarantee', 'Trained for safe transfers') %></h3>
                                    <p><%= t('home.features.itemDescription', 'Drivers practiced in boarding, securing wheelchairs, and assisting passengers with reduced mobility.') %></p>
                                </div>
                            </li>
                            <li class="wow fade-in-right" data-wow-delay="400ms">
                                <div class="feature-icon">
                                    <i class="las la-taxi"></i>
                                </div>
                                <div class="feature-content">
                                    <h3><%= t('home.features.fastPickups', 'Hospital & care-home rides') %></h3>
                                    <p><%= t('home.features.itemDescription', 'Drivers practiced in boarding, securing wheelchairs, and assisting passengers with reduced mobility.') %></p>
                                </div>
                            </li>
                            <li class="wow fade-in-right" data-wow-delay="500ms">
                                <div class="feature-icon">
                                    <i class="las la-tachometer-alt"></i>
                                </div>
                                <div class="feature-content">
                                    <h3><%= t('home.features.quickRide', 'Adapted vehicles') %></h3>
                                    <p><%= t('home.features.itemDescription', 'Drivers practiced in boarding, securing wheelchairs, and assisting passengers with reduced mobility.') %></p>
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!--/.testimonial-section-->

    <section class="cta-section padding">
        <div class="cta-men wow fade-in-bottom" data-wow-delay="200ms"></div>
        <div class="container">
            <div class="cta-content">
                <h2><%= t('home.cta.callUsNow', 'Call now') %> <span><%= t('home.cta.bookYourTaxi', 'book accessible transport') %></span> <br> <%= t('home.cta.forYourNextRide', 'for your next journey') %></h2>
                <p><%= t('home.cta.description', 'Wheelchair-accessible vans across Belgium. Business and regular taxi also available. TFlex/Mutuelle on request.') %></p>
                <div class="cta-call">
                    <i class="las la-phone-volume"></i>
                    <p><span><%= t('home.cta.callForTaxi', 'Call for accessible transport') %></span><a href="tel:<%= String(publicPhone).replace(/[^\d+]/g, '') %>"><%= publicPhone %></a></p>
                </div>
            </div>
        </div>
    </section>
    <!--/.cta-section-->

    <% const homeBlogPosts = typeof blogPosts !== 'undefined' && Array.isArray(blogPosts) ? blogPosts : []; %>
    <section class="blog-section bg-grey padding">
        <div class="container">
            <div class="section-heading text-center mb-40 wow fade-in-bottom" data-wow-delay="200ms">
                <h4><span></span><%= t('home.blog.eyebrow', 'Mobility news') %></h4>
                <h2><%= t('home.blog.title', 'Insights on accessible transport') %></h2>
                <p><%= t('home.blog.description', 'Updates on handicap transport, vehicle adaptations, and travelling safely in Belgium.') %></p>
            </div>
            <% if (homeBlogPosts.length) { %>
            <div class="row grid-post">
                <% homeBlogPosts.forEach(function(post) { %>
                <% const postCatKey = (post.category || '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, ''); %>
                <% const blogDetailPath = post.slug ? ('/blog/details/' + encodeURIComponent(String(post.slug).trim())) : '/blog'; %>
                <% const blogHref = typeof withLocale === 'function' ? withLocale(blogDetailPath) : blogDetailPath; %>
                <div class="col-lg-4 col-md-6 padding-15">
                    <div class="post-card">
                        <div class="post-thumb">
                            <img src="<%= (post.coverImage && String(post.coverImage).trim()) || '/assets/img/post-1.jpg' %>" alt="">
                            <a href="<%= blogHref %>" class="post-category"><%= postCatKey ? t('blog.category.' + postCatKey, post.category || '') : (post.category || t('home.blog.categoryBusiness')) %></a>
                        </div>
                        <div class="post-content-wrap">
                            <ul class="post-meta">
                                <li><i class="las la-calendar"></i><%= post.publishedAt ? new Date(post.publishedAt).toLocaleDateString(locale || 'nl') : t('common.emDash', '—') %></li>
                                <li><i class="las la-user"></i><%= post.authorName || '—' %></li>
                            </ul>
                            <div class="post-content">
                                <h3>
                                    <a href="<%= blogHref %>" class="hover"><%= post.slug ? t('blog.' + post.slug + '.title', post.title || '') : (post.title || '') %></a>
                                </h3>
                                <p><%= post.slug ? t('blog.' + post.slug + '.excerpt', post.excerpt || '') : (post.excerpt || '') %></p>
                                <a href="<%= blogHref %>" class="read-more"><%= t('home.blog.readMore', 'Read more') %></a>
                            </div>
                        </div>
                    </div>
                </div>
                <% }); %>
            </div>
            <% } else { %>
            <p class="text-center text-muted py-4 mb-0"><%= t('home.empty.noPublishedBlog', 'No published blog posts to show. Publish a post in the admin panel (Show on public website).') %></p>
            <% } %>
        </div>
    </section>
    <!--/.blog-section-->

    <%- include('../../shared/partials/legacy-footer') %>
