                <div class="tab-pane fade" id="town-taxi-content" role="tabpanel" aria-labelledby="town-taxi-content">
                    <div class="row">
                        <% if (pt[1].length) { pt[1].forEach(function(car) { %>
                            <%- include('../partials/pricing-car-item', { car: car, t: t, withLocale: typeof withLocale === 'function' ? withLocale : null }) %>
                        <% }); } else { %>
                            <div class="col-12 text-center text-muted py-4"><%= t('home.pricing.noCars', 'No vehicles published yet. Add cars in the admin panel.') %></div>
                        <% } %>
                    </div>
                </div>
                <div class="tab-pane fade" id="limousine-taxi-content" role="tabpanel" aria-labelledby="limousine-taxi">
                    <div class="row">
                        <% if (pt[2].length) { pt[2].forEach(function(car) { %>
                            <%- include('../partials/pricing-car-item', { car: car, t: t, withLocale: typeof withLocale === 'function' ? withLocale : null }) %>
                        <% }); } else { %>
                            <div class="col-12 text-center text-muted py-4"><%= t('home.pricing.noCars', 'No vehicles published yet. Add cars in the admin panel.') %></div>
                        <% } %>
                    </div>
                </div>
            </div><!-- Tab Content -->
        </div>
    </section>
