<%- include('../../shared/partials/legacy-head') %>
<%- include('../../shared/partials/legacy-header-nav') %>

<div class="slider-section">
        <div class="main-slider-2">
            <div class="swiper-wrapper">
                <% const homeBannerImages = ['/assets/img/banner-1.jpg', '/assets/img/banner-2.jpg', '/assets/img/banner-3.jpg', '/assets/img/slider-bg.jpg']; %>
                <% homeBannerImages.forEach(function(bannerImage) { %>
                <div class="swiper-slide">
                    <div class="slider-img"><img src="<%= bannerImage %>" alt="Taxiofany banner" class="kenburns" style="animation-duration: 12000ms; "></div>
                    <div class="slider-content-wrap d-flex align-items-center text-left">
                        <div class="container">
                            <div class="slider-content text-center pb-60">
                                <div class="slider-caption medium">
                                    <div class="inner-layer">
                                        <div data-animation="fade-in-bottom" data-delay="0.3s"><%= t('home.hero.tagline', 'Travel securely with us!') %></div>
                                    </div>
                                </div>
                                <div class="slider-caption big">
                                    <div class="inner-layer">
                                        <div data-animation="fade-in-bottom" data-delay="0.5s"><%= t('home.hero.title', 'Book your taxi from anywhare today!') %></div>
                                    </div>
                                </div>
                                <div class="slider-caption small">
                                    <div class="inner-layer">
                                        <div data-animation="fade-in-bottom" data-delay="0.7s" data-duration="1s"><%= t('home.hero.description', 'Everything your taxi business needs is already here! taxiOfany made for taxi service companies!') %></div>
                                    </div>
                                </div>
                                <div class="slider-btn">
                                    <a href="/book-taxi" class="default-btn" data-animation="fade-in-bottom" data-delay="0.9s"><%= t('home.hero.ctaBookNow', 'Book Now') %></a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <% }); %>
            </div>
            <!-- Slider Arrows -->
            <div class="swiper-nav swiper-next"><i class="las la-long-arrow-alt-right"></i></div>
            <div class="swiper-nav swiper-prev"><i class="las la-long-arrow-alt-left"></i></div>
        </div>
    </div>
    <!--/.slider-section-->

    <% const bookingAuthed = typeof bookingPrefillEmail !== 'undefined' && bookingPrefillEmail; %>
    <% const wl = typeof withLocale === 'function' ? withLocale : function (p) { return p; }; %>
    <section class="booking-section-2">
        <div class="container">
            <div class="row booking-form-2 g-0">
                <div class="col-md-4 d-none d-lg-block">
                    <div class="booking-car-wrap">
                        <div class="booking-car wow fade-in-left" data-wow-delay="200ms"></div>
                    </div>
                </div>
                <div class="col-lg-8">
                    <div class="section-heading mb-30">
                        <h4><span></span><%= t('home.booking.onlineBooking', 'Online Booking') %></h4>
                        <h2 class="white"><%= t('home.booking.bookTaxiRide', 'Book Your Taxi Ride') %></h2>
                    </div>
                    <form action="<%= wl('/book-taxi') %>" method="post" id="book-taxi-ride" data-booking-authed="<%= bookingAuthed ? '1' : '0' %>">
                        <div class="booking-form">
                            <% if (bookingAuthed) { %>
                            <div class="form-field booking-identity-field">
                                <i class="las la-user-tie"></i>
                                <input type="text" id="full-name" name="full-name" class="form-control booking-input-readonly" placeholder="<%= t('home.booking.yourName', 'Your Name') %>" value="<%= bookingPrefillName %>" autocomplete="name" readonly required aria-readonly="true">
                            </div>
                            <div class="form-field booking-identity-field">
                                <i class="las la-envelope-open"></i>
                                <input type="email" id="email" name="email" class="form-control booking-input-readonly" placeholder="<%= t('home.booking.email', 'Email') %>" value="<%= bookingPrefillEmail %>" autocomplete="email" readonly required aria-readonly="true">
                            </div>
                            <% } else { %>
                            <div class="form-field">
                                <i class="las la-user-tie"></i>
                                <input type="text" id="full-name" name="full-name" class="form-control" placeholder="<%= t('home.booking.yourName', 'Your Name') %>" value="<%= typeof bookingPrefillName !== 'undefined' ? bookingPrefillName : '' %>" autocomplete="name" required>
                            </div>
                            <div class="form-field">
                                <i class="las la-envelope-open"></i>
                                <input type="email" id="email" name="email" class="form-control" placeholder="<%= t('home.booking.email', 'Email') %>" value="<%= typeof bookingPrefillEmail !== 'undefined' ? bookingPrefillEmail : '' %>" autocomplete="email" required>
                            </div>
                            <% } %>
                            <div class="form-field">
                                <i class="las la-tags"></i>
                                <select name="package-type" id="package-type" class="niceSelect">
                                    <option value="regular" selected><%= t('booking.package.regular', 'Regular Transport') %></option>
                                    <option value="business"><%= t('booking.package.business', 'Business Transport') %></option>
                                    <option value="handicap"><%= t('booking.package.handicap', 'Handicap Transport') %></option>
                                </select>
                            </div>
                            <div class="form-field">
                                <i class="las la-user-friends"></i>
                                <select name="passengers" id="passengers" class="niceSelect">
                                    <option value="1"><%= t('pages.users.home.modern.1_person', '1 Person') %></option>
                                    <option value="2"><%= t('pages.users.home.modern.2_person', '2 Person') %></option>
                                    <option value="3"><%= t('pages.users.home.modern.3_person', '3 Person') %></option>
                                    <option value="4"><%= t('pages.users.home.modern.4_person', '4 Person') %></option>
                                    <option value="5"><%= t('pages.users.home.modern.5_person', '5 Person') %></option>
                                </select>
                            </div>
                            <div class="form-field">
                                <i class="las la-map-marker"></i>
                                <input type="text" id="start-dest" name="start-dest" class="form-control" placeholder="<%= t('home.booking.startDestination', 'Start Destination') %>" required>
                            </div>
                            <div class="form-field">
                                <i class="las la-map-marker"></i>
                                <input type="text" id="end-dest" name="end-dest" class="form-control" placeholder="<%= t('home.booking.endDestination', 'End Destination') %>" required>
                            </div>
                            <div class="form-field">
                                <i class="las la-calendar"></i>
                                <input type="text" id="ride-date" name="ride-date" class="form-control date-picker" placeholder="<%= t('home.booking.selectDate', 'Select Date') %>" required>
                            </div>
                            <div class="form-field">
                                <i class="las la-clock"></i>
                                <input type="text" id="ride-time" name="ride-time" class="form-control time-picker" placeholder="<%= t('home.booking.selectTime', 'Select Time') %>" required>
                            </div>
                            <div class="form-field">
                                <button id="submit" class="default-btn" type="submit"><%= t('home.booking.submit', 'Book Your Taxi') %></button>
                            </div>
                        </div>
                        <div id="form-messages" class="alert" role="alert"></div>
                    </form><!-- Booking Form -->
                </div>
            </div>
        </div>
    </section>
    <!--/.booking-section-->

    <% const homeServices = typeof services !== 'undefined' && Array.isArray(services) ? services : []; %>
    <% const homeFleetCars = typeof cars !== 'undefined' && Array.isArray(cars) ? cars : []; %>
    <section class="service-section bg-grey padding">
        <div class="bg-half"></div>
        <div class="container">
            <div class="section-heading text-center mb-40 wow fade-in-bottom" data-wow-delay="200ms">
                <h4><span></span><%= t('home.services.eyebrow') %></h4>
                <h2 class="white"><%= t('home.services.titleStart') %><br><%= t('home.services.titleEnd') %></h2>
                <p><%= t('home.services.description') %></p>
            </div>
            <!--/.section-heading-->
            <% if (homeServices.length) { %>
            <div class="swiper-outside">
                <div class="service-carousel">
                    <div class="swiper-wrapper">
                        <% const delayMap = ['200ms', '400ms', '600ms']; %>
                        <% homeServices.forEach(function(item, idx) { %>
                        <% const slugOk = item.slug && String(item.slug).trim(); %>
                        <% const detailPath = slugOk ? ('/services/details/' + encodeURIComponent(String(item.slug).trim())) : '/services'; %>
                        <% const serviceHref = typeof withLocale === 'function' ? withLocale(detailPath) : detailPath; %>
                        <% const cover = (item.coverImage && String(item.coverImage).trim()) || (item.featureImage && String(item.featureImage).trim()) || (item.benefitsImage && String(item.benefitsImage).trim()) || ''; %>
                        <% const carImg = (item.serviceCarImage && String(item.serviceCarImage).trim()) || (homeFleetCars.length ? (homeFleetCars[idx % homeFleetCars.length].detailImage || homeFleetCars[idx % homeFleetCars.length].image || '') : ''); %>
                        <% const useWow = idx < 3; %>
                        <div class="swiper-slide">
                            <div class="service-item<%= useWow ? ' wow fade-in-bottom' : '' %>"<% if (useWow) { %> data-wow-delay="<%= delayMap[idx] %>"<% } %>>
                                <div class="service-thumb">
                                    <img src="<%= cover || '/assets/img/service-1.jpg' %>" alt="">
                                    <div class="service-shape-wrap">
                                        <div class="service-shape"></div>
                                    </div>
                                    <% if (carImg) { %><div class="service-car"><img src="<%= carImg %>" alt=""></div><% } %>
                                </div>
                                <div class="service-content">
                                    <h3><a href="<%= serviceHref %>"><%= item.slug ? t('service.' + item.slug + '.title', item.title || t('home.services.regularTransport')) : (item.title || t('home.services.regularTransport')) %></a></h3>
                                    <p><%= item.slug ? t('service.' + item.slug + '.shortDescription', item.shortDescription || item.description || t('home.services.itemDescription')) : (item.shortDescription || item.description || t('home.services.itemDescription')) %></p>
                                    <a class="read-more" href="<%= serviceHref %>"><%= t('home.services.readMore') %></a>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                    </div>
                    <div class="swiper-pagination"></div><!-- Carousel Dots -->
                </div>
                <!-- Carousel Arrows -->
                <div class="swiper-nav swiper-next"><i class="las la-long-arrow-alt-right"></i></div>
                <div class="swiper-nav swiper-prev"><i class="las la-long-arrow-alt-left"></i></div>
            </div>
            <% } else { %>
            <p class="text-center text-white-50 py-5 mb-0" style="opacity:0.9"><%= t('home.empty.noPublishedServices', 'No published services to show. Publish at least one service in the admin panel (Show on public website).') %></p>
            <% } %>
        </div>
    </section>
    <!--/.service-section-->

    <section class="cta-section-2 padding">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-4">
                    <div class="cta-content">
                        <h4><%= t('home.cta.serviceLabel') %></h4>
                        <h2><%= t('home.cta.feelYourJourney') %></h2>
                        <a href="/book-taxi" class="default-btn"><%= t('home.cta.bookTaxiBtn') %></a>
                    </div>
                </div>
                <div class="col-lg-5">
                    <ul class="check-list">
                        <li><i class="las la-arrow-right"></i><%= t('home.cta2.item1') %></li>
                        <li><i class="las la-arrow-right"></i><%= t('home.cta2.item2') %></li>
                        <li><i class="las la-arrow-right"></i><%= t('home.cta2.item3') %></li>
                        <li><i class="las la-arrow-right"></i><%= t('home.cta2.item4') %></li>
                    </ul>
                </div>
                <div class="col-lg-3">
                    <div class="cta-men wow fade-in-right" data-wow-delay="200ms"> </div>
                </div>
            </div>
        </div>
    </section>
    <!--/.cta-section-->

    <section class="pricing-section bg-grey bd-bottom padding">
        <div class="container">
            <div class="section-heading text-center mb-40 wow fade-in-bottom" data-wow-delay="200ms">
                <h4><span></span><%= t('home.pricing.eyebrow') %></h4>
                <h2><%= t('home.pricing.title') %></h2>
                <p><%= t('home.pricing.description') %></p>
            </div>
            <!--/.section-heading-->
            <ul class="nav pricing-tab-menu" id="pricing-tab" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="hybrid-taxi" data-bs-toggle="tab" data-bs-target="#hybrid-taxi-content" type="button" role="tab" aria-controls="hybrid-taxi-content" aria-selected="true"><%= t('pages.users.home.modern.hybrid_taxi', 'Hybrid Taxi') %></button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="town-taxt" data-bs-toggle="tab" data-bs-target="#town-taxi-content" type="button" role="tab" aria-controls="town-taxi-content" aria-selected="false"><%= t('pages.users.home.modern.town_taxi', 'Town Taxi') %></button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="limousine-taxi" data-bs-toggle="tab" data-bs-target="#limousine-taxi-content" type="button" role="tab" aria-controls="limousine-taxi-content" aria-selected="false"><%= t('pages.users.home.modern.limousine_taxi', 'Limousine Taxi') %></button>
                </li>
            </ul>
            <!--Tab Menu-->
            <% const pt = pricingTabs && pricingTabs.length === 3 ? pricingTabs : [[], [], []]; %>
            <div class="tab-content" id="pricing-tab-content">
                <div class="tab-pane fade show active" id="hybrid-taxi-content" role="tabpanel" aria-labelledby="hybrid-taxi">
                    <div class="row">
                        <% if (pt[0].length) { pt[0].forEach(function(car) { %>
                            <%- include('../partials/pricing-car-item', { car: car, t: t, withLocale: typeof withLocale === 'function' ? withLocale : null }) %>
                        <% }); } else { %>
                            <div class="col-12 text-center text-muted py-4"><%= t('home.pricing.noCars', 'No vehicles published yet. Add cars in the admin panel.') %></div>
                        <% } %>
                    </div>
                </div>
                <div class="tab-pane fade" id="town-taxi-content" role="tabpanel" aria-labelledby="town-taxi-content">
                    <div class="row">
                        <% if (pt[1].length) { pt[1].forEach(function(car) { %>
                            <%- include('../partials/pricing-car-item', { car: car, t: t, withLocale: typeof withLocale === 'function' ? withLocale : null }) %>
                        <% }); } else { %>
                            <div class="col-12 text-center text-muted py-4"><%= t('home.pricing.noCars', 'No vehicles published yet. Add cars in the admin panel.') %></div>
                        <% } %>
                    </div>
                </div>
                <div class="tab-pane fade" id="limousine-taxi-content" role="tabpanel" aria-labelledby="limousine-taxi">
                    <div class="row">
                        <% if (pt[2].length) { pt[2].forEach(function(car) { %>
                            <%- include('../partials/pricing-car-item', { car: car, t: t, withLocale: typeof withLocale === 'function' ? withLocale : null }) %>
                        <% }); } else { %>
                            <div class="col-12 text-center text-muted py-4"><%= t('home.pricing.noCars', 'No vehicles published yet. Add cars in the admin panel.') %></div>
                        <% } %>
                    </div>
                </div>
            </div><!-- Tab Content -->
        </div>
    </section>
    <!--/.pricing-section-->

    <% const ctaProPath = typeof withLocale === 'function' ? withLocale('/book-taxi') : '/book-taxi'; %>
    <section class="service-section padding" style="background: linear-gradient(180deg, #0f172a 0%, #1e293b 100%);">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <div class="section-heading text-md-start mb-30">
                        <h4 class="text-white-50" style="opacity:0.85"><span></span><%= t('home.professional.eyebrow', 'Service & reliability') %></h4>
                        <h2 class="text-white"><%= t('home.professional.title', 'Built for safe, comfortable journeys') %></h2>
                        <p class="text-white-50" style="opacity:0.9"><%= t('home.professional.description', 'We focus on professional drivers, clear communication, and transparent service. Book on the web when you are ready—no app required.') %></p>
                        <ul class="app-feature list-unstyled mt-4" style="padding-left: 0;">
                            <li class="d-flex align-items-start mb-3" style="gap: 0.75rem;">
                                <i class="las la-shield-alt text-info" style="font-size: 1.75rem; margin-top: 0.15rem;"></i>
                                <div><strong class="text-white d-block"><%= t('home.professional.point1', 'Punctual pickups & familiar routes') %></strong><span class="text-white-50 small d-block"><%= t('home.professional.point1sub', 'Plan your trip with confidence and reliable scheduling.') %></span></div>
                            </li>
                            <li class="d-flex align-items-start mb-3" style="gap: 0.75rem;">
                                <i class="las la-user-tie text-info" style="font-size: 1.75rem; margin-top: 0.15rem;"></i>
                                <div><strong class="text-white d-block"><%= t('home.professional.point2', 'Licensed drivers & maintained vehicles') %></strong><span class="text-white-50 small d-block"><%= t('home.professional.point2sub', 'Safety and comfort on every trip.') %></span></div>
                            </li>
                            <li class="d-flex align-items-start" style="gap: 0.75rem;">
                                <i class="las la-file-invoice-dollar text-info" style="font-size: 1.75rem; margin-top: 0.15rem;"></i>
                                <div><strong class="text-white d-block"><%= t('home.professional.point3', 'Clear pricing & straightforward booking') %></strong><span class="text-white-50 small d-block"><%= t('home.professional.point3sub', 'Request a ride in minutes on the web—no app download needed.') %></span></div>
                            </li>
                        </ul>
                        <div class="mt-4">
                            <a href="<%= ctaProPath %>" class="default-btn d-inline-block"><%= t('home.professional.ctaBook', 'Book your ride') %></a>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 d-none d-md-block text-center">
                    <img class="img-fluid rounded shadow-lg wow fade-in-bottom" data-wow-delay="200ms" src="/assets/img/slider-bg.jpg" alt="" style="max-height: 380px; object-fit: cover; width: 100%; max-width: 520px; margin: 0 auto; border: 1px solid rgba(255,255,255,0.08);">
                </div>
            </div>
        </div>
    </section>
    <!--/.professional section (replaces app download)-->

    <section class="team-section padding">
        <div class="container">
            <div class="section-heading text-center mb-40 wow fade-in-bottom" data-wow-delay="200ms">
                <h4><span></span><%= t('home.pricing.eyebrow') %></h4>
                <h2><%= t('home.team.title', 'Our Expert Drivers') %></h2>
                <p><%= t('home.team.description', 'We successfully cope with tasks of varying complexity, provide long-term guarantees and regularly master new technologies.') %></p>
