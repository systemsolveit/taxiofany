<%- include('../../shared/partials/legacy-head') %>
<%- include('../../shared/partials/legacy-header-nav') %>
<% const contactHeaderConfig = (siteSettings && siteSettings.header) ? siteSettings.header : {}; %>
<% const contactAddress = contactHeaderConfig.location || t('footer.fallbackAddress', 'Wemmel Brussels Belgium'); %>
<% const contactPhone = contactHeaderConfig.phone || t('footer.fallbackPhone', '+32484262105'); %>
<% const contactEmail = contactHeaderConfig.email || t('footer.fallbackEmail', 'info@taxiofany.com'); %>

<div class="map-wrapper pt-90">
        <iframe src="https://www.google.com/maps?q=Wemmel%20Brussels%20Belgium&output=embed" width="100%" height="400" frameborder="0" style="border:0;" allowfullscreen=""></iframe>
    </div><!-- /#google-map -->

    <section class="contact-section bd-bottom padding">
        <div class="map"></div>
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <div class="contact-details-wrap">
                        <div class="contact-title">
                            <h2><%= t('pages.users.contact.have_any', 'Have Any') %> <span><%= t('pages.users.contact.questions', 'Questions?') %></span></h2>
                            <p><%= t('pages.users.contact.get_in_touch_to_discuss_your_employee_wellbeing_', 'Get in touch to discuss your employee wellbeing needs today. Please give us a call, drop us an email or fill out the contact form.') %></p>
                        </div>
                        <ul class="contact-details">
                            <li><i class="fas fa-map-marker-alt"></i><%= contactAddress %></li>
                            <li><i class="fas fa-envelope"></i><a href="mailto:<%= contactEmail %>"><%= contactEmail %></a></li>
                            <li><i class="fas fa-phone"></i><a href="tel:<%= String(contactPhone).replace(/[^\d+]/g, '') %>"><%= contactPhone %></a></li>
                        </ul>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="contact-form">
                        <form action="/contact/send" method="post" id="ajax_contact" class="form-horizontal">
                            <div class="contact-title">
                                <h2><%= t('pages.users.contact.contact_with_us', 'Contact With Us!') %> <span></span></h2>
                            </div>
                            <div class="contact-form-group">
                                <div class="form-field">
                                    <input type="text" id="firstname" name="firstname" class="form-control" placeholder="<%= t('contact.form.firstName', 'First Name') %>" required>
                                </div>
                                <div class="form-field">
                                    <input type="text" id="lastname" name="lastname" class="form-control" placeholder="<%= t('contact.form.lastName', 'Last Name') %>" required>
                                </div>
                                <div class="form-field">
                                    <input type="email" id="email" name="email" class="form-control" placeholder="<%= t('contact.form.email', 'Email') %>" required>
                                </div>
                                <div class="form-field">
                                    <input type="text" id="phone" name="phone" class="form-control" placeholder="<%= t('contact.form.phone', 'Phone Number') %>" required>
                                </div>
                                <div class="form-field message">
                                    <textarea id="message" name="message" cols="30" rows="4" class="form-control" placeholder="<%= t('contact.form.message', 'Message') %>" required></textarea>
                                </div>
                                <div class="form-field">
                                    <button id="submit" class="default-btn" type="submit"><%= t('pages.users.contact.send_massage', 'Send Massage') %></button>
                                </div>
                            </div>
                            <div id="form-messages" class="alert" role="alert"></div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!--/.contact-section-->

    <section class="branches-section bg-grey padding">
        <div class="container">
            <div class="row branches-lists justify-content-center">
                <div class="col-lg-6 col-md-8 sm-padding">
                    <div class="branches-list">
                        <h3><%= t('pages.users.contact.headOffice', 'Head Office') %></h3>
                        <ul>
                            <li><%= contactAddress %></li>
                            <li><a href="tel:<%= String(contactPhone).replace(/[^\d+]/g, '') %>"><%= contactPhone %></a></li>
                            <li><a href="mailto:<%= contactEmail %>"><%= contactEmail %></a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!--/.branches-section-->

    <%- include('../../shared/partials/legacy-footer') %>
