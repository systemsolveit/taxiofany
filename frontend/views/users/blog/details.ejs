                        <ul class="tags">
                            <li><a href="#"><%= t('pages.users.blog.details.business', 'Business') %></a></li>
                            <li><a href="#"><%= t('pages.users.blog.details.marketing', 'Marketing') %></a></li>
                            <li><a href="#"><%= t('pages.users.blog.details.startup', 'Startup') %></a></li>
                            <li><a href="#"><%= t('pages.users.blog.details.design', 'Design') %></a></li>
                        </ul>
                        <!--Tags-->

                        <ul class="post-navigation">
                            <li><a href="/blog/details"><span><i class="las la-angle-left"></i><%= t('pages.users.blog.details.previous', 'Previous') %></span><%= t('pages.users.blog.details.how_to_start_initiating_an_startup_in_few_days', 'How To Start Initiating An Startup In Few Days.') %></a></li>
                            <li><a href="/blog/details"><span><%= t('pages.users.blog.details.next', 'Next') %><i class="las la-angle-right"></i></span><%= t('pages.users.blog.details.fresh_startup_ideas_for_digital_business', 'Fresh Startup Ideas For Digital Business.') %></a></li>
                        </ul>
                        <!--Post Navigations-->

                        <div class="author-box">
                            <div class="author-thumb">
                                <img src="/assets/img/auhtor.png" alt="img">
                            </div>
                            <div class="author-info">
                                <h3>Elliot Alderson</h3>
                                <p>Our versatile team is built of designers, developers and digital marketers who all bring unique experience.</p>
