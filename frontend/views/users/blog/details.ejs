                    <li><i class="las la-user"></i><%= t('pages.users.blog.details.elliot_alderson', 'Elliot Alderson') %></li>
                    <li><i class="las la-calendar"></i><%= t('pages.users.blog.details.jan_01_2022', 'Jan 01 2022') %></li>
                    <li><i class="las la-comments"></i><%= t('pages.users.blog.details.comments_0', 'Comments 0') %></li>
