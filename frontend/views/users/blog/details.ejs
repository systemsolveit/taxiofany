                        <h3 class="comment-title"><%= t('pages.users.blog.details.post_comments', 'Post Comments') %></h3>
                        <ul class="comments-box">
                            <li class="comment">
                                <div class="comment-inner">
                                    <div class="comment-thumb"><img src="/assets/img/comment-1.png" alt="img"></div>
                                    <div class="comment-wrap">
                                        <div class="comments-meta">
                                            <h4><%= t('pages.users.blog.details.ashton_porter', 'Ashton Porter') %> <span><%= t('pages.users.blog.details.jan_01_2022_at_8_00', 'Jan 01, 2022 at 8:00') %></span></h4>
