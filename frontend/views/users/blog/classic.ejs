<%- include('../../shared/partials/legacy-head') %>
<%- include('../../shared/partials/legacy-header-nav') %>

<section class="page-header">
        <div class="page-header-shape"></div>
        <div class="container">
            <div class="page-header-info">
                <h4><%= t('pages.users.blog.classic.blog_classic', 'Blog Classic!') %></h4>
                <h2><%= t('pages.users.blog.classic.feel_your_journey', 'Feel your journey') %> <br> <%= t('pages.users.blog.classic.with', 'with') %> <span><%= t('pages.users.blog.classic.taxiofany', 'taxiOfany!') %></span></h2>
                <p><%= t('pages.users.blog.classic.everything_your_taxi_business', 'Everything your taxi business') %> <br><%= t('pages.users.blog.classic.needs_is_already_here', 'needs is already here!') %> </p>
            </div>
        </div>
    </section>
    <!--/.page-header-->

    <section class="blog-section blog-page bg-grey padding">
        <div class="container">
            <div class="row">
                <div class="col-lg-8 sm-padding">
                    <div class="classic-post">
                        <% if (Array.isArray(blogPosts) && blogPosts.length) { %>
                        <% blogPosts.forEach(function(post) { %>
                        <% var postCatKey = (post.category || '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, ''); %>
                        <div class="post-card">
                            <div class="post-thumb">
                                <img src="<%= post.coverImage || '/assets/img/post-1.jpg' %>" alt="post">
                                <a href="/blog/details/<%= encodeURIComponent(post.slug) %>" class="post-category"><%= postCatKey ? t('blog.category.' + postCatKey, post.category || t('pages.users.blog.classic.business', 'Business')) : (post.category || t('pages.users.blog.classic.business', 'Business')) %></a>
                            </div>
                            <div class="post-content-wrap">
                                <ul class="post-meta">
                                    <li><i class="las la-calendar"></i><%= post.publishedAt ? new Date(post.publishedAt).toLocaleDateString(locale || 'en') : t('common.dateUnavailable', 'Date unavailable') %></li>
                                    <li><i class="las la-user"></i><%= post.authorName || t('pages.users.blog.classic.elliot_alderson', 'Elliot Alderson') %></li>
                                </ul>
                                <div class="post-content">
                                    <h3><a href="/blog/details/<%= encodeURIComponent(post.slug) %>" class="hover"><%= post.slug ? t('blog.' + post.slug + '.title', post.title || '') : (post.title || '') %></a></h3>
                                    <p><%= post.slug ? t('blog.' + post.slug + '.excerpt', post.excerpt || '') : (post.excerpt || '') %></p>
                                    <a href="/blog/details/<%= encodeURIComponent(post.slug) %>" class="read-more"><%= t('pages.users.blog.classic.read_more', 'Read More') %></a>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                        <% } else { %>
                        <div class="alert alert-light border text-center mb-0"><%= t('blog.empty', 'No published blog posts are available right now.') %></div>
                        <% } %>
                    </div>
                    <ul class="pagination-wrap text-left mt-30">
                        <% if (blogPagination && blogPagination.totalPages > 1) { %>
                            <% const currentPage = Number(blogPagination.page || 1); %>
                            <% const totalPages = Number(blogPagination.totalPages || 1); %>
                            <% const queryBase = `q=${encodeURIComponent((blogFilters && blogFilters.q) || '')}&category=${encodeURIComponent((blogFilters && blogFilters.category) || '')}`; %>
                            <li><a href="/blog/classic?<%= queryBase %>&page=<%= currentPage > 1 ? currentPage - 1 : 1 %>"><i class="las la-arrow-left"></i></a></li>
                            <% for (let p = 1; p <= totalPages; p += 1) { %>
                                <li><a href="/blog/classic?<%= queryBase %>&page=<%= p %>" class="<%= p === currentPage ? 'active' : '' %>"><%= p %></a></li>
                            <% } %>
                            <li><a href="/blog/classic?<%= queryBase %>&page=<%= currentPage < totalPages ? currentPage + 1 : totalPages %>"><i class="las la-arrow-right"></i></a></li>
                        <% } %>
                    </ul>
                    <!--Pagination-->
                </div>
                <!--Blog Grid-->
                <div class="col-lg-4 sm-padding">
                    <div class="sidebar-widget">
                        <form action="/blog/classic" method="get" class="search-form">
                            <input type="text" class="form-control" name="q" value="<%= (blogFilters && blogFilters.q) || '' %>" placeholder="<%= t('common.search', 'Search') %>">
                            <input type="hidden" name="category" value="<%= (blogFilters && blogFilters.category) || '' %>">
                            <button class="search-btn" type="submit"><i class="fa fa-search"></i></button>
                        </form>
                    </div>
                    <!--Search Form-->
                    <div class="sidebar-widget">
                        <div class="widget-title">
                            <h3><%= t('pages.users.blog.classic.categories', 'Categories') %></h3>
                        </div>
                        <ul class="category-list">
                            <% if (blogSidebar && Array.isArray(blogSidebar.categories) && blogSidebar.categories.length) { %>
                                <% blogSidebar.categories.forEach(function(category) { %>
                                    <li><a href="/blog/classic?category=<%= encodeURIComponent(category.name) %>"><%= category.name %></a><span><%= category.count %></span></li>
                                <% }) %>
                            <% } else { %>
                                <li class="text-muted"><%= t('blog.sidebar.noCategories', 'No categories yet.') %></li>
                            <% } %>
                        </ul>
                    </div>
                    <!--Categories-->
                    <div class="sidebar-widget">
                        <div class="widget-title">
                            <h3><%= t('pages.users.blog.classic.recent_articles', 'Recent Articles') %></h3>
                        </div>
                        <ul class="thumb-post">
                            <% if (blogSidebar && Array.isArray(blogSidebar.recentArticles) && blogSidebar.recentArticles.length) { %>
                                <% blogSidebar.recentArticles.forEach(function(article) { %>
                                    <li>
                                        <div class="thumb">
                                            <img src="<%= article.coverImage || '/assets/img/post-thumb-1.jpg' %>" alt="thumb">
                                        </div>
                                        <div class="thumb-post-info">
                                            <h3><a href="/blog/details/<%= encodeURIComponent(article.slug) %>"><%= article.title %></a></h3>
                                            <a href="#" class="date"><%= article.publishedAt ? new Date(article.publishedAt).toLocaleDateString(locale || 'en') : t('common.dateUnavailable', 'Date unavailable') %></a>
                                        </div>
                                    </li>
                                <% }) %>
                            <% } else { %>
                                <li class="text-muted"><%= t('blog.sidebar.noRecentArticles', 'No recent articles yet.') %></li>
                            <% } %>
                        </ul>
                    </div>
                    <!--Recent Thumb Post-->
                    <div class="sidebar-widget">
                        <div class="widget-title">
                            <h3><%= t('pages.users.blog.classic.tags', 'Tags') %></h3>
                        </div>
                        <ul class="tags">
                            <% if (blogSidebar && Array.isArray(blogSidebar.popularTags) && blogSidebar.popularTags.length) { %>
                                <% blogSidebar.popularTags.forEach(function(tag) { %>
                                    <li><a href="#"><%= tag.name %></a></li>
                                <% }) %>
                            <% } else { %>
                                <li class="text-muted"><%= t('blog.sidebar.noTags', 'No tags yet.') %></li>
                            <% } %>
                        </ul>
                    </div>
                    <!--Tags-->
                </div>
                <!--Sidebar-->
            </div>
        </div>
    </section>
    <!--Blog Section-->

    <%- include('../../shared/partials/legacy-footer') %>
