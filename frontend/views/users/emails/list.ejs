<%- include('../../shared/partials/legacy-head') %>
<%- include('../../shared/partials/legacy-header-nav') %>

<section class="page-header">
  <div class="page-header-shape"></div>
  <div class="container">
    <div class="page-header-info">
      <h4><%= t('pages.users.emails.list.email_library', 'Email Library') %></h4>
      <h2><%= t('pages.users.emails.list.published', 'Published') %> <span><%= t('pages.users.emails.list.email_templates', 'Email Templates') %></span></h2>
      <p><%= t('pages.users.emails.list.preview_the_currently_published_customer_and_ope', 'Preview the currently published customer and operations email messages managed from the admin panel.') %></p>
    </div>
  </div>
</section>

<section class="service-section bg-grey padding">
  <div class="container">
    <div class="row">
      <% if (!templates || !templates.length) { %>
        <div class="col-12">
          <div class="alert alert-light border text-center"><%= t('pages.users.emails.list.no_published_email_templates_are_available_yet', 'No published email templates are available yet.') %></div>
        </div>
      <% } else { %>
        <% templates.forEach(function(item) { %>
          <div class="col-lg-4 col-md-6 sm-padding">
            <div class="service-item wow fade-in-bottom" data-wow-delay="200ms">
              <div class="service-content p-4">
                <span class="badge badge-info mb-2"><%= item.category ? t('emails.category.' + String(item.category).toLowerCase().replace(/[^a-z0-9]+/g, '-'), item.category) : t('emails.category.general', 'General') %></span>
                <h3><a href="<%= withLocale('/emails/' + item.slug) %>"><%= item.title %></a></h3>
                <p><%= item.previewText || item.summary || '' %></p>
                <a class="read-more" href="<%= withLocale('/emails/' + item.slug) %>"><%= t('emails.list.previewCta', 'Preview Template') %></a>
              </div>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</section>

<%- include('../../shared/partials/legacy-footer') %>
