<%- include('../../shared/partials/legacy-head') %>
<%- include('../../shared/partials/legacy-header-nav') %>
<% const publicPhone = (siteSettings && siteSettings.header && siteSettings.header.phone) || t('footer.fallbackPhone', '+32484262105'); %>

<section class="page-header">
        <div class="page-header-shape"></div>
        <div class="container">
            <div class="page-header-info">
                <h4><%= t('pages.company.aboutUs.header.eyebrow', 'About Taxiofany') %></h4>
                <h2><%= t('pages.company.aboutUs.header.titleLine1', 'Wheelchair-accessible transport') %> <br> <%= t('pages.company.aboutUs.header.titleLine2', 'with') %> <span><%= t('pages.company.aboutUs.header.titleBrand', 'Taxiofany') %></span></h2>
                <p><%= t('pages.company.aboutUs.header.description', 'Belgium\'s handicap-first taxi network—adapted vans, trained drivers, TFlex/Mutuelle support on request.') %></p>
            </div>
        </div>
    </section>
    <!--/.page-header-->

    <section class="about-section padding">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 col-sm-6">
                    <div class="about-img">
                        <img class="about-img1" src="/assets/img/about-1.png" alt="img">
                        <img class="about-img2" src="/assets/img/about-2.png" alt="img">
                        <figure class="round-text"><img src="/assets/img/experience-text-round.png" alt="img"></figure>
                    </div>
                </div>
                <div class="col-md-6 col-sm-6">
                    <div class="section-heading mb-40">
                        <h4><span></span><%= t('home.about.eyebrow', 'About Taxiofany') %></h4>
                        <h2><%= t('home.about.title', 'Safe, dignified mobility for every passenger') %></h2>
                        <p><%= t('home.about.description', 'We focus on handicap and wheelchair-accessible transport first: trained drivers, ramp- and lift-equipped vans, and 24/7 dispatch for hospital, care-home and daily journeys across Belgium. Corporate shuttles and regular taxi rides are available too.') %></p>
                    </div>
                    <!--/.section-heading-->
                    <ul class="about-info">
                        <li>
                            <img class="owner-thumb" src="/assets/img/comment-1.png" alt="thumb">
                            <div class="owner">
                                <h4><%= t('home.about.founderTitle', 'Dispatch & accessibility team') %></h4>
                                <img class="signature" src="/assets/img/signature.png" alt="signature">
                            </div>
                        </li>
                        <li>
                            <h2><span><%= t('home.about.callForTaxi', 'Call for accessible transport') %></span><a href="tel:<%= String(publicPhone).replace(/[^\d+]/g, '') %>"><%= publicPhone %></a></h2>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>
    <!--/.about-section-->

    <section class="service-section bg-grey bd-bottom padding">
        <div class="bg-half"></div>
        <div class="container">
            <div class="section-heading text-center mb-40">
                <h4><span></span><%= t('home.services.eyebrow', 'What we offer') %></h4>
                <h2 class="white"><%= t('home.services.titleStart', 'Handicap transport first') %><br><%= t('home.services.titleEnd', '—then business & regular taxi') %></h2>
                <p><%= t('home.services.description', 'Primary: wheelchair-accessible vans with ramps, lifts and secure restraint systems. Secondary: executive business transport and everyday taxi rides.') %></p>
            </div>
            <!--/.section-heading-->
            <div class="swiper-outside">
                <div class="service-carousel">
                    <div class="swiper-wrapper">
                        <% const companyServices = typeof services !== 'undefined' && Array.isArray(services) ? services : []; %>
                        <% if (companyServices.length) { companyServices.forEach(function(item) { %>
                            <div class="swiper-slide">
                                <div class="service-item">
                                    <div class="service-thumb">
                                        <img src="<%= item.coverImage || '/assets/img/banner-1.jpg' %>" alt="<%= t('service.imageAlt', 'Accessible transport service') %>">
                                        <div class="service-shape-wrap">
                                            <div class="service-shape"></div>
                                        </div>
                                        <div class="service-car"><img src="<%= item.serviceCarImage || '/assets/img/car-1.png' %>" alt="<%= t('taxi.carImageAlt', 'Wheelchair-accessible taxi van') %>"></div>
                                    </div>
                                    <div class="service-content">
                                        <h3><a href="/services/details/<%= encodeURIComponent(item.slug) %>"><%= item.slug ? t('service.' + item.slug + '.title', item.title || '') : (item.title || '') %></a></h3>
                                        <p><%= item.slug ? t('service.' + item.slug + '.shortDescription', item.shortDescription || item.description || '') : (item.shortDescription || item.description || '') %></p>
                                        <a class="read-more" href="/services/details/<%= encodeURIComponent(item.slug) %>"><%= t('home.services.readMore', 'Read more') %></a>
                                    </div>
                                </div>
                            </div>
                        <% }); } else { %>
                            <div class="swiper-slide">
                                <div class="alert alert-light border text-center mb-0"><%= t('pages.services.list.noServices', 'No services available right now.') %></div>
                            </div>
                        <% } %>
                    </div>
                    <div class="swiper-pagination"></div><!-- Carousel Dots -->
                </div>
                <!-- Carousel Arrows -->
                <div class="swiper-nav swiper-next"><i class="las la-long-arrow-alt-right"></i></div>
                <div class="swiper-nav swiper-prev"><i class="las la-long-arrow-alt-left"></i></div>
            </div>
        </div>
    </section>
    <!--/.service-section-->

    <section class="testimonial-section bg-grey">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <div class="section-heading mb-10">
                        <h4><span></span><%= t('home.testimonial.eyebrow', 'Passenger stories') %></h4>
                        <h2><%= t('home.testimonial.title', 'Trusted for accessible rides') %></h2>
                        <p><%= t('home.testimonial.description', 'Families and caregivers rely on Taxiofany for dignified, on-time handicap transport across Belgium.') %></p>
                    </div>
                    <div class="swiper-outside testi-pagination">
                        <div class="testimonial-carousel">
                            <div class="swiper-wrapper">
                                <%- include('../partials/testimonial-slides', { testimonials: testimonials, t: t }) %>
                            </div>
                        </div>
                        <div class="swiper-pagination"></div><!-- Carousel Dots -->
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="feature-wrap">
                        <div class="section-heading mb-30">
                            <h4 class="white"><span></span><%= t('home.features.eyebrow', 'Why Taxiofany') %></h4>
                            <h2 class="white"><%= t('home.features.title', 'Built around accessibility') %></h2>
                            <p class="white"><%= t('home.features.description', 'Ramp- and lift-equipped vans, 4-point wheel restraint systems, caregiver seating, and dispatch that understands medical and care-home schedules.') %></p>
                        </div>
                        <!--/.section-heading-->
                        <ul class="taxiofany-features">
                            <li>
                                <div class="feature-icon">
                                    <i class="las la-gem"></i>
                                </div>
                                <div class="feature-content">
                                    <h3><%= t('home.features.safeGuarantee', 'Trained for safe transfers') %></h3>
                                    <p><%= t('home.features.itemDescription', 'Drivers practiced in boarding, securing wheelchairs, and assisting passengers with reduced mobility.') %></p>
                                </div>
                            </li>
                            <li>
                                <div class="feature-icon">
                                    <i class="las la-taxi"></i>
                                </div>
                                <div class="feature-content">
                                    <h3><%= t('home.features.fastPickups', 'Hospital & care-home rides') %></h3>
                                    <p><%= t('home.features.itemDescription', 'Drivers practiced in boarding, securing wheelchairs, and assisting passengers with reduced mobility.') %></p>
                                </div>
                            </li>
                            <li>
                                <div class="feature-icon">
                                    <i class="las la-tachometer-alt"></i>
                                </div>
                                <div class="feature-content">
                                    <h3><%= t('home.features.quickRide', 'Adapted vehicles') %></h3>
                                    <p><%= t('home.features.itemDescription', 'Drivers practiced in boarding, securing wheelchairs, and assisting passengers with reduced mobility.') %></p>
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!--/.testimonial-section-->

    <section class="cta-section padding">
        <div class="cta-men"></div>
        <div class="container">
            <div class="cta-content">
                <h2><%= t('home.cta.callUsNow', 'Call now') %> <span><%= t('home.cta.bookYourTaxi', 'book accessible transport') %></span> <br> <%= t('home.cta.forYourNextRide', 'for your next journey') %></h2>
                <p><%= t('home.cta.description', 'Wheelchair-accessible vans across Belgium. Business and regular taxi also available. TFlex/Mutuelle on request.') %></p>
                <div class="cta-call">
                    <i class="las la-phone-volume"></i>
                    <p><span><%= t('home.cta.callForTaxi', 'Call for accessible transport') %></span><a href="tel:<%= String(publicPhone).replace(/[^\d+]/g, '') %>"><%= publicPhone %></a></p>
                </div>
            </div>
        </div>
    </section>
    <!--/.cta-section-->

    <section class="blog-section bg-grey padding">
        <div class="container">
            <div class="section-heading text-center mb-40">
                <h4><span></span><%= t('pages.users.company.about-us.recent_posts', 'Recent posts') %></h4>
                <h2><%= t('pages.users.company.about-us.news_and_insights', 'Mobility news & insights') %></h2>
                <p><%= t('pages.users.company.about-us.we_successfully_cope_with_tasks_of_varying_compl', 'Stories about accessible transport in Belgium') %> <br><%= t('pages.users.company.about-us.guarantees_and_regularly_master_new_technologies', 'vehicle adaptations, caregiver tips, and safe travel.') %></p>
            </div>
            <!--/.section-heading-->
            <div class="row grid-post">
                <% const companyBlogPosts = typeof latestBlogPosts !== 'undefined' && Array.isArray(latestBlogPosts) ? latestBlogPosts : []; %>
                <% if (companyBlogPosts.length) { companyBlogPosts.forEach(function(post) { %>
                    <% const postCatKey = (post.category || '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, ''); %>
                    <div class="col-lg-4 col-md-6 padding-15">
                        <div class="post-card">
                            <div class="post-thumb">
                                <img src="<%= post.coverImage || '/assets/img/banner-1.jpg' %>" alt="<%= t('blog.postImageAlt', 'post') %>" />
                                <a href="/blog/details/<%= encodeURIComponent(post.slug) %>" class="post-category"><%= postCatKey ? t('blog.category.' + postCatKey, post.category || t('pages.users.company.about-us.business', 'Business')) : (post.category || t('pages.users.company.about-us.business', 'Business')) %></a>
                            </div>
                            <div class="post-content-wrap">
                                <ul class="post-meta">
                                    <li><i class="las la-calendar"></i><%= post.publishedAt ? new Date(post.publishedAt).toLocaleDateString(locale || 'nl') : t('common.dateUnavailable', 'Date unavailable') %></li>
                                    <li><i class="las la-user"></i><%= post.authorName || t('blog.authorFallbackName', 'Taxiofany') %></li>
                                </ul>
                                <div class="post-content">
                                    <h3>
                                        <a href="/blog/details/<%= encodeURIComponent(post.slug) %>" class="hover"><%= post.slug ? t('blog.' + post.slug + '.title', post.title || '') : (post.title || '') %></a>
                                    </h3>
                                    <p><%= post.slug ? t('blog.' + post.slug + '.excerpt', post.excerpt || post.summary || '') : (post.excerpt || post.summary || '') %></p>
                                    <a href="/blog/details/<%= encodeURIComponent(post.slug) %>" class="read-more"><%= t('pages.users.company.about-us.read_more', 'Read More') %></a>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); } else { %>
                    <div class="col-12">
                        <div class="alert alert-light border text-center mb-0"><%= t('blog.empty', 'No published blog posts are available right now.') %></div>
                    </div>
                <% } %>
            </div>
        </div>
    </section>
    <!--/.blog-section-->

    <%- include('../../shared/partials/legacy-footer') %>
