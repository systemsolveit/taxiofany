<%- include('../../shared/partials/legacy-head') %>
<%- include('../../shared/partials/legacy-header-nav') %>

<section class="page-header">
        <div class="page-header-shape"></div>
        <div class="container">
            <div class="page-header-info">
                <h4><%= t('pages.users.testimonials.testimonials', 'Testimonials!') %></h4>
                <h2><%= t('pages.users.testimonials.our_passengers', 'Our passengers') %> <span><%= t('pages.users.testimonials.reviews', 'reviews') %></span></h2>
                <p><%= t('pages.users.testimonials.everything_your_taxi_business', 'Everything your taxi business') %> <br><%= t('pages.users.testimonials.needs_is_already_here', 'needs is already here!') %> </p>
            </div>
        </div>
    </section>
    <!--/.page-header-->

    <section class="testimonial-section-2 bg-grey padding">
        <div class="container">
            <div class="swiper-outside testi-pagination">
                <div class="testimonial-carousel-2 swiper-container">
                    <div class="swiper-wrapper">
                        <% const testimonialItems = typeof testimonials !== 'undefined' && Array.isArray(testimonials) ? testimonials : []; %>
                        <% if (testimonialItems.length) { testimonialItems.forEach(function(item) { %>
                            <div class="swiper-slide">
                                <div class="testi-item">
                                    <div class="quote-icon"><i class="las la-quote-right"></i></div>
                                    <p><%= item._id ? t('testimonial.' + item._id + '.quote', item.quote || '') : (item.quote || '') %></p>
                                    <div class="testi-author">
                                        <div class="author-thumb"><img src="<%= item.avatar || '/assets/img/profile-avatar.svg' %>" alt="<%= t('testimonials.authorAlt', 'author') %>"></div>
                                        <div class="author-info">
                                            <h3><%= item._id ? t('testimonial.' + item._id + '.name', item.name || '') : (item.name || '') %> <span><%= item._id ? t('testimonial.' + item._id + '.company', item.company || item.role || '') : (item.company || item.role || '') %></span></h3>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }); } else { %>
                            <div class="swiper-slide">
                                <div class="alert alert-light border text-center mb-0"><%= t('testimonials.empty', 'No testimonials are published yet.') %></div>
                            </div>
                        <% } %>
                    </div>
                </div>
                <div class="swiper-pagination text-center"></div><!-- Carousel Dots -->
            </div>
        </div>
    </section>
    <!--/.testimonial-section-->

    <%- include('../../shared/partials/legacy-footer') %>
