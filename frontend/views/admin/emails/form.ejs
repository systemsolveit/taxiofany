<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../../shared/partials/admin-head', { pageTitle: pageTitle }) %>
  <style>
    .form-panel {
      border: 1px solid #e5e7eb;
      border-radius: 0.85rem;
      padding: 1rem;
      margin-bottom: 1rem;
      background: #fff;
    }

    .form-panel h4 {
      font-size: 1rem;
      margin-bottom: 0.85rem;
    }
  </style>
</head>
<body class="hold-transition sidebar-mini">
  <div class="wrapper">
    <%- include('../../shared/partials/admin-topbar') %>
    <%- include('../../shared/partials/admin-sidebar', { activeSection: activeSection }) %>

    <div class="content-wrapper">
      <section class="content-header">
        <div class="container-fluid d-flex justify-content-between align-items-center">
          <h1 class="mb-0"><%= mode === 'edit' ? 'Edit Email Template' : 'Create Email Template' %></h1>
          <a href="/admin/emails" class="btn btn-outline-secondary">Back</a>
        </div>
      </section>

      <section class="content">
        <div class="container-fluid">
          <% if (notice) { %>
            <div class="alert alert-<%= notice.type %>"><%= notice.message %></div>
          <% } %>

          <div class="card card-primary card-outline">
            <div class="card-body">
              <form method="post" action="<%= mode === 'edit' ? ('/admin/emails/' + template._id + '/update') : '/admin/emails/new' %>">
                <div class="form-panel">
                  <h4>Template Basics</h4>
                  <div class="form-row">
                    <div class="form-group col-md-6">
                      <label>Title</label>
                      <input class="form-control" name="title" value="<%= template.title || '' %>" required>
                    </div>
                    <div class="form-group col-md-6">
                      <label>Slug</label>
                      <input class="form-control" name="slug" value="<%= template.slug || '' %>" placeholder="auto-from-title">
                    </div>
                  </div>
                  <div class="form-row">
                    <div class="form-group col-md-4">
                      <label>Category</label>
                      <input class="form-control" name="category" value="<%= template.category || '' %>">
                    </div>
                    <div class="form-group col-md-4">
                      <label>Audience</label>
                      <input class="form-control" name="audience" value="<%= template.audience || '' %>">
                    </div>
                    <div class="form-group col-md-4">
                      <label>Tone</label>
                      <input class="form-control" name="tone" value="<%= template.tone || '' %>">
                    </div>
                  </div>
                </div>

                <div class="form-panel">
                  <h4>Message Copy</h4>
                  <div class="form-group">
                    <label>Subject</label>
                    <input class="form-control" name="subject" value="<%= template.subject || '' %>" required>
                  </div>
                  <div class="form-group">
                    <label>Preview Text</label>
                    <input class="form-control" name="previewText" value="<%= template.previewText || '' %>">
                  </div>
                  <div class="form-group">
                    <label>Summary</label>
                    <textarea class="form-control" rows="2" name="summary"><%= template.summary || '' %></textarea>
                  </div>
                  <div class="form-row">
                    <div class="form-group col-md-6">
                      <label>Hero Title</label>
                      <input class="form-control" name="heroTitle" value="<%= template.heroTitle || '' %>">
                    </div>
                    <div class="form-group col-md-6">
                      <label>Body Title</label>
                      <input class="form-control" name="bodyTitle" value="<%= template.bodyTitle || '' %>">
                    </div>
                  </div>
                  <div class="form-group">
                    <label>Hero Description</label>
                    <textarea class="form-control" rows="3" name="heroDescription"><%= template.heroDescription || '' %></textarea>
                  </div>
                  <div class="form-group">
                    <label>Body Content</label>
                    <textarea class="form-control" rows="6" name="bodyContent"><%= template.bodyContent || '' %></textarea>
                  </div>
                </div>

                <div class="form-panel">
                  <h4>Call To Action</h4>
                  <div class="form-row">
                    <div class="form-group col-md-6">
                      <label>CTA Label</label>
                      <input class="form-control" name="ctaLabel" value="<%= template.ctaLabel || '' %>">
                    </div>
                    <div class="form-group col-md-6">
                      <label>CTA URL</label>
                      <input class="form-control" name="ctaUrl" value="<%= template.ctaUrl || '' %>">
                    </div>
                  </div>
                </div>

                <div class="form-row">
                  <div class="form-group col-md-4">
                    <label>Display Order</label>
                    <input type="number" min="0" class="form-control" name="displayOrder" value="<%= Number(template.displayOrder || 0) %>">
                  </div>
                  <div class="form-group col-md-4 d-flex align-items-center">
                    <div class="form-check mt-4">
                      <input class="form-check-input" type="checkbox" name="isPublished" value="true" id="published-check" <%= template.isPublished ? 'checked' : '' %>>
                      <label class="form-check-label" for="published-check">Published</label>
                    </div>
                  </div>
                </div>

                <div class="d-flex" style="gap:0.5rem;">
                  <button type="submit" class="btn btn-primary"><%= mode === 'edit' ? 'Update Template' : 'Create Template' %></button>
                </div>
              </form>
              <% if (mode === 'edit') { %>
                <form method="post" action="/admin/emails/<%= template._id %>/delete" onsubmit="return confirm('Delete this email template?');" class="mt-3">
                  <button type="submit" class="btn btn-outline-danger">Delete</button>
                </form>
              <% } %>
            </div>
          </div>
        </div>
      </section>
    </div>

    <footer class="main-footer">
      <strong>Taxiofany Admin.</strong>
    </footer>
  </div>

  <%- include('../../shared/partials/admin-scripts') %>
</body>
</html>
