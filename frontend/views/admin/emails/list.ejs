<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../../shared/partials/admin-head', { pageTitle: pageTitle }) %>
  <style>
    .email-hero {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .email-stat {
      border: 1px solid #dbeafe;
      background: linear-gradient(135deg, #eff6ff 0%, #f8fafc 100%);
      border-radius: 0.9rem;
      padding: 1rem 1.2rem;
      color: #1f2937;
    }

    .email-stat strong {
      display: block;
      font-size: 1.15rem;
      line-height: 1;
    }
  </style>
</head>
<body class="hold-transition sidebar-mini">
  <div class="wrapper">
    <%- include('../../shared/partials/admin-topbar') %>
    <%- include('../../shared/partials/admin-sidebar', { activeSection: activeSection }) %>

    <div class="content-wrapper">
      <section class="content-header">
        <div class="container-fluid">
          <h1>Email Management</h1>
        </div>
      </section>

      <section class="content">
        <div class="container-fluid">
          <% if (notice) { %>
            <div class="alert alert-<%= notice.type %>"><%= notice.message %></div>
          <% } %>

          <div class="email-hero">
            <div class="email-stat">
              <strong><%= Array.isArray(templates) ? templates.length : 0 %></strong>
              <span>Total email templates</span>
            </div>
            <a href="/admin/emails/new" class="btn btn-primary"><i class="fas fa-envelope-open-text mr-1"></i>Create Template</a>
          </div>

          <% const ns = typeof notificationsSettings !== 'undefined' && notificationsSettings ? notificationsSettings : {}; %>
          <div class="card mb-3">
            <div class="card-header">
              <h3 class="card-title mb-0">Ride status emails</h3>
            </div>
            <div class="card-body">
              <form method="post" action="/admin/settings/notifications/update">
                <input type="hidden" name="_redirect" value="/admin/emails">
                <div class="form-row align-items-end">
                  <div class="form-group col-md-6 mb-md-0">
                    <label for="rideStatusEmailTemplateId">Template for customer notifications</label>
                    <select class="form-control" id="rideStatusEmailTemplateId" name="rideStatusEmailTemplateId">
                      <option value="">Default (system “ride status update” template)</option>
                      <% if (Array.isArray(templates)) { templates.forEach(function(t) { %>
                        <option value="<%= t._id %>" <%= String(ns.rideStatusEmailTemplateId || '') === String(t._id) ? 'selected' : '' %>><%= t.title %></option>
                      <% }); } %>
                    </select>
                  </div>
                  <div class="form-group col-md-3 mb-md-0">
                    <label for="sendOnStatusChange">Send when booking status changes</label>
                    <select class="form-control" id="sendOnStatusChange" name="sendOnStatusChange">
                      <option value="true" <%= ns.sendOnStatusChange !== false ? 'selected' : '' %>>Enabled</option>
                      <option value="false" <%= ns.sendOnStatusChange === false ? 'selected' : '' %>>Disabled</option>
                    </select>
                  </div>
                  <div class="form-group col-md-3 text-md-right">
                    <button type="submit" class="btn btn-primary">Save</button>
                  </div>
                </div>
                <p class="text-muted small mb-0">Uses site primary color and template placeholders such as <code>{{customerName}}</code>, <code>{{bookingCode}}</code>, <code>{{status}}</code>.</p>
              </form>
            </div>
          </div>

          <div class="card">
            <div class="card-header">
              <h3 class="card-title">Template Library</h3>
            </div>
            <div class="card-body table-responsive p-0">
              <table class="table table-hover text-nowrap">
                <thead>
                  <tr>
                    <th>Template</th>
                    <th>Subject</th>
                    <th>Audience</th>
                    <th>Status</th>
                    <th class="text-right">Preview</th>
                    <th class="text-right">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (!templates || !templates.length) { %>
                    <tr>
                      <td colspan="6" class="text-center text-muted py-4">No email templates found.</td>
                    </tr>
                  <% } else { %>
                    <% templates.forEach(function(item) { %>
                      <tr>
                        <td>
                          <strong><%= item.title %></strong>
                          <div class="text-muted small"><%= item.category || '-' %> / <%= item.slug %></div>
                        </td>
                        <td><%= item.subject || '-' %></td>
                        <td><%= item.audience || '-' %></td>
                        <td><span class="badge badge-<%= item.isPublished ? 'success' : 'secondary' %>"><%= item.isPublished ? 'published' : 'draft' %></span></td>
                        <td class="text-right">
                          <button type="button" class="btn btn-sm btn-outline-secondary email-preview-btn" data-preview-url="/admin/emails/preview/<%= item._id %>">Preview</button>
                        </td>
                        <td class="text-right"><a href="/admin/emails/<%= item._id %>/edit" class="btn btn-sm btn-outline-primary">Edit</a></td>
                      </tr>
                    <% }) %>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </section>
    </div>

    <footer class="main-footer">
      <strong>Taxiofany Admin.</strong>
    </footer>
  </div>

  <div class="modal fade" id="emailPreviewModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Template preview</h5>
          <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
        </div>
        <div class="modal-body p-0" style="height:70vh;">
          <iframe id="emailPreviewFrame" title="Email preview" style="width:100%;height:100%;border:0;"></iframe>
        </div>
      </div>
    </div>
  </div>

  <%- include('../../shared/partials/admin-scripts') %>
  <script>
    (function () {
      $('.email-preview-btn').on('click', function () {
        var url = $(this).data('preview-url');
        $('#emailPreviewFrame').attr('src', url);
        $('#emailPreviewModal').modal('show');
      });
      $('#emailPreviewModal').on('hidden.bs.modal', function () {
        $('#emailPreviewFrame').attr('src', 'about:blank');
      });
    })();
  </script>
</body>
</html>
