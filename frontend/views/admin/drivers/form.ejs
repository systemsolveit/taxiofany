<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../../shared/partials/admin-head', { pageTitle: pageTitle }) %>
</head>
<body class="hold-transition sidebar-mini">
  <div class="wrapper">
    <%- include('../../shared/partials/admin-topbar') %>
    <%- include('../../shared/partials/admin-sidebar', { activeSection: activeSection }) %>

    <div class="content-wrapper">
      <section class="content-header">
        <div class="container-fluid d-flex justify-content-between align-items-center">
          <h1 class="mb-0"><%= mode === 'edit' ? 'Edit Driver' : 'Create Driver' %></h1>
          <a href="/admin/drivers" class="btn btn-outline-secondary">Back</a>
        </div>
      </section>

      <section class="content">
        <div class="container-fluid">
          <% if (notice) { %>
            <div class="alert alert-<%= notice.type %>"><%= notice.message %></div>
          <% } %>

          <div class="card card-primary card-outline">
            <div class="card-body">
              <form method="post" action="<%= mode === 'edit' ? ('/admin/drivers/' + driver._id + '/update') : '/admin/drivers/new' %>">
                <div class="form-row">
                  <div class="form-group col-md-8">
                    <label>Full Name</label>
                    <input class="form-control" name="fullName" value="<%= driver.fullName || '' %>" required>
                  </div>
                  <div class="form-group col-md-4">
                    <label>Slug</label>
                    <input class="form-control" name="slug" value="<%= driver.slug || '' %>" placeholder="auto-from-name">
                  </div>
                </div>

                <div class="form-row">
                  <div class="form-group col-md-4">
                    <label>Role Title</label>
                    <input class="form-control" name="roleTitle" value="<%= driver.roleTitle || '' %>">
                  </div>
                  <div class="form-group col-md-4">
                    <label>Phone</label>
                    <input class="form-control" name="phone" value="<%= driver.phone || '' %>">
                  </div>
                  <div class="form-group col-md-4">
                    <label>Availability</label>
                    <select class="form-control" name="availability">
                      <option value="available" <%= driver.availability === 'available' ? 'selected' : '' %>>Available</option>
                      <option value="busy" <%= driver.availability === 'busy' ? 'selected' : '' %>>Busy</option>
                      <option value="offline" <%= driver.availability === 'offline' ? 'selected' : '' %>>Offline</option>
                    </select>
                  </div>
                </div>

                <div class="form-row">
                  <div class="form-group col-md-6" data-media-picker-field>
                    <label>List Image</label>
                    <input class="form-control" name="image" value="<%= driver.image || '' %>" readonly data-media-picker-value>
                    <div class="mt-2">
                      <img class="admin-media-picker-preview <%= driver.image ? '' : 'd-none' %>" src="<%= driver.image || '' %>" alt="List image preview" data-media-picker-preview-image>
                    </div>
                    <div class="btn-group btn-group-sm mt-2">
                      <button type="button" class="btn btn-outline-primary" data-media-picker-open>Choose from Media Hub</button>
                      <button type="button" class="btn btn-outline-secondary" data-media-picker-clear>Clear</button>
                    </div>
                  </div>
                  <div class="form-group col-md-6" data-media-picker-field>
                    <label>Details Image</label>
                    <input class="form-control" name="detailImage" value="<%= driver.detailImage || '' %>" readonly data-media-picker-value>
                    <div class="mt-2">
                      <img class="admin-media-picker-preview <%= driver.detailImage ? '' : 'd-none' %>" src="<%= driver.detailImage || '' %>" alt="Details image preview" data-media-picker-preview-image>
                    </div>
                    <div class="btn-group btn-group-sm mt-2">
                      <button type="button" class="btn btn-outline-primary" data-media-picker-open>Choose from Media Hub</button>
                      <button type="button" class="btn btn-outline-secondary" data-media-picker-clear>Clear</button>
                    </div>
                  </div>
                </div>

                <div class="form-row">
                  <div class="form-group col-md-4">
                    <label>Vehicle</label>
                    <input class="form-control" name="carType" value="<%= driver.carType || '' %>">
                  </div>
                  <div class="form-group col-md-4">
                    <label>Plate Number</label>
                    <input class="form-control" name="plateNumber" value="<%= driver.plateNumber || '' %>">
                  </div>
                  <div class="form-group col-md-4">
                    <label>Languages</label>
                    <input class="form-control" name="languages" value="<%= driver.languages || '' %>" placeholder="English, Dutch">
                  </div>
                </div>

                <div class="form-row">
                  <div class="form-group col-md-6">
                    <label>Experience Years</label>
                    <input type="number" min="0" class="form-control" name="experienceYears" value="<%= Number(driver.experienceYears || 0) %>">
                  </div>
                  <div class="form-group col-md-6">
                    <label>Display Order</label>
                    <input type="number" min="0" class="form-control" name="displayOrder" value="<%= Number(driver.displayOrder || 0) %>">
                  </div>
                </div>

                <div class="form-group">
                  <label>Bio</label>
                  <textarea class="form-control" name="bio" rows="6"><%= driver.bio || '' %></textarea>
                </div>

                <div class="form-group form-check">
                  <input class="form-check-input" type="checkbox" name="isPublished" value="true" id="published-check" <%= driver.isPublished ? 'checked' : '' %>>
                  <label class="form-check-label" for="published-check">Show on public website</label>
                  <small class="form-text text-muted d-block">When unchecked, this driver stays a draft and is hidden from the main site.</small>
                </div>

                <button type="submit" class="btn btn-primary"><%= mode === 'edit' ? 'Update Driver' : 'Create Driver' %></button>
              </form>
            </div>
          </div>
        </div>
      </section>
    </div>

    <footer class="main-footer">
      <strong>Taxiofany Admin.</strong>
    </footer>
  </div>

  <%- include('../shared/media-picker-modal') %>
  <%- include('../../shared/partials/admin-scripts') %>
  <script src="/admin/js/media-picker.js"></script>
</body>
</html>