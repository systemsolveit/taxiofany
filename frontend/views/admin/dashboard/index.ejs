<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../../shared/partials/admin-head', { pageTitle: pageTitle }) %>
</head>
<body class="hold-transition sidebar-mini layout-fixed">
  <div class="wrapper">
    <%- include('../../shared/partials/admin-topbar') %>
    <%- include('../../shared/partials/admin-sidebar', { activeSection: activeSection }) %>

    <div class="content-wrapper">
      <div class="content-header">
        <div class="container-fluid">
          <div class="row mb-2">
            <div class="col-sm-6">
              <h1 class="m-0">Operations Dashboard</h1>
            </div>
          </div>
        </div>
      </div>

      <section class="content">
        <div class="container-fluid">
          <div class="row">
            <% stats.forEach(function(stat) { %>
              <div class="col-lg-3 col-6">
                <div class="small-box bg-<%= stat.color %>">
                  <div class="inner">
                    <h3><%= stat.value %></h3>
                    <p><%= stat.label %></p>
                  </div>
                  <div class="icon">
                    <i class="<%= stat.icon %>"></i>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>

          <div class="row">
            <section class="col-lg-7">
              <div class="card">
                <div class="card-header">
                  <h3 class="card-title"><i class="fas fa-clock mr-1"></i> Recent Bookings</h3>
                </div>
                <div class="card-body p-0">
                  <table class="table table-striped mb-0">
                    <thead>
                      <tr>
                        <th>ID</th>
                        <th>Customer</th>
                        <th>Route</th>
                        <th>Status</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% recentBookings.forEach(function(booking) { %>
                        <tr>
                          <td><a href="/admin/bookings/<%= booking.id %>"><%= booking.id %></a></td>
                          <td><%= booking.customer %></td>
                          <td><%= booking.route %></td>
                          <td><span class="badge badge-info"><%= booking.status %></span></td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              </div>
            </section>

            <section class="col-lg-5">
              <div class="card card-primary card-outline">
                <div class="card-header">
                  <h3 class="card-title">Quick Actions</h3>
                </div>
                <div class="card-body">
                  <a href="/admin/users" class="btn btn-primary btn-block">Manage Users</a>
                  <a href="/admin/bookings" class="btn btn-outline-primary btn-block">Review Bookings</a>
                  <a href="/admin/mediahub/upload" class="btn btn-outline-info btn-block">Media Hub</a>
                  <a href="/" class="btn btn-outline-secondary btn-block">Open Public Website</a>
                </div>
              </div>
            </section>
          </div>
        </div>
      </section>
    </div>

    <footer class="main-footer">
      <strong>Taxiofany Admin.</strong> AdminLTE starter integration.
    </footer>
  </div>

  <%- include('../../shared/partials/admin-scripts') %>
</body>
</html>
