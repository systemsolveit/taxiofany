<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../../shared/partials/admin-head', { pageTitle: pageTitle }) %>
</head>
<body class="hold-transition sidebar-mini">
  <div class="wrapper">
    <%- include('../../shared/partials/admin-topbar') %>
    <%- include('../../shared/partials/admin-sidebar', { activeSection: activeSection }) %>

    <div class="content-wrapper">
      <section class="content-header">
        <div class="container-fluid d-flex justify-content-between align-items-center">
          <h1 class="mb-0">Services Management</h1>
          <a href="/admin/services/new" class="btn btn-primary"><i class="fas fa-plus mr-1"></i>New Service</a>
        </div>
      </section>

      <section class="content">
        <div class="container-fluid">
          <% if (notice) { %>
            <div class="alert alert-<%= notice.type %>"><%= notice.message %></div>
          <% } %>

          <div class="card">
            <div class="card-header">
              <h3 class="card-title">Service Items</h3>
            </div>
            <div class="card-body table-responsive p-0">
              <table class="table table-hover text-nowrap">
                <thead>
                  <tr>
                    <th>Order</th>
                    <th>Title</th>
                    <th>Slug</th>
                    <th>Category</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (!services || !services.length) { %>
                    <tr>
                      <td colspan="6" class="text-center text-muted py-4">No services yet. Create your first service item.</td>
                    </tr>
                  <% } else { %>
                    <% services.forEach(function(item) { %>
                      <tr>
                        <td><%= item.displayOrder || 0 %></td>
                        <td><%= item.title %></td>
                        <td><code><%= item.slug %></code></td>
                        <td><%= item.category || '-' %></td>
                        <td>
                          <span class="badge badge-<%= item.isPublished ? 'success' : 'secondary' %>">
                            <%= item.isPublished ? 'Published' : 'Draft' %>
                          </span>
                        </td>
                        <td>
                          <div class="d-flex" style="gap:0.35rem;">
                            <a href="/admin/services/<%= item._id %>/edit" class="btn btn-sm btn-outline-primary">Edit</a>
                            <form action="/admin/services/<%= item._id %>/delete" method="post" onsubmit="return confirm('Delete this service?');">
                              <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                          </div>
                        </td>
                      </tr>
                    <% }) %>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </section>
    </div>

    <footer class="main-footer">
      <strong>Taxiofany Admin.</strong>
    </footer>
  </div>

  <%- include('../../shared/partials/admin-scripts') %>
</body>
</html>
