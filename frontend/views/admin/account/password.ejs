<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../../shared/partials/admin-head', { pageTitle: pageTitle }) %>
</head>
<body class="hold-transition sidebar-mini">
  <div class="wrapper">
    <%- include('../../shared/partials/admin-topbar') %>
    <%- include('../../shared/partials/admin-sidebar', { activeSection: activeSection }) %>

    <div class="content-wrapper">
      <section class="content-header">
        <div class="container-fluid">
          <h1 class="mb-0">Change password</h1>
        </div>
      </section>

      <section class="content">
        <div class="container-fluid" style="max-width: 520px;">
          <% if (typeof successMessage === 'string' && successMessage) { %>
            <div class="alert alert-success"><%= successMessage %></div>
          <% } %>
          <% if (typeof errorMessage === 'string' && errorMessage) { %>
            <div class="alert alert-danger"><%= errorMessage %></div>
          <% } %>

          <div class="card">
            <div class="card-body">
              <form method="post" action="/admin/account/password">
                <div class="form-group">
                  <label>Current password</label>
                  <input type="password" name="currentPassword" class="form-control" required autocomplete="current-password">
                </div>
                <div class="form-group">
                  <label>New password</label>
                  <input type="password" name="newPassword" class="form-control" required minlength="8" autocomplete="new-password">
                  <small class="text-muted">At least 8 characters.</small>
                </div>
                <button type="submit" class="btn btn-primary">Update password</button>
              </form>
            </div>
          </div>
        </div>
      </section>
    </div>

    <footer class="main-footer">
      <strong>Taxiofany Admin.</strong>
    </footer>
  </div>

  <%- include('../../shared/partials/admin-scripts') %>
</body>
</html>
