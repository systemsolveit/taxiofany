<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../../shared/partials/admin-head', { pageTitle: pageTitle }) %>
</head>
<body class="hold-transition sidebar-mini">
  <div class="wrapper">
    <%- include('../../shared/partials/admin-topbar') %>
    <%- include('../../shared/partials/admin-sidebar', { activeSection: activeSection }) %>

    <div class="content-wrapper">
      <section class="content-header">
        <div class="container-fluid">
          <h1>Roles Management</h1>
        </div>
      </section>

      <section class="content">
        <div class="container-fluid">
          <% if (notice) { %>
            <div class="alert alert-<%= notice.type %>"><%= notice.message %></div>
          <% } %>

          <div class="row">
            <% (roles || []).forEach(function(item) { %>
              <div class="col-lg-6">
                <div class="card card-outline card-primary">
                  <div class="card-header d-flex justify-content-between align-items-center">
                    <h3 class="card-title mb-0"><%= item.role %></h3>
                    <span class="badge badge-<%= item.source === 'override' ? 'warning' : 'secondary' %>"><%= item.source || 'default' %></span>
                  </div>
                  <div class="card-body">
                    <form method="post" action="/admin/roles/<%= encodeURIComponent(item.role) %>/update">
                      <div class="form-group">
                        <label>Permissions</label>
                        <div class="border rounded p-2" style="max-height:220px; overflow:auto;">
                          <% (permissions || []).forEach(function(permission) { %>
                            <div class="form-check">
                              <input
                                class="form-check-input"
                                type="checkbox"
                                name="permissions"
                                id="perm-<%= item.role %>-<%= permission.replace(/[^a-z0-9]/gi, '-') %>"
                                value="<%= permission %>"
                                <%= Array.isArray(item.permissions) && item.permissions.includes(permission) ? 'checked' : '' %>
                              >
                              <label class="form-check-label" for="perm-<%= item.role %>-<%= permission.replace(/[^a-z0-9]/gi, '-') %>"><%= permission %></label>
                            </div>
                          <% }) %>
                        </div>
                      </div>

                      <div class="d-flex" style="gap:0.5rem;">
                        <button type="submit" class="btn btn-sm btn-primary">Save Permissions</button>
                      </div>
                    </form>

                    <form method="post" action="/admin/roles/<%= encodeURIComponent(item.role) %>/reset" class="mt-2" onsubmit="return confirm('Reset this role to default permissions?');">
                      <button type="submit" class="btn btn-sm btn-outline-secondary">Reset to Default</button>
                    </form>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      </section>
    </div>

    <footer class="main-footer">
      <strong>Taxiofany Admin.</strong>
    </footer>
  </div>

  <%- include('../../shared/partials/admin-scripts') %>
</body>
</html>
