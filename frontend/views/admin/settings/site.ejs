<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../../shared/partials/admin-head', { pageTitle: pageTitle }) %>
  <style>
    .settings-tabs .nav-link {
      border-radius: 999px;
      margin-right: 0.4rem;
      padding: 0.45rem 0.9rem;
    }

    .settings-card {
      border: 1px solid #e5e7eb;
      border-radius: 0.9rem;
      background: #fff;
      box-shadow: 0 1px 3px rgba(15, 23, 42, 0.06);
    }

    .settings-card .card-header {
      border-bottom: 1px solid #eef2f7;
      background: #fafbfc;
    }

    .settings-card .card-subtitle {
      font-size: 0.875rem;
      color: #64748b;
      margin: 0.35rem 0 0;
      font-weight: 400;
      line-height: 1.45;
    }

    .hint-box {
      border: 1px solid #dcfce7;
      background: #f0fdf4;
      color: #14532d;
      border-radius: 0.7rem;
      padding: 0.75rem 1rem;
      margin-bottom: 1rem;
    }

    .table td,
    .table th {
      vertical-align: middle;
    }

    .site-help-btn {
      min-width: 1.75rem;
      min-height: 1.75rem;
      line-height: 1;
      border-radius: 999px;
      font-weight: 700;
      color: #0f172a !important;
      border: 1px solid #cbd5e1 !important;
      background: #f8fafc !important;
    }

    .site-help-btn:hover,
    .site-help-btn:focus {
      background: #e2e8f0 !important;
      color: #0f172a !important;
      outline: 2px solid #3b82f6;
      outline-offset: 2px;
    }

    .site-settings-sticky {
      position: sticky;
      bottom: 0;
      z-index: 1020;
      margin: 1.5rem -15px -15px;
      padding: 1rem 1.25rem;
      background: linear-gradient(to top, #fff 70%, rgba(255,255,255,0.92));
      border-top: 1px solid #e5e7eb;
      box-shadow: 0 -8px 24px rgba(15, 23, 42, 0.06);
    }

    .form-group label {
      font-weight: 600;
      color: #334155;
    }

    .sr-only-help {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      border: 0;
    }

    .site-settings-accordion .card-header {
      background: #fafbfc;
    }

    .site-settings-accordion .btn-link {
      color: #0f172a;
      text-decoration: none;
      font-weight: 600;
      box-shadow: none;
    }

    .site-settings-accordion .btn-link:hover,
    .site-settings-accordion .btn-link:focus {
      color: #2563eb;
      text-decoration: none;
    }

    .site-settings-accordion .site-acc-chevron {
      transition: transform 0.2s ease;
    }

    .site-settings-accordion .btn-link:not(.collapsed) .site-acc-chevron {
      transform: rotate(180deg);
    }
  </style>
</head>
<body class="hold-transition sidebar-mini">
  <div class="wrapper">
    <%- include('../../shared/partials/admin-topbar') %>
    <%- include('../../shared/partials/admin-sidebar', { activeSection: activeSection }) %>

    <div class="content-wrapper">
      <section class="content-header">
        <div class="container-fluid">
          <h1 class="mb-0">Settings</h1>
          <p class="text-muted mb-0 small">Site &amp; navigation — control public appearance and which routes visitors can open.</p>
        </div>
      </section>

      <section class="content">
        <div class="container-fluid pb-5">
          <% if (notice) { %>
            <div class="alert alert-<%= notice.type %>"><%= notice.message %></div>
          <% } %>

          <div class="settings-tabs mb-3">
            <ul class="nav nav-pills">
              <li class="nav-item"><a class="nav-link" href="/admin/settings/mail"><i class="fas fa-envelope mr-1"></i>Mail Integrations</a></li>
              <li class="nav-item"><a class="nav-link active" href="/admin/settings/site"><i class="fas fa-palette mr-1"></i>Site & Navigation</a></li>
              <li class="nav-item"><a class="nav-link" href="/admin/settings/logs"><i class="fas fa-file-alt mr-1"></i>Logs</a></li>
            </ul>
          </div>

          <div class="hint-box">
            <strong>Control point:</strong> set brand color, navbar menu items, and page visibility from this screen. Saving updates the public site after cache refresh.
          </div>

          <form method="post" action="/admin/settings/site/update" id="siteSettingsForm">
            <div class="accordion site-settings-accordion mb-3" id="siteSettingsAccordion">
            <div class="card settings-card mb-2">
              <div class="card-header p-0 border-bottom-0" id="siteAccHColor">
                <h3 class="mb-0">
                  <button type="button" class="btn btn-link btn-block text-left d-flex align-items-start justify-content-between collapsed rounded-0 py-3 px-3" style="white-space: normal;" data-toggle="collapse" data-target="#siteAccCColor" aria-expanded="false" aria-controls="siteAccCColor">
                    <span class="pr-2">
                      <span class="card-title d-block mb-0">Site color</span>
                      <span class="card-subtitle">Accent color used in public CSS (buttons, highlights). Enter a valid HEX value.</span>
                    </span>
                    <i class="fas fa-chevron-down site-acc-chevron mt-1 flex-shrink-0 text-muted" aria-hidden="true"></i>
                  </button>
                </h3>
              </div>
              <div id="siteAccCColor" class="collapse" data-parent="#siteSettingsAccordion" aria-labelledby="siteAccHColor">
              <div class="card-body border-top">
                <% const primaryColorValue = (siteSettings && siteSettings.effective && siteSettings.effective.primaryColor) || '#f59e0b'; %>
                <div class="form-row align-items-end">
                  <div class="form-group col-md-4">
                    <label class="d-flex align-items-center flex-wrap" for="primaryColorInput">
                      Primary color (HEX)
                      <button type="button" class="btn btn-sm site-help-btn ml-2" tabindex="0"
                        data-toggle="popover" data-trigger="hover focus" data-placement="right" data-container="body"
                        title="Primary color"
                        data-content="Sets the CSS variable used on the public site for primary actions and accents. Use a 6-digit HEX such as #f59e0b. The color picker next to it is read-only preview."
                        aria-label="Help: primary site color">
                        ?
                      </button>
                    </label>
                    <input id="primaryColorInput" class="form-control" name="primaryColor" value="<%= primaryColorValue %>" placeholder="#f59e0b" autocomplete="off" aria-describedby="helpPrimaryColor">
                    <span id="helpPrimaryColor" class="sr-only-help">Sets public site accent color via HEX. Preview only on the swatch beside this field.</span>
                  </div>
                  <div class="form-group col-md-2">
                    <label class="d-block small text-muted">Preview</label>
                    <input type="color" class="form-control" value="<%= primaryColorValue %>" disabled aria-hidden="true">
                  </div>
                </div>
              </div>
              </div>
            </div>

            <div class="card settings-card mb-2">
              <div class="card-header p-0 border-bottom-0" id="siteAccHNav">
                <h3 class="mb-0">
                  <button type="button" class="btn btn-link btn-block text-left d-flex align-items-start justify-content-between collapsed rounded-0 py-3 px-3" style="white-space: normal;" data-toggle="collapse" data-target="#siteAccCNav" aria-expanded="false" aria-controls="siteAccCNav">
                    <span class="pr-2">
                      <span class="card-title d-block mb-0">Navbar menu</span>
                      <span class="card-subtitle">Top navigation links shown to visitors (when the theme uses the configured menu). Disable a row to hide that link without deleting it.</span>
                    </span>
                    <i class="fas fa-chevron-down site-acc-chevron mt-1 flex-shrink-0 text-muted" aria-hidden="true"></i>
                  </button>
                </h3>
              </div>
              <div id="siteAccCNav" class="collapse" data-parent="#siteSettingsAccordion" aria-labelledby="siteAccHNav">
              <div class="card-body p-0 border-top">
                <div class="table-responsive">
                  <table class="table table-striped mb-0">
                    <thead>
                      <tr>
                        <th style="width:18%;">Key</th>
                        <th style="width:32%;">Label</th>
                        <th style="width:35%;">URL</th>
                        <th style="width:15%;">
                          Enabled
                          <button type="button" class="btn btn-sm site-help-btn ml-1" tabindex="0"
                            data-toggle="popover" data-trigger="hover focus" data-placement="left" data-container="body"
                            title="Navbar: enabled"
                            data-content="When checked, this row is shown in the public main navigation (subject to theme rules). When unchecked, the link is hidden from the bar but the URL may still work if typed directly."
                            aria-label="Help: navbar enabled column">
                            ?
                          </button>
                        </th>
                      </tr>
                    </thead>
                    <tbody>
                      <% const menuItems = (siteSettings && siteSettings.effective && siteSettings.effective.navbarMenu) || []; %>
                      <% menuItems.forEach(function(item, i) { %>
                        <tr>
                          <td><input class="form-control" name="navbarMenu[<%= i %>][key]" value="<%= item.key %>" aria-label="Navbar key <%= i + 1 %>"></td>
                          <td><input class="form-control" name="navbarMenu[<%= i %>][label]" value="<%= item.label %>" aria-label="Navbar label <%= i + 1 %>"></td>
                          <td><input class="form-control" name="navbarMenu[<%= i %>][url]" value="<%= item.url %>" aria-label="Navbar URL <%= i + 1 %>"></td>
                          <td>
                            <input type="hidden" name="navbarMenu[<%= i %>][enabled]" value="false">
                            <input type="checkbox" name="navbarMenu[<%= i %>][enabled]" value="true" <%= item.enabled ? 'checked' : '' %> aria-label="Enable navbar item <%= item.label || item.key %>">
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              </div>
              </div>
            </div>

            <div class="card settings-card mb-2">
              <div class="card-header p-0 border-bottom-0" id="siteAccHTop">
                <h3 class="mb-0">
                  <button type="button" class="btn btn-link btn-block text-left d-flex align-items-start justify-content-between collapsed rounded-0 py-3 px-3" style="white-space: normal;" data-toggle="collapse" data-target="#siteAccCTop" aria-expanded="false" aria-controls="siteAccCTop">
                    <span class="pr-2">
                      <span class="card-title d-block mb-0">Header top links</span>
                      <span class="card-subtitle">Small text links in the top bar (e.g. Help, Support). Toggle without removing rows.</span>
                    </span>
                    <i class="fas fa-chevron-down site-acc-chevron mt-1 flex-shrink-0 text-muted" aria-hidden="true"></i>
                  </button>
                </h3>
              </div>
              <div id="siteAccCTop" class="collapse" data-parent="#siteSettingsAccordion" aria-labelledby="siteAccHTop">
              <div class="card-body p-0 border-top">
                <div class="table-responsive">
                  <table class="table table-striped mb-0">
                    <thead>
                      <tr>
                        <th style="width:18%;">Key</th>
                        <th style="width:32%;">Label</th>
                        <th style="width:35%;">URL</th>
                        <th style="width:15%;">
                          Enabled
                          <button type="button" class="btn btn-sm site-help-btn ml-1" tabindex="0"
                            data-toggle="popover" data-trigger="hover focus" data-placement="left" data-container="body"
                            title="Top links: enabled"
                            data-content="When checked, this link appears in the header top strip. When unchecked, it is hidden; fallback header links may show if none are enabled."
                            aria-label="Help: top links enabled column">
                            ?
                          </button>
                        </th>
                      </tr>
                    </thead>
                    <tbody>
                      <% const headerTopLinks = (siteSettings && siteSettings.effective && siteSettings.effective.header && siteSettings.effective.header.topLinks) || []; %>
                      <% headerTopLinks.forEach(function(item, i) { %>
                        <tr>
                          <td><input class="form-control" name="header[topLinks][<%= i %>][key]" value="<%= item.key %>"></td>
                          <td><input class="form-control" name="header[topLinks][<%= i %>][label]" value="<%= item.label %>"></td>
                          <td><input class="form-control" name="header[topLinks][<%= i %>][url]" value="<%= item.url %>"></td>
                          <td>
                            <input type="hidden" name="header[topLinks][<%= i %>][enabled]" value="false">
                            <input type="checkbox" name="header[topLinks][<%= i %>][enabled]" value="true" <%= item.enabled ? 'checked' : '' %>>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              </div>
              </div>
            </div>

            <div class="card settings-card mb-2">
              <div class="card-header p-0 border-bottom-0" id="siteAccHContact">
                <h3 class="mb-0">
                  <button type="button" class="btn btn-link btn-block text-left d-flex align-items-start justify-content-between collapsed rounded-0 py-3 px-3" style="white-space: normal;" data-toggle="collapse" data-target="#siteAccCContact" aria-expanded="false" aria-controls="siteAccCContact">
                    <span class="pr-2">
                      <span class="card-title d-block mb-0">Header contact &amp; CTA</span>
                      <span class="card-subtitle">Phone, email, and location shown in the mid header; plus the orange navbar button label and destination.</span>
                    </span>
                    <i class="fas fa-chevron-down site-acc-chevron mt-1 flex-shrink-0 text-muted" aria-hidden="true"></i>
                  </button>
                </h3>
              </div>
              <div id="siteAccCContact" class="collapse" data-parent="#siteSettingsAccordion" aria-labelledby="siteAccHContact">
              <div class="card-body border-top">
                <% const headerInfo = (siteSettings && siteSettings.effective && siteSettings.effective.header) || {}; %>
                <div class="form-group">
                  <label class="d-flex align-items-center" for="headerTopTagline">Top bar welcome text
                    <button type="button" class="btn btn-sm site-help-btn ml-2" tabindex="0"
                      data-toggle="popover" data-trigger="hover focus" data-placement="top" data-container="body"
                      title="Top bar welcome text"
                      data-content="Displayed in the public site's top header. On mobile, long text is shortened automatically."
                      aria-label="Help: top bar welcome text">?</button>
                  </label>
                  <input id="headerTopTagline" class="form-control" name="header[topTagline]" value="<%= headerInfo.topTagline || '' %>" maxlength="160" placeholder="Reliable taxi service and transport solutions!">
                </div>
                <div class="form-row">
                  <div class="form-group col-md-4">
                    <label class="d-flex align-items-center">Phone
                      <button type="button" class="btn btn-sm site-help-btn ml-2" tabindex="0"
                        data-toggle="popover" data-trigger="hover focus" data-placement="top" data-container="body"
                        title="Header phone"
                        data-content="Displayed in the public header with click-to-call. Keep digits consistent with your tel: link expectations."
                        aria-label="Help: header phone">?</button>
                    </label>
                    <input class="form-control" name="header[phone]" value="<%= headerInfo.phone || '' %>" autocomplete="tel">
                  </div>
                  <div class="form-group col-md-4">
                    <label class="d-flex align-items-center">Email
                      <button type="button" class="btn btn-sm site-help-btn ml-2" tabindex="0"
                        data-toggle="popover" data-trigger="hover focus" data-placement="top" data-container="body"
                        title="Header email"
                        data-content="Shown as plain text in the header info block (not a mailto by default). Use your public contact address."
                        aria-label="Help: header email">?</button>
                    </label>
                    <input class="form-control" name="header[email]" value="<%= headerInfo.email || '' %>" autocomplete="email">
                  </div>
                  <div class="form-group col-md-4">
                    <label class="d-flex align-items-center">Location
                      <button type="button" class="btn btn-sm site-help-btn ml-2" tabindex="0"
                        data-toggle="popover" data-trigger="hover focus" data-placement="top" data-container="body"
                        title="Header location"
                        data-content="Short location line in the header (city/region). Does not change map embeds elsewhere unless your theme uses it."
                        aria-label="Help: header location">?</button>
                    </label>
                    <input class="form-control" name="header[location]" value="<%= headerInfo.location || '' %>">
                  </div>
                </div>
                <div class="form-row">
                  <div class="form-group col-md-6">
                    <label class="d-flex align-items-center">Navbar button label
                      <button type="button" class="btn btn-sm site-help-btn ml-2" tabindex="0"
                        data-toggle="popover" data-trigger="hover focus" data-placement="top" data-container="body"
                        title="Navbar button label"
                        data-content="Text on the primary call-to-action button in the public nav (e.g. Book Taxi)."
                        aria-label="Help: navbar button label">?</button>
                    </label>
                    <input class="form-control" name="header[navButtonLabel]" value="<%= headerInfo.navButtonLabel || '' %>">
                  </div>
                  <div class="form-group col-md-6">
                    <label class="d-flex align-items-center">Navbar button URL
                      <button type="button" class="btn btn-sm site-help-btn ml-2" tabindex="0"
                        data-toggle="popover" data-trigger="hover focus" data-placement="top" data-container="body"
                        title="Navbar button URL"
                        data-content="Target path when visitors click the navbar CTA (e.g. /book-taxi). Use a site-relative path."
                        aria-label="Help: navbar button URL">?</button>
                    </label>
                    <input class="form-control" name="header[navButtonUrl]" value="<%= headerInfo.navButtonUrl || '' %>">
                  </div>
                </div>
              </div>
              </div>
            </div>

            <div class="card settings-card mb-2">
              <div class="card-header p-0 border-bottom-0" id="siteAccHSocial">
                <h3 class="mb-0">
                  <button type="button" class="btn btn-link btn-block text-left d-flex align-items-start justify-content-between collapsed rounded-0 py-3 px-3" style="white-space: normal;" data-toggle="collapse" data-target="#siteAccCSocial" aria-expanded="false" aria-controls="siteAccCSocial">
                    <span class="pr-2">
                      <span class="card-title d-block mb-0">Header social links</span>
                      <span class="card-subtitle">Icon buttons in the top bar. Icon class should match your loaded CSS (e.g. Font Awesome).</span>
                    </span>
                    <i class="fas fa-chevron-down site-acc-chevron mt-1 flex-shrink-0 text-muted" aria-hidden="true"></i>
                  </button>
                </h3>
              </div>
              <div id="siteAccCSocial" class="collapse" data-parent="#siteSettingsAccordion" aria-labelledby="siteAccHSocial">
              <div class="card-body p-0 border-top">
                <div class="table-responsive">
                  <table class="table table-striped mb-0">
                    <thead>
                      <tr>
                        <th style="width:20%;">Key</th>
                        <th style="width:35%;">Icon class</th>
                        <th style="width:30%;">URL</th>
                        <th style="width:15%;">
                          Enabled
                          <button type="button" class="btn btn-sm site-help-btn ml-1" tabindex="0"
                            data-toggle="popover" data-trigger="hover focus" data-placement="left" data-container="body"
                            title="Social links: enabled"
                            data-content="When checked, this icon link appears in the header social row. When unchecked, the icon is hidden."
                            aria-label="Help: social links enabled column">
                            ?
                          </button>
                        </th>
                      </tr>
                    </thead>
                    <tbody>
                      <% const socialItems = (siteSettings && siteSettings.effective && siteSettings.effective.header && siteSettings.effective.header.socialLinks) || []; %>
                      <% socialItems.forEach(function(item, i) { %>
                        <tr>
                          <td><input class="form-control" name="header[socialLinks][<%= i %>][key]" value="<%= item.key %>"></td>
                          <td><input class="form-control" name="header[socialLinks][<%= i %>][iconClass]" value="<%= item.iconClass %>"></td>
                          <td><input class="form-control" name="header[socialLinks][<%= i %>][url]" value="<%= item.url %>"></td>
                          <td>
                            <input type="hidden" name="header[socialLinks][<%= i %>][enabled]" value="false">
                            <input type="checkbox" name="header[socialLinks][<%= i %>][enabled]" value="true" <%= item.enabled ? 'checked' : '' %>>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              </div>
              </div>
            </div>

            <div class="card settings-card mb-2">
              <div class="card-header p-0 border-bottom-0" id="siteAccHStickyIcons">
                <h3 class="mb-0">
                  <button type="button" class="btn btn-link btn-block text-left d-flex align-items-start justify-content-between collapsed rounded-0 py-3 px-3" style="white-space: normal;" data-toggle="collapse" data-target="#siteAccCStickyIcons" aria-expanded="false" aria-controls="siteAccCStickyIcons">
                    <span class="pr-2">
                      <span class="card-title d-block mb-0">Sticky WhatsApp button</span>
                      <span class="card-subtitle">Control the floating WhatsApp button shown on public pages: visibility, color, phone number, and default message.</span>
                    </span>
                    <i class="fas fa-chevron-down site-acc-chevron mt-1 flex-shrink-0 text-muted" aria-hidden="true"></i>
                  </button>
                </h3>
              </div>
              <div id="siteAccCStickyIcons" class="collapse" data-parent="#siteSettingsAccordion" aria-labelledby="siteAccHStickyIcons">
              <div class="card-body border-top">
                <% const stickyWhatsapp = (siteSettings && siteSettings.effective && siteSettings.effective.stickyIcons && siteSettings.effective.stickyIcons.whatsapp) || {}; %>
                <div class="form-row align-items-end">
                  <div class="form-group col-md-3">
                    <label class="d-block">Show WhatsApp button</label>
                    <input type="hidden" name="stickyIcons[whatsapp][enabled]" value="false">
                    <div class="custom-control custom-switch">
                      <input type="checkbox" class="custom-control-input" id="stickyWhatsappEnabled" name="stickyIcons[whatsapp][enabled]" value="true" <%= stickyWhatsapp.enabled !== false ? 'checked' : '' %>>
                      <label class="custom-control-label" for="stickyWhatsappEnabled">Enabled on public site</label>
                    </div>
                  </div>
                  <div class="form-group col-md-3">
                    <label for="stickyWhatsappColor">Icon color</label>
                    <input id="stickyWhatsappColor" class="form-control" name="stickyIcons[whatsapp][color]" value="<%= stickyWhatsapp.color || '#25d366' %>" placeholder="#25d366" autocomplete="off">
                  </div>
                  <div class="form-group col-md-6">
                    <label for="stickyWhatsappPhone">WhatsApp phone number</label>
                    <input id="stickyWhatsappPhone" class="form-control" name="stickyIcons[whatsapp][phone]" value="<%= stickyWhatsapp.phone || '' %>" placeholder="+15551234567" autocomplete="tel">
                    <small class="form-text text-muted">Use international format. Example: +15551234567.</small>
                  </div>
                </div>
                <div class="form-group mb-0">
                  <label for="stickyWhatsappMessage">Default WhatsApp message</label>
                  <textarea id="stickyWhatsappMessage" class="form-control" name="stickyIcons[whatsapp][message]" rows="3" maxlength="300" placeholder="Hello Taxiofany, I would like to book a taxi."><%= stickyWhatsapp.message || 'Hello Taxiofany, I would like to book a taxi.' %></textarea>
                </div>
              </div>
              </div>
            </div>

            <div class="card settings-card mb-2">
              <div class="card-header p-0 border-bottom-0" id="siteAccHPages">
                <h3 class="mb-0">
                  <button type="button" class="btn btn-link btn-block text-left d-flex align-items-start justify-content-between collapsed rounded-0 py-3 px-3" style="white-space: normal;" data-toggle="collapse" data-target="#siteAccCPages" aria-expanded="false" aria-controls="siteAccCPages">
                    <span class="pr-2">
                      <span class="card-title d-block mb-0">Pages</span>
                      <span class="card-subtitle">Visibility flags used by public middleware: disabling a page can return 404 for that path unless another rule allows it (e.g. menu or home exception).</span>
                    </span>
                    <i class="fas fa-chevron-down site-acc-chevron mt-1 flex-shrink-0 text-muted" aria-hidden="true"></i>
                  </button>
                </h3>
              </div>
              <div id="siteAccCPages" class="collapse" data-parent="#siteSettingsAccordion" aria-labelledby="siteAccHPages">
              <div class="card-body p-0 border-top">
                <div class="table-responsive">
                  <table class="table table-striped mb-0">
                    <thead>
                      <tr>
                        <th style="width:18%;">Key</th>
                        <th style="width:32%;">Title</th>
                        <th style="width:35%;">Path</th>
                        <th style="width:15%;">
                          Enabled
                          <button type="button" class="btn btn-sm site-help-btn ml-1" tabindex="0"
                            data-toggle="popover" data-trigger="hover focus" data-placement="left" data-container="body"
                            title="Pages: enabled"
                            data-content="Controls whether this path is treated as enabled for visitors. If disabled and no exception applies, the public site may show a 404 for matching URLs. Account and profile paths are always exempt in middleware."
                            aria-label="Help: pages enabled column">
                            ?
                          </button>
                        </th>
                      </tr>
                    </thead>
                    <tbody>
                      <% const pageItems = (siteSettings && siteSettings.effective && siteSettings.effective.pages) || []; %>
                      <% pageItems.forEach(function(item, i) { %>
                        <tr>
                          <td><input class="form-control" name="pages[<%= i %>][key]" value="<%= item.key %>"></td>
                          <td><input class="form-control" name="pages[<%= i %>][title]" value="<%= item.title %>"></td>
                          <td><input class="form-control" name="pages[<%= i %>][path]" value="<%= item.path %>"></td>
                          <td>
                            <input type="hidden" name="pages[<%= i %>][enabled]" value="false">
                            <input type="checkbox" name="pages[<%= i %>][enabled]" value="true" <%= item.enabled ? 'checked' : '' %>>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              </div>
              </div>
            </div>
            </div>

            <div class="site-settings-sticky">
              <button type="submit" class="btn btn-primary btn-lg" form="siteSettingsForm">
                <i class="fas fa-save mr-1"></i> Save site settings
              </button>
              <span class="text-muted small ml-3 d-none d-md-inline">Changes apply to the public site after save (cache may refresh immediately).</span>
            </div>
          </form>
        </div>
      </section>
    </div>

    <footer class="main-footer">
      <strong>Taxiofany Admin.</strong>
    </footer>
  </div>

  <%- include('../../shared/partials/admin-scripts') %>
  <script>
    (function () {
      if (typeof jQuery === 'undefined' || !jQuery.fn.popover) return;
      jQuery(function () {
        jQuery('[data-toggle="popover"]').popover({
          container: 'body',
          html: false
        });
      });
    })();
  </script>
</body>
</html>
