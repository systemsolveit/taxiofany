<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../../shared/partials/admin-head', { pageTitle: pageTitle }) %>
  <style>
    .settings-tabs .nav-link {
      border-radius: 999px;
      margin-right: 0.4rem;
      padding: 0.45rem 0.9rem;
    }

    .settings-card {
      border: 1px solid #e5e7eb;
      border-radius: 0.9rem;
      background: #fff;
    }

    .hint-box {
      border: 1px solid #fef3c7;
      background: #fffbeb;
      color: #92400e;
      border-radius: 0.7rem;
      padding: 0.75rem 1rem;
      margin-bottom: 1rem;
    }

    .log-console {
      background: #0f172a;
      color: #e2e8f0;
      border-radius: 0.8rem;
      padding: 1rem;
      font-family: Consolas, Monaco, monospace;
      font-size: 0.86rem;
      max-height: 65vh;
      overflow: auto;
    }

    .log-entry {
      border-bottom: 1px solid rgba(148, 163, 184, 0.18);
      padding: 0.75rem 0;
    }

    .log-entry:last-child {
      border-bottom: 0;
      padding-bottom: 0;
    }

    .log-meta {
      color: #93c5fd;
      margin-bottom: 0.35rem;
      word-break: break-all;
    }

    .log-level {
      display: inline-block;
      min-width: 4.5rem;
      text-transform: uppercase;
      font-weight: 700;
    }

    .log-message {
      white-space: pre-wrap;
      word-break: break-word;
    }

    .log-json {
      color: #94a3b8;
      margin-top: 0.35rem;
      white-space: pre-wrap;
      word-break: break-word;
    }
  </style>
</head>
<body class="hold-transition sidebar-mini">
  <div class="wrapper">
    <%- include('../../shared/partials/admin-topbar') %>
    <%- include('../../shared/partials/admin-sidebar', { activeSection: activeSection }) %>

    <div class="content-wrapper">
      <section class="content-header">
        <div class="container-fluid">
          <h1 class="mb-0">Settings</h1>
        </div>
      </section>

      <section class="content">
        <div class="container-fluid">
          <% if (notice) { %>
            <div class="alert alert-<%= notice.type %>"><%= notice.message %></div>
          <% } %>

          <div class="settings-tabs mb-3">
            <ul class="nav nav-pills">
              <li class="nav-item"><a class="nav-link" href="/admin/settings/mail"><i class="fas fa-envelope mr-1"></i>Mail Integrations</a></li>
              <li class="nav-item"><a class="nav-link" href="/admin/settings/site"><i class="fas fa-palette mr-1"></i>Site & Navigation</a></li>
              <li class="nav-item"><a class="nav-link active" href="/admin/settings/logs"><i class="fas fa-file-alt mr-1"></i>Logs</a></li>
            </ul>
          </div>

          <div class="hint-box">
            <strong>Control Point:</strong> Winston now captures backend console output, request logs, handled errors, and process failures into persistent log files.
            <div>Current level: <strong><%= (logSettings && logSettings.level) || 'info' %></strong></div>
            <div>Combined log file: <strong><%= logSettings && logSettings.files ? logSettings.files.combined : '' %></strong></div>
          </div>

          <div class="card settings-card mb-3">
            <div class="card-header">
              <h3 class="card-title">Log Filters</h3>
            </div>
            <div class="card-body">
              <form method="get" action="/admin/settings/logs">
                <div class="form-row align-items-end">
                  <div class="form-group col-md-3">
                    <label>Level</label>
                    <select class="form-control" name="level">
                      <option value="" <%= !filters || !filters.level ? 'selected' : '' %>>All levels</option>
                      <option value="error" <%= filters && filters.level === 'error' ? 'selected' : '' %>>Error</option>
                      <option value="warn" <%= filters && filters.level === 'warn' ? 'selected' : '' %>>Warn</option>
                      <option value="info" <%= filters && filters.level === 'info' ? 'selected' : '' %>>Info</option>
                      <option value="http" <%= filters && filters.level === 'http' ? 'selected' : '' %>>HTTP</option>
                      <option value="debug" <%= filters && filters.level === 'debug' ? 'selected' : '' %>>Debug</option>
                    </select>
                  </div>
                  <div class="form-group col-md-5">
                    <label>Search</label>
                    <input class="form-control" name="search" value="<%= (filters && filters.search) || '' %>" placeholder="http_request, NOT_FOUND, smtp, startup...">
                  </div>
                  <div class="form-group col-md-2">
                    <label>Limit</label>
                    <input type="number" min="1" max="500" class="form-control" name="limit" value="<%= (filters && filters.limit) || '100' %>">
                  </div>
                  <div class="form-group col-md-2 d-flex" style="gap:0.5rem;">
                    <button type="submit" class="btn btn-primary flex-fill">Refresh</button>
                    <a href="/admin/settings/logs" class="btn btn-outline-secondary flex-fill">Reset</a>
                  </div>
                </div>
              </form>
            </div>
          </div>

          <div class="card settings-card">
            <div class="card-header d-flex justify-content-between align-items-center">
              <h3 class="card-title mb-0">Recent Backend Logs</h3>
              <span class="text-muted small"><%= logSettings && typeof logSettings.count === 'number' ? logSettings.count : 0 %> entries</span>
            </div>
            <div class="card-body">
              <% const entries = (logSettings && logSettings.entries) || []; %>
              <div class="log-console">
                <% if (!entries.length) { %>
                  <div class="text-muted">No log entries matched the current filters.</div>
                <% } else { %>
                  <% entries.forEach(function(entry) { %>
                    <div class="log-entry">
                      <div class="log-meta">
                        <span class="log-level"><%= entry.level || 'info' %></span>
                        <span><%= entry.timestamp || 'no-timestamp' %></span>
                        <% if (entry.source) { %>
                          <span> | source: <%= entry.source %></span>
                        <% } %>
                        <% if (entry.service) { %>
                          <span> | service: <%= entry.service %></span>
                        <% } %>
                      </div>
                      <div class="log-message"><%= entry.message || '' %></div>
                      <% if (entry.meta) { %>
                        <div class="log-json"><%= JSON.stringify(entry.meta, null, 2) %></div>
                      <% } %>
                    </div>
                  <% }) %>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>

    <footer class="main-footer">
      <strong>Taxiofany Admin.</strong>
    </footer>
  </div>

  <%- include('../../shared/partials/admin-scripts') %>
</body>
</html>