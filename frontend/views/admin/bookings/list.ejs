<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../../shared/partials/admin-head', { pageTitle: pageTitle }) %>
  <style>
    .booking-route {
      display: flex;
      flex-direction: column;
    }

    .booking-route small {
      color: #6b7280;
    }
  </style>
</head>
<body class="hold-transition sidebar-mini">
  <div class="wrapper">
    <%- include('../../shared/partials/admin-topbar') %>
    <%- include('../../shared/partials/admin-sidebar', { activeSection: activeSection }) %>

    <div class="content-wrapper">
      <section class="content-header">
        <div class="container-fluid">
          <h1>Bookings Management</h1>
        </div>
      </section>

      <section class="content">
        <div class="container-fluid">
          <% if (notice) { %>
            <div class="alert alert-<%= notice.type %>"><%= notice.message %></div>
          <% } %>

          <div class="card">
            <div class="card-header">
              <h3 class="card-title">Ride Requests</h3>
            </div>
            <div class="card-body table-responsive p-0">
              <table class="table table-hover text-nowrap">
                <thead>
                  <tr>
                    <th>Code</th>
                    <th>Customer</th>
                    <th>Route</th>
                    <th>Schedule</th>
                    <th>Status</th>
                    <th class="text-right">Action</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (!bookings || !bookings.length) { %>
                    <tr>
                      <td colspan="6" class="text-center text-muted py-4">No ride requests submitted yet.</td>
                    </tr>
                  <% } else { %>
                    <% bookings.forEach(function(booking) { %>
                      <% const status = String(booking.status || 'pending').toLowerCase(); %>
                      <tr>
                        <td><a href="/admin/bookings/<%= booking._id %>"><%= booking.bookingCode %></a></td>
                        <td>
                          <strong><%= booking.customerName %></strong>
                          <div class="text-muted small"><%= booking.customerEmail || '-' %></div>
                        </td>
                        <td>
                          <div class="booking-route">
                            <span><%= booking.pickupLocation %></span>
                            <small>to <%= booking.destinationLocation %></small>
                          </div>
                        </td>
                        <td><%= booking.requestedDateText || '-' %><%= booking.rideTime ? (' / ' + booking.rideTime) : '' %></td>
                        <td><span class="badge badge-<%= status === 'completed' ? 'success' : status === 'pending' ? 'warning' : status === 'cancelled' ? 'danger' : 'info' %>"><%= status %></span></td>
                        <td class="text-right"><a href="/admin/bookings/<%= booking._id %>" class="btn btn-sm btn-outline-primary">Open</a></td>
                      </tr>
                    <% }) %>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </section>
    </div>

    <footer class="main-footer">
      <strong>Taxiofany Admin.</strong>
    </footer>
  </div>

  <%- include('../../shared/partials/admin-scripts') %>
</body>
</html>
