<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../../shared/partials/admin-head', { pageTitle: pageTitle }) %>
  <style>
    .user-create-hero {
      border: 1px solid #dbeafe;
      background: linear-gradient(135deg, #eff6ff 0%, #f8fafc 100%);
      border-radius: 0.9rem;
      padding: 1.1rem 1.25rem;
      margin-bottom: 1rem;
    }

    .user-create-hero p {
      margin: 0.35rem 0 0;
      color: #64748b;
    }
  </style>
</head>
<body class="hold-transition sidebar-mini">
  <div class="wrapper">
    <%- include('../../shared/partials/admin-topbar') %>
    <%- include('../../shared/partials/admin-sidebar', { activeSection: activeSection }) %>

    <div class="content-wrapper">
      <section class="content-header">
        <div class="container-fluid d-flex justify-content-between align-items-center">
          <h1 class="mb-0">Create User</h1>
          <a href="/admin/users" class="btn btn-outline-secondary">Back to Users</a>
        </div>
      </section>

      <section class="content">
        <div class="container-fluid">
          <% if (notice) { %>
            <div class="alert alert-<%= notice.type %>"><%= notice.message %></div>
          <% } %>

          <div class="user-create-hero">
            <h5 class="mb-0">New Account Setup</h5>
            <p>Create a customer, driver, dispatcher, or admin account with the initial role and status already assigned.</p>
          </div>

          <div class="card card-primary card-outline">
            <div class="card-body">
              <form method="post" action="/admin/users/create">
                <div class="form-row">
                  <div class="form-group col-md-6">
                    <label>Full Name</label>
                    <input class="form-control" name="fullName" value="<%= formValues.fullName || '' %>" required>
                  </div>
                  <div class="form-group col-md-6">
                    <label>Email Address</label>
                    <input type="email" class="form-control" name="email" value="<%= formValues.email || '' %>" required>
                  </div>
                </div>

                <div class="form-row">
                  <div class="form-group col-md-6">
                    <label>Phone</label>
                    <input class="form-control" name="phone" value="<%= formValues.phone || '' %>" placeholder="Optional contact number">
                  </div>
                  <div class="form-group col-md-6">
                    <label>Temporary Password</label>
                    <input type="password" class="form-control" name="password" minlength="6" required>
                    <small class="form-text text-muted">Minimum 6 characters.</small>
                  </div>
                </div>

                <div class="form-row">
                  <div class="form-group col-md-6">
                    <label>Role</label>
                    <select class="form-control" name="role">
                      <% ['customer', 'driver', 'dispatcher', 'admin', 'super_admin'].forEach(function(role) { %>
                        <option value="<%= role %>" <%= String(formValues.role || 'customer') === role ? 'selected' : '' %>><%= role %></option>
                      <% }) %>
                    </select>
                  </div>
                  <div class="form-group col-md-6">
                    <label>Status</label>
                    <select class="form-control" name="status">
                      <% ['active', 'pending', 'suspended'].forEach(function(status) { %>
                        <option value="<%= status %>" <%= String(formValues.status || 'active') === status ? 'selected' : '' %>><%= status %></option>
                      <% }) %>
                    </select>
                  </div>
                </div>

                <div class="d-flex" style="gap:0.5rem;">
                  <button type="submit" class="btn btn-primary">Create User</button>
                  <a href="/admin/users" class="btn btn-outline-secondary">Cancel</a>
                </div>
              </form>
            </div>
          </div>
        </div>
      </section>
    </div>

    <footer class="main-footer">
      <strong>Taxiofany Admin.</strong>
    </footer>
  </div>

  <%- include('../../shared/partials/admin-scripts') %>
</body>
</html>
