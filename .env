# Shared environment file for backend and frontend

# Common
NODE_ENV=production

# Backend
BACKEND_PORT=3000
MONGO_URI=mongodb://127.0.0.1:27017/taxiofany
MONGO_URI_DOCKER=mongodb://mongo:27017/taxiofany
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1d
SUPER_ADMIN_EMAIL=admin@taxiofany.com
SUPER_ADMIN_PASSWORD=asdfgh
SUPER_ADMIN_FULL_NAME=Taxiofany Super Admin
SUPER_ADMIN_PHONE=

# Frontend
FRONTEND_PORT=3001
APP_NAME=Taxiofany Frontend
API_BASE_URL=http://localhost:3000/api/v1
API_BASE_URL_DOCKER=http://backend:3000/api/v1
SESSION_SECRET=change-me-frontend-session-secret
SESSION_COOKIE_NAME=taxiofany_admin_sid
SESSION_COOKIE_SECURE=false
SESSION_STORE_MONGO_URI=mongodb://mongo:27017/taxiofany
